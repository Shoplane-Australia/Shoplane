{% comment %} Shoplane Collection Hero Section — Collection page header banner {% endcomment %}

<section class="collection-hero" aria-label="{% render 'auto-alt', title: collection.title, image: section.settings.background_image %}" style="{% if section.settings.background_image %}background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');{% endif %}">
  <div class="collection-hero__overlay"></div>
  <div class="container">
    <div class="collection-hero__content animate-on-scroll">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol class="breadcrumbs__list">
          <li><a href="/">Home</a></li>
          {% if collection.handle == 'all' %}
            <li aria-current="page">All Stores</li>
          {% else %}
            <li><a href="/collections">Stores</a></li>
            <li aria-current="page">{{ collection.title }}</li>
          {% endif %}
        </ol>
      </nav>

      <h1 class="collection-hero__title">{{ collection.title }}</h1>

      {% if collection.description != blank %}
        <div class="collection-hero__description">
          {{ collection.description }}
        </div>
      {% endif %}

      <span class="collection-hero__count">
        {{ collection.products_count }} {{ collection.products_count | pluralize: 'store', 'stores' }} available
      </span>
    </div>
  </div>
</section>

<style>
  .collection-hero {
    position: relative;
    background: var(--color-dark, #0A0A0A);
    background-size: cover;
    background-position: center;
    padding: 6rem 0 4rem;
    overflow: hidden;
    min-height: 280px;
    display: flex;
    align-items: flex-end;
  }
  .collection-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,10,10,0.7) 0%, rgba(10,10,10,0.9) 100%);
  }
  .collection-hero__content {
    position: relative;
    z-index: 1;
    max-width: 640px;
  }
  .collection-hero .breadcrumbs__list {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    font-size: 0.8125rem;
  }
  .collection-hero .breadcrumbs__list li:not(:last-child)::after {
    content: '›';
    margin-left: 0.5rem;
    color: rgba(255,255,255,0.3);
  }
  .collection-hero .breadcrumbs__list a {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.2s;
  }
  .collection-hero .breadcrumbs__list a:hover {
    color: var(--color-teal, #00D4AA);
  }
  .collection-hero .breadcrumbs__list [aria-current] {
    color: rgba(255,255,255,0.7);
  }
  .collection-hero__title {
    font-size: 2.5rem;
    font-weight: 800;
    color: #fff;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .collection-hero__description {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .collection-hero__count {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    background: rgba(255,255,255,0.08);
    border-radius: 20px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-teal, #00D4AA);
  }

  @media (max-width: 767px) {
    .collection-hero {
      padding: 5rem 0 2.5rem;
      min-height: 220px;
    }
    .collection-hero__title {
      font-size: 1.75rem;
    }
  }
</style>

{% schema %}
{
  "name": "Collection Hero",
  "tag": "div",
  "class": "collection-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Optional. Recommended size: 1920x600px"
    }
  ]
}
{% endschema %}
