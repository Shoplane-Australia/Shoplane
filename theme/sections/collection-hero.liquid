{% comment %} Shoplane Collection Hero — Editorial light {% endcomment %}

<section
  class="collection-hero"
  data-header-theme="light"
  aria-label="{{ collection.title | escape }}"
  {% if section.settings.background_image %}
    style="--collection-hero-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');"
  {% endif %}
>
  <div class="collection-hero__media" aria-hidden="true"></div>
  <div class="container">
    <div class="collection-hero__content animate-on-scroll">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol class="breadcrumbs__list">
          <li><a href="{{ routes.root_url }}">Home</a></li>
          {% if collection.handle == 'all' %}
            <li aria-current="page">All Stores</li>
          {% else %}
            <li><a href="{{ routes.collections_url }}">Stores</a></li>
            <li aria-current="page">{{ collection.title }}</li>
          {% endif %}
        </ol>
      </nav>

      <h1 class="collection-hero__title">{{ collection.title }}</h1>

      {% if collection.description != blank %}
        <div class="collection-hero__description">
          {{ collection.description }}
        </div>
      {% endif %}

      <span class="collection-hero__count">
        {{ collection.products_count }} {{ collection.products_count | pluralize: 'store', 'stores' }} available
      </span>
    </div>
  </div>
</section>

<style>
  .collection-hero {
    position: relative;
    background: var(--color-background, #FAFAF8);
    padding: calc(var(--header-height, 72px) + 3.5rem) 0 3rem;
    overflow: hidden;
    min-height: 0;
  }

  .collection-hero__media {
    position: absolute;
    inset: 0;
    background-image: var(--collection-hero-image, none);
    background-size: cover;
    background-position: center;
    opacity: 0.18;
    pointer-events: none;
  }

  .collection-hero__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(250, 250, 248, 0.7) 0%, rgba(250, 250, 248, 0.95) 70%, var(--color-background, #FAFAF8) 100%);
  }

  .collection-hero__content {
    position: relative;
    z-index: 1;
    max-width: 640px;
  }

  .collection-hero .breadcrumbs__list {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    font-family: var(--font-body);
    font-size: 0.8125rem;
  }

  .collection-hero .breadcrumbs__list li:not(:last-child)::after {
    content: '›';
    margin-left: 0.5rem;
    color: var(--color-text-tertiary);
  }

  .collection-hero .breadcrumbs__list a {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .collection-hero .breadcrumbs__list a:hover {
    color: var(--color-accent);
  }

  .collection-hero .breadcrumbs__list [aria-current] {
    color: var(--color-text);
  }

  .collection-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.75rem;
    letter-spacing: -0.03em;
    line-height: 1.15;
  }

  .collection-hero__description {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .collection-hero__description p {
    margin: 0;
  }

  .collection-hero__count {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    padding: 0;
    background: none;
    border-radius: 0;
  }

  @media (max-width: 767px) {
    .collection-hero {
      padding: calc(var(--header-height, 72px) + 2.5rem) 0 2rem;
    }

    .collection-hero__title {
      font-size: 1.75rem;
    }
  }
</style>

{% schema %}
{
  "name": "Collection Hero",
  "tag": "div",
  "class": "collection-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Optional soft wash. Recommended: 1920x600px"
    }
  ]
}
{% endschema %}
