<section
  id="growth-features-{{ section.id }}"
  class="growth-features section-lg"
  data-section-id="{{ section.id }}"
  data-section-type="growth-features"
>
  <div class="container">
    <div class="growth-features__layout">
      <div class="growth-features__intro{% unless request.design_mode %} animate-on-scroll stagger-1{% endunless %}">
        {%- if section.settings.eyebrow != blank -%}
          <span class="growth-features__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <div class="growth-features__icon-circle" aria-hidden="true">
          {%- if section.settings.intro_image != blank -%}
            <img
              src="{{ section.settings.intro_image | image_url: width: 160 }}"
              alt=""
              width="80"
              height="80"
              loading="lazy"
            >
          {%- else -%}
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <circle cx="20" cy="20" r="16" stroke="currentColor" stroke-width="2"/>
              <circle cx="20" cy="20" r="8" stroke="currentColor" stroke-width="2"/>
              <circle cx="20" cy="20" r="2" fill="currentColor"/>
              <path d="M20 4v4M20 32v4M4 20h4M32 20h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          {%- endif -%}
        </div>
        <h2 class="growth-features__heading">
          {{ section.settings.heading }}
        </h2>
        {%- if section.settings.description != blank -%}
          <p class="growth-features__description">
            {{ section.settings.description }}
          </p>
        {%- endif -%}
      </div>

      <div class="growth-features__items">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <article
              class="growth-features__item{% unless request.design_mode %} animate-on-scroll stagger-{{ forloop.index | plus: 1 }}{% endunless %}"
              {{ block.shopify_attributes }}
            >
              <span class="growth-features__item-icon" aria-hidden="true">
                {% render 'icon', icon: block.settings.icon_name %}
              </span>
              <div class="growth-features__item-content">
                <h3 class="growth-features__item-title">{{ block.settings.title }}</h3>
                {%- if block.settings.description != blank -%}
                  <p class="growth-features__item-desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #growth-features-{{ section.id }} {
    background: var(--color-surface);
    padding: var(--space-16) 0;
  }

  #growth-features-{{ section.id }} .growth-features__layout {
    display: grid;
    grid-template-columns: minmax(260px, 5fr) minmax(320px, 7fr);
    gap: var(--space-12);
    align-items: center;
  }

  #growth-features-{{ section.id }} .growth-features__eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  #growth-features-{{ section.id }} .growth-features__icon-circle {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(108, 99, 255, 0.12), rgba(0, 212, 170, 0.1));
    border: 1px solid rgba(108, 99, 255, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    margin-bottom: var(--space-6);
    overflow: hidden;
  }

  #growth-features-{{ section.id }} .growth-features__icon-circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #growth-features-{{ section.id }} .growth-features__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0 0 var(--space-4);
    line-height: 1.15;
  }

  #growth-features-{{ section.id }} .growth-features__description {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    max-width: 36ch;
  }

  #growth-features-{{ section.id }} .growth-features__items {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  #growth-features-{{ section.id }} .growth-features__item {
    display: grid;
    grid-template-columns: 56px 1fr;
    align-items: stretch;
    min-height: 100%;
    background: var(--color-background);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  #growth-features-{{ section.id }} .growth-features__item:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.07);
  }

  #growth-features-{{ section.id }} .growth-features__item-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, rgba(108, 99, 255, 0.14), rgba(0, 212, 170, 0.08));
    color: var(--color-accent);
    border-right: 1px solid rgba(108, 99, 255, 0.08);
  }

  #growth-features-{{ section.id }} .growth-features__item-icon svg {
    width: 22px;
    height: 22px;
  }

  #growth-features-{{ section.id }} .growth-features__item-content {
    padding: var(--space-5) var(--space-5) var(--space-5) var(--space-4);
    min-width: 0;
  }

  #growth-features-{{ section.id }} .growth-features__item-title {
    font-family: var(--font-mono);
    font-size: 0.975rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
    line-height: 1.35;
  }

  #growth-features-{{ section.id }} .growth-features__item-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin: 0;
  }

  @media (max-width: 991px) {
    #growth-features-{{ section.id }} .growth-features__layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    #growth-features-{{ section.id }} .growth-features__intro {
      text-align: center;
    }

    #growth-features-{{ section.id }} .growth-features__icon-circle {
      margin-left: auto;
      margin-right: auto;
    }

    #growth-features-{{ section.id }} .growth-features__description {
      max-width: none;
      margin: 0 auto;
    }
  }

  @media (max-width: 640px) {
    #growth-features-{{ section.id }} .growth-features__items {
      grid-template-columns: 1fr;
    }
  }

  {% if request.design_mode %}
    #growth-features-{{ section.id }} .animate-on-scroll {
      opacity: 1;
      transform: none;
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "Growth Features",
  "tag": "section",
  "class": "growth-features-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "image_picker",
      "id": "intro_image",
      "label": "Intro icon image",
      "info": "Optional. Replaces the default target icon on the left."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for Real Ecommerce Growth"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every Shoplane store is designed with the right products, supplier connections, and a structure built to scale — not just launch."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icon",
          "options": [
            { "value": "check-circle", "label": "Check Circle" },
            { "value": "star", "label": "Star" },
            { "value": "zap", "label": "Zap" },
            { "value": "shield", "label": "Shield" },
            { "value": "store", "label": "Store" },
            { "value": "check", "label": "Check" }
          ],
          "default": "check-circle"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Built for demand"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Products selected for demand, not guesswork"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Growth Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon_name": "check-circle",
            "title": "Products selected for demand, not guesswork",
            "description": "Researched, high-demand products already loaded and organised."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "store",
            "title": "Supplier connections already handled",
            "description": "Verified supplier details and integration guidance included."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "zap",
            "title": "Conversion-focused design",
            "description": "Mobile-optimised layouts built to turn visitors into buyers."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "star",
            "title": "Performance from day one",
            "description": "Fast, clean, structured stores ready to sell immediately."
          }
        }
      ]
    }
  ]
}
{% endschema %}
