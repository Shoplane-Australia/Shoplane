<section
  id="growth-features-{{ section.id }}"
  class="growth-features section-lg"
  data-section-id="{{ section.id }}"
  data-section-type="growth-features"
>
  <div class="container">
    <div class="growth-features__layout">
      <div class="growth-features__intro{% unless request.design_mode %} animate-on-scroll stagger-1{% endunless %}">
        {%- if section.settings.eyebrow != blank -%}
          <span class="growth-features__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="growth-features__heading">
          {{ section.settings.heading }}
        </h2>
        {%- if section.settings.description != blank -%}
          <p class="growth-features__description">
            {{ section.settings.description }}
          </p>
        {%- endif -%}
      </div>

      <ol class="growth-features__items">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <li
              class="growth-features__item{% unless request.design_mode %} animate-on-scroll stagger-{{ forloop.index | plus: 1 }}{% endunless %}"
              {{ block.shopify_attributes }}
            >
              <span class="growth-features__item-num" aria-hidden="true">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
              <div class="growth-features__item-content">
                <h3 class="growth-features__item-title">{{ block.settings.title }}</h3>
                {%- if block.settings.description != blank -%}
                  <p class="growth-features__item-desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ol>
    </div>
  </div>
</section>

<style>
  #growth-features-{{ section.id }} {
    background: var(--color-surface, #F0EEE9);
    padding: var(--space-20) 0;
  }

  #growth-features-{{ section.id }} .growth-features__layout {
    display: grid;
    grid-template-columns: minmax(260px, 5fr) minmax(320px, 7fr);
    gap: var(--space-16);
    align-items: start;
  }

  #growth-features-{{ section.id }} .growth-features__eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  #growth-features-{{ section.id }} .growth-features__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0 0 var(--space-4);
    line-height: 1.15;
  }

  #growth-features-{{ section.id }} .growth-features__description {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    max-width: 36ch;
  }

  #growth-features-{{ section.id }} .growth-features__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--color-border);
  }

  #growth-features-{{ section.id }} .growth-features__item {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: var(--space-5);
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--color-border);
  }

  #growth-features-{{ section.id }} .growth-features__item-num {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-tertiary);
  }

  #growth-features-{{ section.id }} .growth-features__item-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
    line-height: 1.35;
  }

  #growth-features-{{ section.id }} .growth-features__item-desc {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin: 0;
  }

  @media (max-width: 991px) {
    #growth-features-{{ section.id }} .growth-features__layout {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
  }

  {% if request.design_mode %}
    #growth-features-{{ section.id }} .animate-on-scroll {
      opacity: 1;
      transform: none;
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "Growth Features",
  "tag": "section",
  "class": "growth-features-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "image_picker",
      "id": "intro_image",
      "label": "Intro icon image",
      "info": "Optional. Replaces the default target icon on the left."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for Real Ecommerce Growth"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every Shoplane store is designed with the right products, supplier connections, and a structure built to scale — not just launch."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icon",
          "options": [
            { "value": "check-circle", "label": "Check Circle" },
            { "value": "star", "label": "Star" },
            { "value": "zap", "label": "Zap" },
            { "value": "shield", "label": "Shield" },
            { "value": "store", "label": "Store" },
            { "value": "check", "label": "Check" }
          ],
          "default": "check-circle"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Built for demand"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Products selected for demand, not guesswork"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Growth Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon_name": "check-circle",
            "title": "Products selected for demand, not guesswork",
            "description": "Researched, high-demand products already loaded and organised."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "store",
            "title": "Supplier connections already handled",
            "description": "Verified supplier details and integration guidance included."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "zap",
            "title": "Conversion-focused design",
            "description": "Mobile-optimised layouts built to turn visitors into buyers."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "star",
            "title": "Performance from day one",
            "description": "Fast, clean, structured stores ready to sell immediately."
          }
        }
      ]
    }
  ]
}
{% endschema %}
