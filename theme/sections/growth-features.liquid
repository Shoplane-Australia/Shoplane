<section
  id="growth-features-{{ section.id }}"
  class="growth-features section-lg"
  data-section-id="{{ section.id }}"
  data-section-type="growth-features"
>
  <div class="container">
    <div class="growth-features__layout">
      <div class="growth-features__intro animate-on-scroll stagger-1">
        <div class="growth-features__icon-circle" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="16" stroke="currentColor" stroke-width="2"/>
            <circle cx="20" cy="20" r="8" stroke="currentColor" stroke-width="2"/>
            <circle cx="20" cy="20" r="2" fill="currentColor"/>
            <path d="M20 4v4M20 32v4M4 20h4M32 20h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <h2 class="growth-features__heading">
          {{ section.settings.heading }}
        </h2>
        {%- if section.settings.description != blank -%}
          <p class="growth-features__description">
            {{ section.settings.description }}
          </p>
        {%- endif -%}
      </div>

      <div class="growth-features__items">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <article
              class="growth-features__item animate-on-scroll stagger-{{ forloop.index | plus: 1 }}"
              {{ block.shopify_attributes }}
            >
              <span class="growth-features__item-icon" aria-hidden="true">
                {% render 'icon', icon: block.settings.icon_name %}
              </span>
              <div class="growth-features__item-content">
                <h3 class="growth-features__item-title">{{ block.settings.title }}</h3>
                {%- if block.settings.description != blank -%}
                  <p class="growth-features__item-desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #growth-features-{{ section.id }} {
    background: var(--color-surface);
    padding: var(--space-3xl) 0;
  }

  #growth-features-{{ section.id }} .growth-features__layout {
    display: flex;
    align-items: center;
    gap: var(--space-3xl);
  }

  #growth-features-{{ section.id }} .growth-features__intro {
    flex: 0 0 38%;
    max-width: 38%;
  }

  #growth-features-{{ section.id }} .growth-features__icon-circle {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(108, 99, 255, 0.1), rgba(0, 212, 170, 0.08));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    margin-bottom: var(--space-lg);
  }

  #growth-features-{{ section.id }} .growth-features__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0 0 var(--space-md);
    line-height: 1.15;
  }

  #growth-features-{{ section.id }} .growth-features__description {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  #growth-features-{{ section.id }} .growth-features__items {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  #growth-features-{{ section.id }} .growth-features__item {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    padding: var(--space-lg);
    background: var(--color-background);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    transition: box-shadow 0.3s ease;
  }

  #growth-features-{{ section.id }} .growth-features__item:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  #growth-features-{{ section.id }} .growth-features__item-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: linear-gradient(135deg, rgba(108, 99, 255, 0.1), rgba(0, 212, 170, 0.08));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
  }

  #growth-features-{{ section.id }} .growth-features__item-icon svg {
    width: 20px;
    height: 20px;
  }

  #growth-features-{{ section.id }} .growth-features__item-content {
    flex: 1;
    min-width: 0;
  }

  #growth-features-{{ section.id }} .growth-features__item-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 4px;
  }

  #growth-features-{{ section.id }} .growth-features__item-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 991px) {
    #growth-features-{{ section.id }} .growth-features__layout {
      flex-direction: column;
      gap: var(--space-xl);
    }

    #growth-features-{{ section.id }} .growth-features__intro {
      flex: none;
      max-width: 100%;
      text-align: center;
    }

    #growth-features-{{ section.id }} .growth-features__icon-circle {
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 640px) {
    #growth-features-{{ section.id }} .growth-features__items {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Growth Features",
  "tag": "section",
  "class": "growth-features-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for Real Ecommerce Growth"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every Shoplane store is designed with the right products, supplier connections, and a structure built to scale — not just launch."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icon",
          "options": [
            { "value": "check-circle", "label": "Check Circle" },
            { "value": "star", "label": "Star" },
            { "value": "zap", "label": "Zap" },
            { "value": "shield", "label": "Shield" },
            { "value": "store", "label": "Store" },
            { "value": "check", "label": "Check" }
          ],
          "default": "check-circle"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Built for demand"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Products selected for demand, not guesswork"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Growth Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon_name": "check-circle",
            "title": "Demand-Driven Products",
            "description": "Products selected for demand, not guesswork"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "store",
            "title": "Supplier Ready",
            "description": "Supplier connections already handled"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "zap",
            "title": "Conversion Focused",
            "description": "Conversion-focused design from the ground up"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "star",
            "title": "Day-One Performance",
            "description": "Performance from day one, not someday"
          }
        }
      ]
    }
  ]
}
{% endschema %}
