<section
  id="services-how-{{ section.id }}"
  class="services-how-it-works section-lg"
  data-section-id="{{ section.id }}"
  data-section-type="services-how-it-works"
>
  <div class="container">
    <header class="services-how-it-works__header{% unless request.design_mode %} animate-on-scroll stagger-1{% endunless %}">
      {%- if section.settings.eyebrow != blank -%}
        <span class="services-how-it-works__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="services-how-it-works__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.description != blank -%}
        <p class="services-how-it-works__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </header>

    <div class="services-how-it-works__steps">
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          <article
            class="services-how-it-works__step{% unless request.design_mode %} animate-on-scroll stagger-{{ forloop.index | plus: 1 }}{% endunless %}"
            {{ block.shopify_attributes }}
          >
            <span class="services-how-it-works__step-number">{{ forloop.index }}</span>
            <h3 class="services-how-it-works__step-title">{{ block.settings.title }}</h3>
            {%- if block.settings.description != blank -%}
              <p class="services-how-it-works__step-desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #services-how-{{ section.id }} {
    background: #ffffff;
    padding: var(--space-16) 0;
    border-top: 1px solid var(--color-border);
  }

  #services-how-{{ section.id }} .services-how-it-works__header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto var(--space-12);
  }

  #services-how-{{ section.id }} .services-how-it-works__eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 12px;
  }

  #services-how-{{ section.id }} .services-how-it-works__heading {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 12px;
  }

  #services-how-{{ section.id }} .services-how-it-works__description {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0;
  }

  #services-how-{{ section.id }} .services-how-it-works__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    position: relative;
  }

  #services-how-{{ section.id }} .services-how-it-works__steps::before {
    content: '';
    position: absolute;
    top: 28px;
    left: 16%;
    right: 16%;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), #00D4AA);
    opacity: 0.2;
    z-index: 0;
  }

  #services-how-{{ section.id }} .services-how-it-works__step {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 12px;
  }

  #services-how-{{ section.id }} .services-how-it-works__step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    font-size: 1.25rem;
    font-weight: 800;
    color: #fff;
    background: var(--gradient-accent);
    box-shadow: 0 8px 24px var(--color-accent-glow);
    margin-bottom: 20px;
  }

  #services-how-{{ section.id }} .services-how-it-works__step-title {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0 0 10px;
  }

  #services-how-{{ section.id }} .services-how-it-works__step-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0;
  }

  @media (max-width: 768px) {
    #services-how-{{ section.id }} .services-how-it-works__steps {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    #services-how-{{ section.id }} .services-how-it-works__steps::before {
      display: none;
    }
  }

  {% if request.design_mode %}
    #services-how-{{ section.id }} .animate-on-scroll {
      opacity: 1;
      transform: none;
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "Services how it works",
  "tag": "section",
  "class": "services-how-it-works-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Simple process"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Pick a service, checkout securely, and our team delivers — no subscriptions, no surprises."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Choose your service"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Browse 12 expert services across 5 categories and pick what fits your stage."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Services how it works",
      "blocks": [
        { "type": "step", "settings": { "title": "Choose your service", "description": "Browse our catalogue and select the service that matches your goals." } },
        { "type": "step", "settings": { "title": "Checkout & onboard", "description": "Secure one-time payment. We reach out within 24 hours to get started." } },
        { "type": "step", "settings": { "title": "We deliver, you grow", "description": "Our team handles the work. You get a professional result ready to scale." } }
      ]
    }
  ]
}
{% endschema %}
