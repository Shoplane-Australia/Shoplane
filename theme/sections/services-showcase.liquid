<section
  id="services-{{ section.id }}"
  class="services-showcase section-lg"
  data-section-id="{{ section.id }}"
  data-section-type="services-showcase"
>
  <div class="container">
    <header class="services-showcase__header animate-on-scroll stagger-1">
      <h2 class="services-showcase__heading">
        {{ section.settings.heading }}
      </h2>
      {%- if section.settings.description != blank -%}
        <p class="services-showcase__description">
          {{ section.settings.description }}
        </p>
      {%- endif -%}
    </header>

    <div class="services-showcase__list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'service' -%}
          <article
            class="services-showcase__row{% unless request.design_mode %} animate-on-scroll stagger-{{ forloop.index | plus: 1 }}{% endunless %}"
            {{ block.shopify_attributes }}
          >
            <div class="services-showcase__row-index">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
            <div class="services-showcase__row-content">
              <h3 class="services-showcase__row-title">
                {%- if block.settings.url != blank -%}
                  <a href="{{ block.settings.url }}">{{ block.settings.title }}</a>
                {%- else -%}
                  {{ block.settings.title }}
                {%- endif -%}
              </h3>
              {%- if block.settings.description != blank -%}
                <p class="services-showcase__row-desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
            {%- if block.settings.url != blank -%}
              <a href="{{ block.settings.url }}" class="services-showcase__row-link">
                Learn more
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #services-{{ section.id }} {
    background: var(--color-surface, #F0EEE9);
    padding: var(--space-20) 0;
  }

  #services-{{ section.id }} .services-showcase__header {
    text-align: left;
    max-width: 640px;
    margin: 0 0 var(--space-12);
  }

  #services-{{ section.id }} .services-showcase__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0 0 var(--space-4);
  }

  #services-{{ section.id }} .services-showcase__description {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  #services-{{ section.id }} .services-showcase__list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-border);
  }

  #services-{{ section.id }} .services-showcase__row {
    display: grid;
    grid-template-columns: 3.5rem 1fr auto;
    gap: var(--space-6);
    align-items: baseline;
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--color-border);
  }

  #services-{{ section.id }} .services-showcase__row-index {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-tertiary);
    letter-spacing: 0.04em;
  }

  #services-{{ section.id }} .services-showcase__row-title {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }

  #services-{{ section.id }} .services-showcase__row-title a {
    color: inherit;
    text-decoration: none;
  }

  #services-{{ section.id }} .services-showcase__row-title a:hover {
    color: var(--color-accent);
  }

  #services-{{ section.id }} .services-showcase__row-desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    max-width: 48ch;
  }

  #services-{{ section.id }} .services-showcase__row-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    white-space: nowrap;
    transition: gap 0.25s ease;
  }

  #services-{{ section.id }} .services-showcase__row-link:hover {
    gap: 10px;
  }

  @media (max-width: 768px) {
    #services-{{ section.id }} .services-showcase__row {
      grid-template-columns: 2.5rem 1fr;
      gap: var(--space-4);
    }

    #services-{{ section.id }} .services-showcase__row-link {
      grid-column: 2;
      margin-top: 0.5rem;
    }
  }

  {% if request.design_mode %}
    #services-{{ section.id }} .animate-on-scroll {
      opacity: 1;
      transform: none;
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "Services Showcase",
  "tag": "section",
  "class": "services-showcase-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Shopify Services"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "From store setup to ongoing growth, we provide the expert services you need to build, refine and scale your ecommerce business with confidence."
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service Card",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image",
          "info": "Optional. Not shown in editorial list layout."
        },
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icon",
          "info": "Unused in editorial list layout.",
          "options": [
            { "value": "store", "label": "Store" },
            { "value": "zap", "label": "Zap / Performance" },
            { "value": "design", "label": "Design" },
            { "value": "chart", "label": "Growth / Chart" }
          ],
          "default": "store"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge text"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Service title",
          "default": "Store Setup & Launch"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Everything you need to go live — theme configuration, product setup, payment gateways, and a polished storefront ready for customers."
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Services Showcase",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "title": "Store Setup & Launch",
            "description": "Everything you need to go live — theme configuration, product setup, payment gateways, and a polished storefront ready for customers."
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Store Optimisation",
            "description": "Speed improvements, conversion rate optimisation, and UX refinements to turn more visitors into paying customers."
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Branding & Identity",
            "description": "Logo design, brand guidelines, custom typography, and cohesive visual identity that builds trust and recognition."
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Marketing & Growth",
            "description": "SEO setup, email marketing, social media integration, and paid ad strategy to drive traffic and scale revenue."
          }
        }
      ]
    }
  ]
}
{% endschema %}
