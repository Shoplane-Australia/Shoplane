<section
  id="hero-{{ section.id }}"
  class="hero hero--split"
  data-section-id="{{ section.id }}"
  data-section-type="hero"
  data-header-theme="light"
>
  <div class="container hero__container">
    <div class="hero__grid">
      <div class="hero__content">
        {%- if section.settings.brand_text != blank -%}
          <p class="hero__brand animate-on-scroll stagger-1">{{ section.settings.brand_text }}</p>
        {%- endif -%}

        <h1 class="hero__heading animate-on-scroll stagger-2">
          {{ section.settings.heading }}
        </h1>

        {%- if section.settings.subheading != blank -%}
          <p class="hero__subheading animate-on-scroll stagger-3">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}

        <div class="hero__cta-group animate-on-scroll stagger-4">
          {%- if section.settings.primary_cta_text != blank -%}
            <a href="{{ section.settings.primary_cta_url }}" class="btn btn-primary btn-lg">
              {{ section.settings.primary_cta_text }}
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.secondary_cta_text != blank -%}
            <a href="{{ section.settings.secondary_cta_url }}" class="btn btn-outline btn-lg">
              {{ section.settings.secondary_cta_text }}
            </a>
          {%- endif -%}
        </div>
      </div>

      <div class="hero__media animate-on-scroll stagger-2">
        {%- if section.settings.hero_image != blank -%}
          {{
            section.settings.hero_image
            | image_url: width: 1600
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              sizes: '(max-width: 991px) 100vw, 50vw',
              widths: '600, 900, 1200, 1600',
              class: 'hero__media-img',
              alt: ''
          }}
        {%- else -%}
          <div class="hero__media-fallback" aria-hidden="true"></div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{%- if section.settings.show_trust_strip -%}
  <aside class="hero-trust" aria-label="Trust signals">
    <div class="container hero-trust__inner">
      {%- if section.settings.trust_1 != blank -%}
        <span class="hero-trust__item">{{ section.settings.trust_1 }}</span>
      {%- endif -%}
      {%- if section.settings.trust_2 != blank -%}
        <span class="hero-trust__item">{{ section.settings.trust_2 }}</span>
      {%- endif -%}
      {%- if section.settings.trust_3 != blank -%}
        <span class="hero-trust__item">{{ section.settings.trust_3 }}</span>
      {%- endif -%}
      {%- if section.settings.trust_4 != blank -%}
        <span class="hero-trust__item">{{ section.settings.trust_4 }}</span>
      {%- endif -%}
    </div>
  </aside>
{%- endif -%}

<style>
  #hero-{{ section.id }} {
    position: relative;
    background: var(--color-background, #FAFAF8);
    overflow: hidden;
    padding: calc(var(--header-height, 72px) + 3rem) 0 0;
    color: var(--color-text, #121212);
  }

  #hero-{{ section.id }} .hero__container {
    position: relative;
    z-index: 2;
    padding-bottom: clamp(2.5rem, 6vh, 4rem);
  }

  #hero-{{ section.id }} .hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.15fr);
    gap: 0;
    align-items: center;
    min-height: min(72vh, 640px);
  }

  #hero-{{ section.id }} .hero__content {
    max-width: 34rem;
    text-align: left;
    position: relative;
    z-index: 2;
    padding-right: clamp(1rem, 3vw, 2.5rem);
  }

  #hero-{{ section.id }} .hero__brand {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--color-text, #121212);
    margin: 0 0 1.1rem;
  }

  #hero-{{ section.id }} .hero__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--color-text, #121212);
    margin: 0 0 1rem;
    max-width: 18ch;
  }

  #hero-{{ section.id }} .hero__subheading {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.6vw, 1.1rem);
    line-height: 1.55;
    color: var(--color-text-secondary, #3D3D3A);
    max-width: 38ch;
    margin: 0 0 2rem;
  }

  #hero-{{ section.id }} .hero__cta-group {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    align-items: center;
  }

  #hero-{{ section.id }} .hero__media {
    position: relative;
    width: calc(100% + max(0px, (100vw - min(100vw, 1280px)) / 2 + 1.5rem));
    max-width: none;
    height: min(72vh, 640px);
    min-height: 420px;
    overflow: visible;
    background: transparent;
    border: none;
    margin-right: calc(-1 * max(1.5rem, (100vw - min(100vw, 1280px)) / 2 + 1.5rem));
  }

  #hero-{{ section.id }} .hero__media-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center left;
    display: block;
    background: transparent;
    /* Soft blend into page background on the left (and lightly on top/bottom) */
    -webkit-mask-image:
      linear-gradient(90deg, transparent 0%, rgba(0, 0, 0, 0.35) 12%, #000 28%, #000 100%),
      linear-gradient(180deg, transparent 0%, #000 8%, #000 92%, transparent 100%);
    mask-image:
      linear-gradient(90deg, transparent 0%, rgba(0, 0, 0, 0.35) 12%, #000 28%, #000 100%),
      linear-gradient(180deg, transparent 0%, #000 8%, #000 92%, transparent 100%);
    -webkit-mask-composite: source-in;
    mask-composite: intersect;
    -webkit-mask-size: 100% 100%;
    mask-size: 100% 100%;
  }

  #hero-{{ section.id }} .hero__media::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(90deg, var(--color-background, #FAFAF8) 0%, rgba(250, 250, 248, 0.85) 10%, rgba(250, 250, 248, 0.35) 22%, transparent 42%),
      linear-gradient(180deg, var(--color-background, #FAFAF8) 0%, transparent 14%),
      linear-gradient(0deg, var(--color-background, #FAFAF8) 0%, transparent 14%);
  }

  #hero-{{ section.id }} .hero__media-fallback {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(ellipse at 70% 50%, rgba(27, 77, 62, 0.08) 0%, transparent 55%),
      linear-gradient(160deg, #FAFAF8 0%, #F0EEE9 55%, #E8E5DE 100%);
  }

  .hero-trust {
    background: var(--color-surface, #F0EEE9);
    border-block: 1px solid var(--color-border, #E2DFD8);
    padding: 1.1rem 0;
  }

  .hero-trust__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 2rem;
    justify-content: flex-start;
    align-items: center;
  }

  .hero-trust__item {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-secondary, #3D3D3A);
  }

  @media (max-width: 991px) {
    #hero-{{ section.id }} .hero__grid {
      grid-template-columns: 1fr;
      min-height: 0;
      gap: 1.5rem;
    }

    #hero-{{ section.id }} .hero__content {
      padding-right: 0;
    }

    #hero-{{ section.id }} .hero__media {
      order: -1;
      width: 100%;
      margin-right: 0;
      height: 56vw;
      min-height: 260px;
      max-height: 420px;
    }

    #hero-{{ section.id }} .hero__media-img {
      -webkit-mask-image:
        linear-gradient(180deg, transparent 0%, #000 18%, #000 82%, transparent 100%);
      mask-image:
        linear-gradient(180deg, transparent 0%, #000 18%, #000 82%, transparent 100%);
      -webkit-mask-composite: source-in;
      mask-composite: intersect;
    }

    #hero-{{ section.id }} .hero__media::before {
      background:
        linear-gradient(180deg, var(--color-background, #FAFAF8) 0%, transparent 22%),
        linear-gradient(0deg, var(--color-background, #FAFAF8) 0%, transparent 22%);
    }
  }

  @media (max-width: 768px) {
    #hero-{{ section.id }} {
      padding-top: calc(var(--header-height, 72px) + 2rem);
    }

    #hero-{{ section.id }} .hero__cta-group {
      flex-direction: column;
      align-items: stretch;
    }

    #hero-{{ section.id }} .hero__cta-group .btn {
      width: 100%;
    }

    .hero-trust__inner {
      gap: 0.65rem 1.25rem;
    }
  }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand wordmark",
      "info": "Leave blank to hide"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Launch Your Brand. Not Just a Store."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Ready-made Shopify stores and expert services — built for Australian entrepreneurs who want to start selling, not start from scratch."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image (right side)"
    },
    {
      "type": "text",
      "id": "primary_cta_text",
      "label": "Primary CTA text",
      "default": "Browse Stores"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "secondary_cta_text",
      "label": "Secondary CTA text",
      "default": "Explore Services"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "checkbox",
      "id": "show_trust_strip",
      "label": "Show trust strip below hero",
      "default": true
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust item 1",
      "default": "One-time payment"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust item 2",
      "default": "Full ownership"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust item 3",
      "default": "Australian business"
    },
    {
      "type": "text",
      "id": "trust_4",
      "label": "Trust item 4",
      "default": "Shopify Partner"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
