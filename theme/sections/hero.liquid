<section
  id="hero-{{ section.id }}"
  class="hero section-dark"
  data-section-id="{{ section.id }}"
  data-section-type="hero"
>
  {%- comment -%} Animated gradient mesh background {%- endcomment -%}
  <div class="hero__gradient-mesh" aria-hidden="true">
    <div class="hero__gradient-orb hero__gradient-orb--purple"></div>
    <div class="hero__gradient-orb hero__gradient-orb--teal"></div>
    <div class="hero__gradient-orb hero__gradient-orb--blue"></div>
  </div>

  {%- comment -%} Dot grid background {%- endcomment -%}
  <div class="hero__dot-grid" aria-hidden="true"></div>

  {%- comment -%} Floating particles {%- endcomment -%}
  <div class="hero__particles" aria-hidden="true">
    {%- for i in (1..20) -%}
      <span class="hero__particle hero__particle--{{ i }}"></span>
    {%- endfor -%}
  </div>

  <div class="container hero__container">
    {%- if section.settings.announcement_text != blank -%}
      <div class="hero__announcement animate-on-scroll stagger-1">
        <span class="hero__pill">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 1l2.09 4.26L15 6.27l-3.5 3.42L12.18 15 8 12.77 3.82 15l.68-5.31L1 6.27l4.91-1.01L8 1z" fill="#00D4AA"/>
          </svg>
          {{ section.settings.announcement_text }}
        </span>
      </div>
    {%- endif -%}

    <h1 class="hero__heading animate-on-scroll stagger-2">
      {{ section.settings.heading }}
    </h1>

    {%- if section.settings.subheading != blank -%}
      <p class="hero__subheading animate-on-scroll stagger-3">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}

    <div class="hero__cta-group animate-on-scroll stagger-4">
      {%- if section.settings.primary_cta_text != blank -%}
        <a href="{{ section.settings.primary_cta_url }}" class="btn btn-primary btn-lg">
          {{ section.settings.primary_cta_text }}
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_cta_text != blank -%}
        <a href="{{ section.settings.secondary_cta_url }}" class="btn btn-outline btn-lg">
          {{ section.settings.secondary_cta_text }}
        </a>
      {%- endif -%}
    </div>

    <div class="hero__stats animate-on-scroll stagger-5">
      {%- if section.settings.stat_1_number != blank -%}
        <div class="hero__stat">
          <span class="hero__stat-number" data-count="{{ section.settings.stat_1_number }}">{{ section.settings.stat_1_number }}</span>
          <span class="hero__stat-label">{{ section.settings.stat_1_label }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_2_number != blank -%}
        <div class="hero__stat">
          <span class="hero__stat-number" data-count="{{ section.settings.stat_2_number }}">{{ section.settings.stat_2_number }}</span>
          <span class="hero__stat-label">{{ section.settings.stat_2_label }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_3_number != blank -%}
        <div class="hero__stat">
          <span class="hero__stat-number">{{ section.settings.stat_3_number }}</span>
          <span class="hero__stat-label">{{ section.settings.stat_3_label }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_4_number != blank -%}
        <div class="hero__stat">
          <span class="hero__stat-number">{{ section.settings.stat_4_number }}</span>
          <span class="hero__stat-label">{{ section.settings.stat_4_label }}</span>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_trust_badges -%}
    <div class="hero__trust-strip animate-on-scroll stagger-6">
      {% render 'trust-badges' %}
    </div>
  {%- endif -%}
</section>

<style>
  #hero-{{ section.id }} {
    --hero-bg: {{ section.settings.background_color }};
    --hero-accent-1: {{ section.settings.accent_color_1 }};
    --hero-accent-2: {{ section.settings.accent_color_2 }};
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: var(--hero-bg);
    overflow: hidden;
    padding: 120px 0 60px;
    color: #ffffff;
  }

  #hero-{{ section.id }} .hero__gradient-mesh {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  #hero-{{ section.id }} .hero__gradient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.4;
    animation: hero-orb-float 12s ease-in-out infinite;
  }

  #hero-{{ section.id }} .hero__gradient-orb--purple {
    width: 600px;
    height: 600px;
    background: var(--hero-accent-1);
    top: -10%;
    left: 20%;
    animation-delay: 0s;
  }

  #hero-{{ section.id }} .hero__gradient-orb--teal {
    width: 500px;
    height: 500px;
    background: var(--hero-accent-2);
    bottom: -5%;
    right: 15%;
    animation-delay: -4s;
  }

  #hero-{{ section.id }} .hero__gradient-orb--blue {
    width: 400px;
    height: 400px;
    background: #4A47E0;
    top: 40%;
    right: 40%;
    animation-delay: -8s;
  }

  @keyframes hero-orb-float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(40px, -30px) scale(1.05); }
    66% { transform: translate(-20px, 20px) scale(0.95); }
  }

  #hero-{{ section.id }} .hero__dot-grid {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-image: radial-gradient(rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 32px 32px;
  }

  #hero-{{ section.id }} .hero__particles {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
    pointer-events: none;
  }

  #hero-{{ section.id }} .hero__particle {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    animation: hero-particle-drift 20s linear infinite;
  }

  {%- for i in (1..20) -%}
    #hero-{{ section.id }} .hero__particle--{{ i }} {
      left: {{ i | times: 5 | modulo: 100 }}%;
      top: {{ i | times: 7 | modulo: 100 }}%;
      animation-delay: -{{ i | times: 1.3 }}s;
      animation-duration: {{ i | modulo: 8 | plus: 15 }}s;
    }
  {%- endfor -%}

  @keyframes hero-particle-drift {
    0% { transform: translateY(0) translateX(0); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(-100vh) translateX(30px); opacity: 0; }
  }

  #hero-{{ section.id }} .hero__container {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 860px;
    margin: 0 auto;
  }

  #hero-{{ section.id }} .hero__announcement {
    margin-bottom: 32px;
  }

  #hero-{{ section.id }} .hero__pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 20px;
    border-radius: 100px;
    background: rgba(108, 99, 255, 0.12);
    border: 1px solid rgba(108, 99, 255, 0.25);
    font-size: 0.875rem;
    font-weight: 500;
    color: #C4BFFF;
    letter-spacing: 0.02em;
  }

  #hero-{{ section.id }} .hero__heading {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin: 0 0 24px;
    background: linear-gradient(135deg, #ffffff 40%, var(--hero-accent-1) 65%, var(--hero-accent-2) 90%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  #hero-{{ section.id }} .hero__subheading {
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    line-height: 1.6;
    color: rgba(255,255,255,0.65);
    max-width: 640px;
    margin: 0 auto 40px;
  }

  #hero-{{ section.id }} .hero__cta-group {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 64px;
  }

  #hero-{{ section.id }} .hero__stats {
    display: flex;
    justify-content: center;
    gap: 48px;
    flex-wrap: wrap;
    padding-top: 48px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  #hero-{{ section.id }} .hero__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  #hero-{{ section.id }} .hero__stat-number {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 1.75rem;
    font-weight: 700;
    background: linear-gradient(135deg, #ffffff, var(--hero-accent-2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  #hero-{{ section.id }} .hero__stat-label {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  #hero-{{ section.id }} .hero__trust-strip {
    margin-top: auto;
    padding-top: 48px;
    width: 100%;
  }

  @media (max-width: 768px) {
    #hero-{{ section.id }} .hero__stats {
      gap: 24px;
    }
    #hero-{{ section.id }} .hero__cta-group {
      flex-direction: column;
      align-items: center;
    }
  }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement pill text",
      "default": "Official Shopify Partner"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Launch Your Brand. Not Just a Store."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium ready-made Shopify stores built for Australian entrepreneurs. Pick a niche, get a fully loaded store, and start selling — we handle the hard part."
    },
    {
      "type": "text",
      "id": "primary_cta_text",
      "label": "Primary CTA text",
      "default": "Browse Stores"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "secondary_cta_text",
      "label": "Secondary CTA text",
      "default": "Explore Services"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "header",
      "content": "Stats Row"
    },
    {
      "type": "text",
      "id": "stat_1_number",
      "label": "Stat 1 number",
      "default": "9+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "Stores"
    },
    {
      "type": "text",
      "id": "stat_2_number",
      "label": "Stat 2 number",
      "default": "13+"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "Services"
    },
    {
      "type": "text",
      "id": "stat_3_number",
      "label": "Stat 3 number",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "Ownership"
    },
    {
      "type": "text",
      "id": "stat_4_number",
      "label": "Stat 4 number",
      "default": "AUS"
    },
    {
      "type": "text",
      "id": "stat_4_label",
      "label": "Stat 4 label",
      "default": "Business"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#0A0A0A"
    },
    {
      "type": "color",
      "id": "accent_color_1",
      "label": "Accent colour (purple)",
      "default": "#6C63FF"
    },
    {
      "type": "color",
      "id": "accent_color_2",
      "label": "Accent colour (teal)",
      "default": "#00D4AA"
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
