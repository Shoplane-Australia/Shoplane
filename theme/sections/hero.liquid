<section
  id="hero-{{ section.id }}"
  class="hero hero--editorial"
  data-section-id="{{ section.id }}"
  data-section-type="hero"
>
  <div class="hero__media" aria-hidden="true">
    {%- if section.settings.hero_image != blank -%}
      {{
        section.settings.hero_image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '800, 1200, 1600, 2000, 2400',
          class: 'hero__media-img',
          alt: ''
      }}
    {%- else -%}
      <div class="hero__media-fallback"></div>
    {%- endif -%}
    <div class="hero__media-wash"></div>
  </div>

  <div class="container hero__container">
    <p class="hero__brand animate-on-scroll stagger-1">{{ section.settings.brand_text | default: shop.name | upcase }}</p>

    <h1 class="hero__heading animate-on-scroll stagger-2">
      {{ section.settings.heading }}
    </h1>

    {%- if section.settings.subheading != blank -%}
      <p class="hero__subheading animate-on-scroll stagger-3">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}

    <div class="hero__cta-group animate-on-scroll stagger-4">
      {%- if section.settings.primary_cta_text != blank -%}
        <a href="{{ section.settings.primary_cta_url }}" class="btn btn-primary btn-lg">
          {{ section.settings.primary_cta_text }}
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_cta_text != blank -%}
        <a href="{{ section.settings.secondary_cta_url }}" class="btn btn-outline btn-lg">
          {{ section.settings.secondary_cta_text }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{%- if section.settings.show_trust_strip -%}
  <aside class="hero-trust" aria-label="Trust signals">
    <div class="container hero-trust__inner">
      {%- if section.settings.trust_1 != blank -%}
        <span class="hero-trust__item">{{ section.settings.trust_1 }}</span>
      {%- endif -%}
      {%- if section.settings.trust_2 != blank -%}
        <span class="hero-trust__item">{{ section.settings.trust_2 }}</span>
      {%- endif -%}
      {%- if section.settings.trust_3 != blank -%}
        <span class="hero-trust__item">{{ section.settings.trust_3 }}</span>
      {%- endif -%}
      {%- if section.settings.trust_4 != blank -%}
        <span class="hero-trust__item">{{ section.settings.trust_4 }}</span>
      {%- endif -%}
    </div>
  </aside>
{%- endif -%}

<style>
  #hero-{{ section.id }} {
    position: relative;
    min-height: min(100vh, 920px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: var(--color-background, #FAFAF8);
    overflow: hidden;
    padding: calc(var(--header-height, 72px) + 4rem) 0 0;
    color: var(--color-text, #121212);
  }

  #hero-{{ section.id }} .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  #hero-{{ section.id }} .hero__media-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.04);
    animation: hero-kenburns 18s ease-out forwards;
  }

  #hero-{{ section.id }} .hero__media-fallback {
    width: 100%;
    height: 100%;
    background:
      linear-gradient(160deg, #F0EEE9 0%, #E2DFD8 45%, #D4D0C8 100%);
  }

  #hero-{{ section.id }} .hero__media-wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(250, 250, 248, 0.92) 0%, rgba(250, 250, 248, 0.78) 38%, rgba(250, 250, 248, 0.55) 62%, rgba(250, 250, 248, 0.94) 100%),
      linear-gradient(90deg, rgba(250, 250, 248, 0.55) 0%, transparent 55%);
    pointer-events: none;
  }

  @keyframes hero-kenburns {
    from { transform: scale(1.06); opacity: 0.85; }
    to { transform: scale(1); opacity: 1; }
  }

  #hero-{{ section.id }} .hero__container {
    position: relative;
    z-index: 2;
    max-width: 720px;
    margin: 0;
    padding-bottom: clamp(3rem, 8vh, 5.5rem);
    text-align: left;
  }

  #hero-{{ section.id }} .hero__brand {
    font-family: var(--font-heading);
    font-size: clamp(2.75rem, 8vw, 5.5rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--color-text, #121212);
    margin: 0 0 1.25rem;
  }

  #hero-{{ section.id }} .hero__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--color-text, #121212);
    margin: 0 0 1rem;
    max-width: 18ch;
  }

  #hero-{{ section.id }} .hero__subheading {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    line-height: 1.55;
    color: var(--color-text-secondary, #3D3D3A);
    max-width: 38ch;
    margin: 0 0 2rem;
  }

  #hero-{{ section.id }} .hero__cta-group {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .hero-trust {
    background: var(--color-surface, #F0EEE9);
    border-block: 1px solid var(--color-border, #E2DFD8);
    padding: 1.1rem 0;
  }

  .hero-trust__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 2rem;
    justify-content: flex-start;
    align-items: center;
  }

  .hero-trust__item {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-secondary, #3D3D3A);
  }

  @media (max-width: 768px) {
    #hero-{{ section.id }} {
      min-height: 88vh;
      padding-top: calc(var(--header-height, 72px) + 2.5rem);
    }

    #hero-{{ section.id }} .hero__brand {
      font-size: clamp(2.25rem, 12vw, 3.25rem);
    }

    #hero-{{ section.id }} .hero__cta-group {
      flex-direction: column;
      align-items: stretch;
    }

    #hero-{{ section.id }} .hero__cta-group .btn {
      width: 100%;
    }

    .hero-trust__inner {
      gap: 0.65rem 1.25rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #hero-{{ section.id }} .hero__media-img {
      animation: none;
      transform: none;
    }
  }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand wordmark",
      "default": "SHOPLANE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Launch Your Brand. Not Just a Store."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Ready-made Shopify stores and expert services — built for Australian entrepreneurs who want to start selling, not start from scratch."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image"
    },
    {
      "type": "text",
      "id": "primary_cta_text",
      "label": "Primary CTA text",
      "default": "Browse Stores"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "secondary_cta_text",
      "label": "Secondary CTA text",
      "default": "Explore Services"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "header",
      "content": "Trust strip (below fold)"
    },
    {
      "type": "checkbox",
      "id": "show_trust_strip",
      "label": "Show trust strip",
      "default": true
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust item 1",
      "default": "Official Shopify Partner"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust item 2",
      "default": "One-time payment"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust item 3",
      "default": "Australian support"
    },
    {
      "type": "text",
      "id": "trust_4",
      "label": "Trust item 4",
      "default": "Full store ownership"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
