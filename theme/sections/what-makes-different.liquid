<section
  id="what-makes-different-{{ section.id }}"
  class="what-makes-different section-lg"
  data-section-id="{{ section.id }}"
  data-section-type="what-makes-different"
>
  <div class="container">
    <div class="what-makes-different__layout">
      <div class="what-makes-different__intro{% unless request.design_mode %} animate-on-scroll stagger-1{% endunless %}">
        {%- if section.settings.eyebrow != blank -%}
          <span class="what-makes-different__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="what-makes-different__heading">
          {{ section.settings.heading }}
        </h2>
        {%- if section.settings.description != blank -%}
          <p class="what-makes-different__description">
            {{ section.settings.description }}
          </p>
        {%- endif -%}
      </div>

      <div class="what-makes-different__features">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <article
              class="what-makes-different__feature{% unless request.design_mode %} animate-on-scroll stagger-{{ forloop.index | plus: 1 }}{% endunless %}"
              {{ block.shopify_attributes }}
            >
              <span class="what-makes-different__feature-icon" aria-hidden="true">
                {% render 'icon', icon: block.settings.icon_name %}
              </span>
              <div class="what-makes-different__feature-content">
                <h3 class="what-makes-different__feature-title">{{ block.settings.title }}</h3>
                {%- if block.settings.description != blank -%}
                  <p class="what-makes-different__feature-desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #what-makes-different-{{ section.id }} {
    position: relative;
    overflow: hidden;
    background: #fcfbfa;
    padding: var(--space-16) 0;
  }

  #what-makes-different-{{ section.id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 55% at 100% 0%, rgba(255, 196, 140, 0.14) 0%, transparent 52%),
      radial-gradient(ellipse 80% 60% at 0% 100%, rgba(108, 99, 255, 0.13) 0%, transparent 56%),
      radial-gradient(ellipse 50% 40% at 75% 85%, rgba(0, 212, 170, 0.07) 0%, transparent 48%),
      linear-gradient(200deg, #fffdfb 0%, #ffffff 38%, #f7f4ff 100%);
    pointer-events: none;
    z-index: 0;
  }

  #what-makes-different-{{ section.id }}::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.92' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.028'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    pointer-events: none;
    z-index: 1;
    opacity: 0.85;
    mix-blend-mode: multiply;
  }

  #what-makes-different-{{ section.id }} .container {
    position: relative;
    z-index: 2;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__layout {
    display: grid;
    grid-template-columns: minmax(280px, 5fr) minmax(320px, 7fr);
    gap: var(--space-12);
    align-items: start;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  #what-makes-different-{{ section.id }} .what-makes-different__heading {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0 0 var(--space-4);
    line-height: 1.15;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__description {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    max-width: 36ch;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__features {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  #what-makes-different-{{ section.id }} .what-makes-different__feature {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-6);
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.85);
    box-shadow: 0 1px 3px rgba(15, 23, 42, 0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__feature:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
  }

  #what-makes-different-{{ section.id }} .what-makes-different__feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, rgba(108, 99, 255, 0.12), rgba(0, 212, 170, 0.08));
    color: var(--color-accent);
  }

  #what-makes-different-{{ section.id }} .what-makes-different__feature-icon svg {
    width: 22px;
    height: 22px;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__feature-content {
    flex: 1;
    min-width: 0;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__feature-title {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
    line-height: 1.35;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__feature-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 991px) {
    #what-makes-different-{{ section.id }} .what-makes-different__layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    #what-makes-different-{{ section.id }} .what-makes-different__description {
      max-width: none;
    }
  }

  {% if request.design_mode %}
    #what-makes-different-{{ section.id }} .animate-on-scroll {
      opacity: 1;
      transform: none;
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "What Makes Different",
  "tag": "section",
  "class": "what-makes-different-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "EXPERTS IN LAUNCHING WINNING BRANDS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Makes Shoplane Different"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We don't just launch stores — we build structured ecommerce businesses designed to grow."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icon",
          "options": [
            { "value": "store", "label": "Store" },
            { "value": "shield", "label": "Shield" },
            { "value": "star", "label": "Star" },
            { "value": "zap", "label": "Zap" },
            { "value": "check-circle", "label": "Check Circle" },
            { "value": "check", "label": "Check" }
          ],
          "default": "store"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Built like a business"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Strategic structure that scales with you."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What Makes Different",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon_name": "store",
            "title": "Built like a business, not a template store",
            "description": "Strategic structure that scales with you."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "shield",
            "title": "Focused on structure, not just design",
            "description": "Store patterns built for conversion and growth."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "star",
            "title": "Designed for long-term growth, not quick wins",
            "description": "Sustainable systems for real-world success."
          }
        }
      ]
    }
  ]
}
{% endschema %}
