<section
  id="what-makes-different-{{ section.id }}"
  class="what-makes-different section-lg"
  data-section-id="{{ section.id }}"
  data-section-type="what-makes-different"
>
  <div class="container">
    <div class="what-makes-different__layout">
      <div class="what-makes-different__intro{% unless request.design_mode %} animate-on-scroll stagger-1{% endunless %}">
        {%- if section.settings.eyebrow != blank -%}
          <span class="what-makes-different__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="what-makes-different__heading">
          {{ section.settings.heading }}
        </h2>
        {%- if section.settings.description != blank -%}
          <p class="what-makes-different__description">
            {{ section.settings.description }}
          </p>
        {%- endif -%}
      </div>

      <div class="what-makes-different__features">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <article
              class="what-makes-different__feature{% unless request.design_mode %} animate-on-scroll stagger-{{ forloop.index | plus: 1 }}{% endunless %}"
              {{ block.shopify_attributes }}
            >
              <span class="what-makes-different__feature-icon" aria-hidden="true">
                {% render 'icon', icon: block.settings.icon_name, size: 48 %}
              </span>
              <div class="what-makes-different__feature-content">
                <h3 class="what-makes-different__feature-title">{{ block.settings.title }}</h3>
                {%- if block.settings.description != blank -%}
                  <p class="what-makes-different__feature-desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #what-makes-different-{{ section.id }} {
    background: var(--color-background, #FAFAF8);
    padding: var(--space-20) 0;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__layout {
    display: grid;
    grid-template-columns: minmax(280px, 5fr) minmax(320px, 7fr);
    gap: var(--space-16);
    align-items: start;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  #what-makes-different-{{ section.id }} .what-makes-different__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0 0 var(--space-4);
    line-height: 1.15;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__description {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    max-width: 36ch;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__features {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--color-border);
  }

  #what-makes-different-{{ section.id }} .what-makes-different__feature {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: var(--space-5);
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--color-border);
    background: transparent;
    backdrop-filter: none;
    border-radius: 0;
    box-shadow: none;
    align-items: start;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__feature:hover {
    transform: none;
    box-shadow: none;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__feature-icon {
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    width: 3rem;
    height: 3rem;
    padding-top: 0;
    background: none;
    color: var(--color-accent);
  }

  #what-makes-different-{{ section.id }} .what-makes-different__feature-icon svg {
    width: 3rem;
    height: 3rem;
    stroke-width: 1.5;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__feature-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
    line-height: 1.35;
  }

  #what-makes-different-{{ section.id }} .what-makes-different__feature-desc {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 991px) {
    #what-makes-different-{{ section.id }} .what-makes-different__layout {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    #what-makes-different-{{ section.id }} .what-makes-different__description {
      max-width: none;
    }
  }

  {% if request.design_mode %}
    #what-makes-different-{{ section.id }} .animate-on-scroll {
      opacity: 1;
      transform: none;
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "What Makes Different",
  "tag": "section",
  "class": "what-makes-different-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "EXPERTS IN LAUNCHING WINNING BRANDS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Makes Shoplane Different"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We don't just launch stores — we build structured ecommerce businesses designed to grow."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icon",
          "options": [
            { "value": "store", "label": "Store" },
            { "value": "shield", "label": "Shield" },
            { "value": "star", "label": "Star" },
            { "value": "zap", "label": "Zap" },
            { "value": "check-circle", "label": "Check Circle" },
            { "value": "check", "label": "Check" }
          ],
          "default": "store"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Built like a business"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Strategic structure that scales with you."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What Makes Different",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon_name": "store",
            "title": "Built like a business, not a template store",
            "description": "Strategic structure that scales with you."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "shield",
            "title": "Focused on structure, not just design",
            "description": "Store patterns built for conversion and growth."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_name": "star",
            "title": "Designed for long-term growth, not quick wins",
            "description": "Sustainable systems for real-world success."
          }
        }
      ]
    }
  ]
}
{% endschema %}
