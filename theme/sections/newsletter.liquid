{{ 'section-newsletter.css' | asset_url | stylesheet_tag }}

<section
  id="newsletter-{{ section.id }}"
  class="newsletter section-lg"
  data-section-id="{{ section.id }}"
  data-section-type="newsletter"
>
  <div class="container">
    <div class="newsletter__wrapper animate-on-scroll stagger-1">
      <div class="newsletter__content">
        {%- if section.settings.eyebrow != blank -%}
          <span class="section-eyebrow animate-on-scroll stagger-1">{{ section.settings.eyebrow }}</span>
        {%- endif -%}

        <h2 class="newsletter__heading animate-on-scroll stagger-2">
          {{ section.settings.heading }}
        </h2>

        {%- if section.settings.subheading != blank -%}
          <p class="newsletter__subheading animate-on-scroll stagger-3">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
      </div>

      <div class="newsletter__form-wrap animate-on-scroll stagger-4">
        {%- form 'customer', class: 'newsletter__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="hidden" name="contact[accepts_marketing]" value="true">

          {%- if form.errors -%}
            <div class="newsletter__alert newsletter__alert--error" role="alert">
              <p>{{ form.errors | default_errors }}</p>
            </div>
          {%- endif -%}

          {%- if form.posted_successfully? -%}
            <div class="newsletter__alert newsletter__alert--success" role="status">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="9" stroke="#00D4AA" stroke-width="1.5"/>
                <path d="M6 10l3 3 5-6" stroke="#00D4AA" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <p>{{ section.settings.success_message }}</p>
            </div>
          {%- endif -%}

          <div class="newsletter__input-group">
            <label for="newsletter-email-{{ section.id }}" class="visually-hidden">
              Email address
            </label>
            <input
              id="newsletter-email-{{ section.id }}"
              type="email"
              name="contact[email]"
              class="newsletter__input"
              placeholder="{{ section.settings.placeholder_text }}"
              required
              autocomplete="email"
              aria-label="Email address"
              {% if form.posted_successfully? %}
                value=""
              {% endif %}
            >
            <button type="submit" class="btn btn-primary newsletter__submit">
              {{ section.settings.button_text }}
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M3.75 9h10.5m0 0l-3.75-3.75m3.75 3.75l-3.75 3.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        {%- endform -%}

        {%- if section.settings.privacy_note != blank -%}
          <p class="newsletter__privacy animate-on-scroll stagger-5">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <rect x="3" y="6" width="8" height="6" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
              <path d="M5 6V4.5a2 2 0 014 0V6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
            {{ section.settings.privacy_note }}
          </p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  #newsletter-{{ section.id }} {
    background: {{ section.settings.background_color }};
    padding: 80px 0;
  }

  #newsletter-{{ section.id }} .newsletter__wrapper {
    background: #ffffff;
    border: 1px solid #E8E8E8;
    border-radius: 20px;
    padding: 56px;
    display: flex;
    align-items: center;
    gap: 56px;
    position: relative;
    overflow: hidden;
  }

  #newsletter-{{ section.id }} .newsletter__wrapper::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #6C63FF, #00D4AA);
  }

  #newsletter-{{ section.id }} .newsletter__content {
    flex: 1;
    min-width: 0;
  }

  #newsletter-{{ section.id }} .section-eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #6C63FF;
    margin-bottom: 12px;
  }

  #newsletter-{{ section.id }} .newsletter__heading {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #0A0A0A;
    margin: 0 0 12px;
  }

  #newsletter-{{ section.id }} .newsletter__subheading {
    font-size: 1rem;
    color: #666;
    line-height: 1.6;
    margin: 0;
  }

  #newsletter-{{ section.id }} .newsletter__form-wrap {
    flex: 1;
    min-width: 0;
  }

  #newsletter-{{ section.id }} .newsletter__input-group {
    display: flex;
    gap: 0;
    border-radius: 12px;
    border: 2px solid #E8E8E8;
    overflow: hidden;
    transition: border-color 0.25s ease;
  }

  #newsletter-{{ section.id }} .newsletter__input-group:focus-within {
    border-color: #6C63FF;
  }

  #newsletter-{{ section.id }} .newsletter__input {
    flex: 1;
    padding: 16px 20px;
    border: none;
    background: transparent;
    font-size: 1rem;
    color: #0A0A0A;
    outline: none;
    min-width: 0;
  }

  #newsletter-{{ section.id }} .newsletter__input::placeholder {
    color: #AAA;
  }

  #newsletter-{{ section.id }} .newsletter__submit {
    border-radius: 0 10px 10px 0;
    padding: 16px 24px;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: none;
    cursor: pointer;
    font-weight: 600;
  }

  #newsletter-{{ section.id }} .newsletter__alert {
    margin-bottom: 16px;
    padding: 12px 16px;
    border-radius: 10px;
    font-size: 0.9rem;
  }

  #newsletter-{{ section.id }} .newsletter__alert p {
    margin: 0;
  }

  #newsletter-{{ section.id }} .newsletter__alert--error {
    background: rgba(255,59,48,0.08);
    color: #D32F2F;
    border: 1px solid rgba(255,59,48,0.15);
  }

  #newsletter-{{ section.id }} .newsletter__alert--success {
    background: rgba(0,212,170,0.08);
    color: #00A87A;
    border: 1px solid rgba(0,212,170,0.15);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #newsletter-{{ section.id }} .newsletter__privacy {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 14px;
    font-size: 0.8rem;
    color: #999;
  }

  @media (max-width: 768px) {
    #newsletter-{{ section.id }} .newsletter__wrapper {
      flex-direction: column;
      padding: 40px 28px;
      gap: 32px;
      text-align: center;
    }

    #newsletter-{{ section.id }} .newsletter__input-group {
      flex-direction: column;
      border-radius: 12px;
    }

    #newsletter-{{ section.id }} .newsletter__submit {
      border-radius: 0 0 10px 10px;
      justify-content: center;
    }
  }
</style>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Newsletter"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stay in the Loop"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get notified about new store launches, exclusive offers, and ecommerce tips — straight to your inbox."
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Input placeholder",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks for subscribing! Check your inbox soon."
    },
    {
      "type": "text",
      "id": "privacy_note",
      "label": "Privacy note",
      "default": "We respect your privacy. Unsubscribe anytime."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#F8F8FA"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
