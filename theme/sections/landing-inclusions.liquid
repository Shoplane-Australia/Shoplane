<section
  id="landing-inclusions-{{ section.id }}"
  class="landing-inclusions"
  data-section-id="{{ section.id }}"
>
  <div class="container">
    <div class="landing-inclusions__layout">
      <header class="landing-inclusions__intro animate-on-scroll stagger-1">
        {%- if section.settings.eyebrow != blank -%}
          <span class="landing-inclusions__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="landing-inclusions__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.description != blank -%}
          <p class="landing-inclusions__description">{{ section.settings.description }}</p>
        {%- endif -%}
      </header>

      <ol class="landing-inclusions__list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'item' -%}
            <li class="landing-inclusions__item animate-on-scroll stagger-{{ forloop.index | plus: 1 }}" {{ block.shopify_attributes }}>
              <span class="landing-inclusions__num" aria-hidden="true">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
              <div>
                <h3 class="landing-inclusions__title">{{ block.settings.title }}</h3>
                {%- if block.settings.description != blank -%}
                  <p class="landing-inclusions__text">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ol>
    </div>
  </div>
</section>

<style>
  #landing-inclusions-{{ section.id }} {
    background: var(--color-surface, #F0EEE9);
    padding: var(--space-20) 0;
  }

  #landing-inclusions-{{ section.id }} .landing-inclusions__layout {
    display: grid;
    grid-template-columns: minmax(240px, 5fr) minmax(300px, 7fr);
    gap: var(--space-16);
    align-items: start;
  }

  #landing-inclusions-{{ section.id }} .landing-inclusions__eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  #landing-inclusions-{{ section.id }} .landing-inclusions__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
    color: var(--color-text);
  }

  #landing-inclusions-{{ section.id }} .landing-inclusions__description {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    max-width: 36ch;
  }

  #landing-inclusions-{{ section.id }} .landing-inclusions__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }

  #landing-inclusions-{{ section.id }} .landing-inclusions__item {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: var(--space-5);
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--color-border);
  }

  #landing-inclusions-{{ section.id }} .landing-inclusions__num {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-tertiary);
  }

  #landing-inclusions-{{ section.id }} .landing-inclusions__title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.35rem;
    color: var(--color-text);
  }

  #landing-inclusions-{{ section.id }} .landing-inclusions__text {
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
  }

  @media (max-width: 991px) {
    #landing-inclusions-{{ section.id }} .landing-inclusions__layout {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
  }
</style>

{% schema %}
{
  "name": "Landing Inclusions",
  "tag": "section",
  "class": "landing-inclusions-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Included"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What you get with every store"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "A professionally configured foundation ready for product integration and launch."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Inclusion",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "A fully built Shopify store"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Theme, navigation and structure ready from day one."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Landing Inclusions",
      "blocks": [
        { "type": "item", "settings": { "title": "A fully built Shopify store", "description": "Professionally designed and structured for conversion." } },
        { "type": "item", "settings": { "title": "Products already added", "description": "Researched products loaded with images and descriptions." } },
        { "type": "item", "settings": { "title": "Supplier-ready setup", "description": "Verified supplier guidance so fulfillment is clear." } },
        { "type": "item", "settings": { "title": "Clean structure and navigation", "description": "Organised collections, menus and pages that scale." } },
        { "type": "item", "settings": { "title": "Full ownership transfer", "description": "One-time payment. The store is yours to run and grow." } }
      ]
    }
  ]
}
{% endschema %}
