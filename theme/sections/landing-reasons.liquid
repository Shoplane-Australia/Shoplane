<section
  id="landing-reasons-{{ section.id }}"
  class="landing-reasons"
  data-section-id="{{ section.id }}"
>
  <div class="container">
    <header class="landing-reasons__header animate-on-scroll stagger-1">
      <h2 class="landing-reasons__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.description != blank -%}
        <p class="landing-reasons__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </header>

    <div class="landing-reasons__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'reason' -%}
          <article class="landing-reasons__item animate-on-scroll stagger-{{ forloop.index | plus: 1 }}" {{ block.shopify_attributes }}>
            <span class="landing-reasons__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            <h3 class="landing-reasons__title">{{ block.settings.title }}</h3>
            {%- if block.settings.description != blank -%}
              <p class="landing-reasons__text">{{ block.settings.description }}</p>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #landing-reasons-{{ section.id }} {
    background: var(--color-background, #FAFAF8);
    padding: var(--space-20) 0;
  }

  #landing-reasons-{{ section.id }} .landing-reasons__header {
    max-width: 560px;
    margin: 0 0 var(--space-12);
  }

  #landing-reasons-{{ section.id }} .landing-reasons__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 0.75rem;
    color: var(--color-text);
  }

  #landing-reasons-{{ section.id }} .landing-reasons__description {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  #landing-reasons-{{ section.id }} .landing-reasons__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-10) var(--space-8);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-10);
  }

  #landing-reasons-{{ section.id }} .landing-reasons__num {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-tertiary);
    margin-bottom: 0.75rem;
  }

  #landing-reasons-{{ section.id }} .landing-reasons__title {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  #landing-reasons-{{ section.id }} .landing-reasons__text {
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    max-width: 36ch;
  }

  @media (max-width: 640px) {
    #landing-reasons-{{ section.id }} .landing-reasons__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Landing Reasons",
  "tag": "section",
  "class": "landing-reasons-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why ready-to-launch stores work"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Built for demand, structured for ownership, and designed to grow beyond launch day."
    }
  ],
  "blocks": [
    {
      "type": "reason",
      "name": "Reason",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "High consumer demand"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Niches chosen for search interest and buying behaviour."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Landing Reasons",
      "blocks": [
        { "type": "reason", "settings": { "title": "High consumer demand", "description": "Niches chosen for search interest and real buying behaviour." } },
        { "type": "reason", "settings": { "title": "Strong repeat potential", "description": "Categories that support repeat purchase and upsells." } },
        { "type": "reason", "settings": { "title": "Scalable catalogue", "description": "Room to expand products as your brand grows." } },
        { "type": "reason", "settings": { "title": "Strategic structure", "description": "Built as a business foundation — not a disposable template." } }
      ]
    }
  ]
}
{% endschema %}
