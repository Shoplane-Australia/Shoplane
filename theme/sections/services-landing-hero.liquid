<section
  id="services-hero-{{ section.id }}"
  class="services-landing-hero"
  data-section-id="{{ section.id }}"
  data-section-type="services-landing-hero"
>
  <div class="container">
    <div class="services-landing-hero__layout">
      <div class="services-landing-hero__content{% unless request.design_mode %} animate-on-scroll stagger-1{% endunless %}">
        {%- if section.settings.eyebrow != blank -%}
          <span class="services-landing-hero__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h1 class="services-landing-hero__heading">{{ section.settings.heading }}</h1>
        {%- if section.settings.description != blank -%}
          <p class="services-landing-hero__description">{{ section.settings.description }}</p>
        {%- endif -%}
        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_url | default: '/pages/contact' }}" class="btn btn-dark btn-lg services-landing-hero__cta">
            {{ section.settings.cta_text }}
          </a>
        {%- endif -%}
        {%- if section.blocks.size > 0 -%}
          <ul class="services-landing-hero__checks">
            {%- for block in section.blocks -%}
              {%- if block.type == 'feature' -%}
                <li {{ block.shopify_attributes }}>
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <circle cx="9" cy="9" r="9" fill="#00D4AA"/>
                    <path d="M5.5 9l2 2 5-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {{ block.settings.text }}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <div class="services-landing-hero__visual{% unless request.design_mode %} animate-on-scroll stagger-2{% endunless %}">
        {%- if section.settings.hero_image != blank -%}
          {{
            section.settings.hero_image
            | image_url: width: 1200
            | image_tag:
              class: 'services-landing-hero__image',
              loading: 'eager',
              widths: '600, 900, 1200',
              sizes: '(max-width: 991px) 100vw, 50vw',
              alt: section.settings.heading
          }}
        {%- else -%}
          <div class="services-landing-hero__image-placeholder" aria-hidden="true">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity="0.35">
              <rect x="2" y="4" width="20" height="14" rx="2"/>
              <path d="M8 20h8M12 18v2"/>
            </svg>
            <span>Add hero image in theme settings</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  #services-hero-{{ section.id }} {
    background: {{ section.settings.background_color }};
    padding: calc(var(--header-height, 80px) + 48px) 0 80px;
  }

  #services-hero-{{ section.id }} .services-landing-hero__layout {
    display: grid;
    grid-template-columns: minmax(280px, 1fr) minmax(280px, 1fr);
    gap: 48px;
    align-items: center;
  }

  #services-hero-{{ section.id }} .services-landing-hero__eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  #services-hero-{{ section.id }} .services-landing-hero__heading {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.12;
    color: var(--color-text);
    margin: 0 0 20px;
  }

  #services-hero-{{ section.id }} .services-landing-hero__description {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0 0 28px;
    max-width: 48ch;
  }

  #services-hero-{{ section.id }} .btn-dark {
    background: #0f2a1c;
    color: #fff;
    border-radius: 999px;
    padding: 0.875rem 1.75rem;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  #services-hero-{{ section.id }} .btn-dark:hover {
    background: #163828;
    transform: translateY(-1px);
  }

  #services-hero-{{ section.id }} .services-landing-hero__checks {
    list-style: none;
    margin: 28px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #services-hero-{{ section.id }} .services-landing-hero__checks li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.95rem;
    color: var(--color-text);
    font-weight: 500;
  }

  #services-hero-{{ section.id }} .services-landing-hero__image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
  }

  #services-hero-{{ section.id }} .services-landing-hero__image-placeholder {
    aspect-ratio: 4 / 3;
    border-radius: 12px;
    background: linear-gradient(145deg, #eef2ff, #e8f4f8);
    border: 1px dashed rgba(15, 42, 28, 0.15);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: rgba(15, 42, 28, 0.45);
    font-size: 0.875rem;
  }

  @media (max-width: 991px) {
    #services-hero-{{ section.id }} .services-landing-hero__layout {
      grid-template-columns: 1fr;
    }
  }

  {% if request.design_mode %}
    #services-hero-{{ section.id }} .animate-on-scroll {
      opacity: 1;
      transform: none;
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "Services landing hero",
  "tag": "section",
  "class": "services-landing-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shopify Services to Build, Launch & Scale Your Business"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "From store setup to ongoing growth, Shoplane provides the services you need to build, refine and scale your ecommerce business with confidence."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Book A Call"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#f9f8f3"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature bullet",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "End-to-end Shopify setup"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Services landing hero",
      "blocks": [
        { "type": "feature", "settings": { "text": "End-to-end Shopify setup" } },
        { "type": "feature", "settings": { "text": "Conversion & performance optimization" } },
        { "type": "feature", "settings": { "text": "Ongoing store support & growth" } }
      ]
    }
  ]
}
{% endschema %}
