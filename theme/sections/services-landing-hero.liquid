<section
  id="services-hero-{{ section.id }}"
  class="services-landing-hero"
  data-header-theme="light"
  data-section-id="{{ section.id }}"
  data-section-type="services-landing-hero"
>
  <div class="container services-landing-hero__container">
    <p class="services-landing-hero__brand animate-on-scroll stagger-1">
      {{ section.settings.brand_text | default: 'SHOPLANE' }}
    </p>

    <h1 class="services-landing-hero__heading animate-on-scroll stagger-2">
      {{ section.settings.heading }}
    </h1>

    {%- if section.settings.description != blank -%}
      <p class="services-landing-hero__description animate-on-scroll stagger-3">
        {{ section.settings.description }}
      </p>
    {%- endif -%}

    <div class="services-landing-hero__actions animate-on-scroll stagger-4">
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_url | default: '/pages/contact' }}" class="btn btn-primary btn-lg">
          {{ section.settings.cta_text }}
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_cta_text != blank -%}
        <a href="{{ section.settings.secondary_cta_url | default: '#category-01' }}" class="btn btn-outline btn-lg">
          {{ section.settings.secondary_cta_text }}
        </a>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <ul class="services-landing-hero__checks animate-on-scroll stagger-5">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

<style>
  #services-hero-{{ section.id }} {
    background: var(--color-background, #FAFAF8);
    padding: calc(var(--header-height, 72px) + 4rem) 0 3.5rem;
  }

  #services-hero-{{ section.id }} .services-landing-hero__container {
    max-width: 720px;
  }

  #services-hero-{{ section.id }} .services-landing-hero__brand {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.95;
    color: var(--color-text);
    margin: 0 0 1.25rem;
  }

  #services-hero-{{ section.id }} .services-landing-hero__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.65rem, 3vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--color-text);
    margin: 0 0 1rem;
    max-width: 22ch;
  }

  #services-hero-{{ section.id }} .services-landing-hero__description {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0 0 2rem;
    max-width: 42ch;
  }

  #services-hero-{{ section.id }} .services-landing-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 1.75rem;
  }

  #services-hero-{{ section.id }} .services-landing-hero__checks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1.5rem;
  }

  #services-hero-{{ section.id }} .services-landing-hero__checks li {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  #services-hero-{{ section.id }} .services-landing-hero__checks li::before {
    content: '— ';
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    #services-hero-{{ section.id }} .services-landing-hero__actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>

{% schema %}
{
  "name": "Services Landing Hero",
  "tag": "section",
  "class": "services-landing-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand wordmark",
      "default": "SHOPLANE"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (unused)",
      "default": "Shopify Partner Services"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shopify Services to Build, Launch & Scale"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "From store setup to ongoing growth, Shoplane provides the expert services you need to build, refine and scale your ecommerce business with confidence."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Primary CTA",
      "default": "Book A Free Call"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "secondary_cta_text",
      "label": "Secondary CTA",
      "default": "Browse Services"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image (unused in editorial layout)"
    },
    {
      "type": "text",
      "id": "float_stat_number",
      "label": "Float stat number",
      "default": "12+"
    },
    {
      "type": "text",
      "id": "float_stat_label",
      "label": "Float stat label",
      "default": "Expert services"
    },
    {
      "type": "text",
      "id": "stat_1_number",
      "label": "Stat 1 number",
      "default": "12+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "Professional services"
    },
    {
      "type": "text",
      "id": "stat_2_number",
      "label": "Stat 2 number",
      "default": "5"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "Service categories"
    },
    {
      "type": "text",
      "id": "stat_3_number",
      "label": "Stat 3 number",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "Done-for-you delivery"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#FAFAF8"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "End-to-end Shopify setup"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Services Landing Hero",
      "blocks": [
        { "type": "feature", "settings": { "text": "End-to-end Shopify setup" } },
        { "type": "feature", "settings": { "text": "Conversion & performance" } },
        { "type": "feature", "settings": { "text": "Ongoing growth support" } }
      ]
    }
  ]
}
{% endschema %}
