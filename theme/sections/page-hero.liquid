{% comment %} Page Hero — Editorial light {% endcomment %}

<section class="page-hero" data-header-theme="light">
  <div class="container">
    <div class="page-hero__content animate-on-scroll">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol class="breadcrumbs__list">
          <li><a href="{{ routes.root_url }}">Home</a></li>
          <li aria-current="page">{{ page.title | default: section.settings.title }}</li>
        </ol>
      </nav>

      <p class="page-hero__brand">{{ section.settings.brand_text | default: 'SHOPLANE' }}</p>
      <h1 class="page-hero__title">{{ page.title | default: section.settings.title }}</h1>

      {% if section.settings.subtitle != blank %}
        <p class="page-hero__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    background: var(--color-background, #FAFAF8);
    padding: calc(var(--header-height, 72px) + 3.5rem) 0 3rem;
    overflow: hidden;
  }

  .page-hero__content {
    position: relative;
    z-index: 1;
    max-width: 640px;
  }

  .page-hero .breadcrumbs__list {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    font-size: 0.8125rem;
  }

  .page-hero .breadcrumbs__list li:not(:last-child)::after {
    content: '›';
    margin-left: 0.5rem;
    color: var(--color-text-tertiary);
  }

  .page-hero .breadcrumbs__list a {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .page-hero .breadcrumbs__list a:hover {
    color: var(--color-accent);
  }

  .page-hero .breadcrumbs__list [aria-current] {
    color: var(--color-text);
  }

  .page-hero__brand {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.95;
    color: var(--color-text);
    margin: 0 0 1rem;
  }

  .page-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(1.65rem, 3vw, 2.5rem);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.75rem;
    letter-spacing: -0.03em;
    line-height: 1.15;
  }

  .page-hero__subtitle {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    max-width: 42ch;
  }

  @media (max-width: 767px) {
    .page-hero {
      padding: calc(var(--header-height, 72px) + 2.5rem) 0 2rem;
    }
  }
</style>

{% schema %}
{
  "name": "Page Hero",
  "tag": "div",
  "class": "page-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand wordmark",
      "default": "SHOPLANE"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "info": "Falls back to the page title if not set"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    }
  ],
  "presets": [
    {
      "name": "Page Hero"
    }
  ]
}
{% endschema %}
