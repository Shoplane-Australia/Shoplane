{% comment %} Shoplane Page Hero Section — Generic page header banner {% endcomment %}

<section class="page-hero">
  <div class="page-hero__overlay"></div>
  <div class="container">
    <div class="page-hero__content animate-on-scroll">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol class="breadcrumbs__list">
          <li><a href="/">Home</a></li>
          <li aria-current="page">{{ page.title | default: section.settings.title }}</li>
        </ol>
      </nav>

      <h1 class="page-hero__title">{{ page.title | default: section.settings.title }}</h1>

      {% if section.settings.subtitle != blank %}
        <p class="page-hero__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    background: var(--color-dark, #0A0A0A);
    padding: 6rem 0 3.5rem;
    overflow: hidden;
  }
  .page-hero__overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 50%, rgba(108,99,255,0.12) 0%, transparent 70%);
  }
  .page-hero__content {
    position: relative;
    z-index: 1;
    max-width: 640px;
  }
  .page-hero .breadcrumbs__list {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    font-size: 0.8125rem;
  }
  .page-hero .breadcrumbs__list li:not(:last-child)::after {
    content: '›';
    margin-left: 0.5rem;
    color: rgba(255,255,255,0.3);
  }
  .page-hero .breadcrumbs__list a {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.2s;
  }
  .page-hero .breadcrumbs__list a:hover {
    color: var(--color-teal, #00D4AA);
  }
  .page-hero .breadcrumbs__list [aria-current] {
    color: rgba(255,255,255,0.7);
  }
  .page-hero__title {
    font-size: 2.5rem;
    font-weight: 800;
    color: #fff;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .page-hero__subtitle {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    margin: 0;
    max-width: 500px;
  }

  @media (max-width: 767px) {
    .page-hero {
      padding: 5rem 0 2.5rem;
    }
    .page-hero__title {
      font-size: 1.75rem;
    }
  }
</style>

{% schema %}
{
  "name": "Page Hero",
  "tag": "div",
  "class": "page-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "info": "Falls back to the page title if not set"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    }
  ],
  "presets": [
    {
      "name": "Page Hero"
    }
  ]
}
{% endschema %}
