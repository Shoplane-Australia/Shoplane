<section
  id="stores-hero-{{ section.id }}"
  class="stores-landing-hero"
  data-header-theme="light"
  data-section-id="{{ section.id }}"
>
  <div class="container stores-landing-hero__container">
    <p class="stores-landing-hero__brand animate-on-scroll stagger-1">
      {{ section.settings.brand_text | default: 'SHOPLANE' }}
    </p>
    <h1 class="stores-landing-hero__heading animate-on-scroll stagger-2">
      {{ section.settings.heading | default: collection.title }}
    </h1>
    {%- if section.settings.subheading != blank -%}
      <p class="stores-landing-hero__subheading animate-on-scroll stagger-3">
        {{ section.settings.subheading }}
      </p>
    {%- elsif collection.description != blank -%}
      <p class="stores-landing-hero__subheading animate-on-scroll stagger-3">
        {{ collection.description | strip_html | truncate: 180 }}
      </p>
    {%- endif -%}

    <div class="stores-landing-hero__actions animate-on-scroll stagger-4">
      {%- if section.settings.primary_cta_text != blank -%}
        <a href="{{ section.settings.primary_cta_url | default: '#stores-grid' }}" class="btn btn-primary btn-lg">
          {{ section.settings.primary_cta_text }}
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_cta_text != blank -%}
        <a href="{{ section.settings.secondary_cta_url }}" class="btn btn-outline btn-lg">
          {{ section.settings.secondary_cta_text }}
        </a>
      {%- endif -%}
    </div>

    <p class="stores-landing-hero__count animate-on-scroll stagger-5">
      {{ collection.products_count }} {{ collection.products_count | pluralize: 'ready-made store', 'ready-made stores' }}
    </p>
  </div>
</section>

<style>
  #stores-hero-{{ section.id }} {
    background: var(--color-background, #FAFAF8);
    padding: calc(var(--header-height, 72px) + 4rem) 0 3.5rem;
  }

  #stores-hero-{{ section.id }} .stores-landing-hero__container {
    max-width: 720px;
  }

  #stores-hero-{{ section.id }} .stores-landing-hero__brand {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.95;
    color: var(--color-text);
    margin: 0 0 1.25rem;
  }

  #stores-hero-{{ section.id }} .stores-landing-hero__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.65rem, 3vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--color-text);
    margin: 0 0 1rem;
    max-width: 18ch;
  }

  #stores-hero-{{ section.id }} .stores-landing-hero__subheading {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0 0 2rem;
    max-width: 40ch;
  }

  #stores-hero-{{ section.id }} .stores-landing-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 1.5rem;
  }

  #stores-hero-{{ section.id }} .stores-landing-hero__count {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin: 0;
  }

  @media (max-width: 640px) {
    #stores-hero-{{ section.id }} .stores-landing-hero__actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>

{% schema %}
{
  "name": "Stores Landing Hero",
  "tag": "section",
  "class": "stores-landing-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand wordmark",
      "default": "SHOPLANE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready-to-Launch Stores"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Niche-focused Shopify stores built with structure, strategy and long-term scalability — professionally configured and ready to launch."
    },
    {
      "type": "text",
      "id": "primary_cta_text",
      "label": "Primary CTA",
      "default": "Browse Stores"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "secondary_cta_text",
      "label": "Secondary CTA",
      "default": "Book a Call"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Secondary CTA link"
    }
  ],
  "presets": [{ "name": "Stores Landing Hero" }]
}
{% endschema %}
