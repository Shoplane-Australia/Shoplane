{% comment %} Contact Form — Editorial light {% endcomment %}

<section class="contact-section">
  <div class="container">
    <div class="contact-grid animate-on-scroll">
      <div class="contact-form-col">
        <h2 class="contact-form__heading">{{ section.settings.form_heading }}</h2>
        <p class="contact-form__text">{{ section.settings.form_subtext }}</p>

        {% form 'contact', class: 'contact-form' %}
          {% if form.posted_successfully? %}
            <div class="form-success" role="alert">
              <p>Thanks for reaching out! We'll get back to you within 24 hours.</p>
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="form-errors" role="alert">
              <p>Please fix the following:</p>
              <ul>
                {% for field in form.errors %}
                  <li>{{ form.errors.messages[field] }}</li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}

          <div class="form-row">
            <div class="form-group">
              <label for="contact-name" class="form-label">Full name <span class="required" aria-hidden="true">*</span></label>
              <input type="text" id="contact-name" name="contact[name]" required autocomplete="name" placeholder="Your name" class="form-input">
            </div>
            <div class="form-group">
              <label for="contact-email" class="form-label">Email <span class="required" aria-hidden="true">*</span></label>
              <input type="email" id="contact-email" name="contact[email]" required autocomplete="email" placeholder="you@example.com" class="form-input">
            </div>
          </div>

          <div class="form-group">
            <label for="contact-subject" class="form-label">Subject</label>
            <select id="contact-subject" name="contact[subject]" class="form-select">
              <option value="" disabled selected>Choose a topic</option>
              <option value="Ready-made store enquiry">Ready-made store enquiry</option>
              <option value="Custom store project">Custom store project</option>
              <option value="Service enquiry">Service enquiry</option>
              <option value="Support">Support / Help with my store</option>
              <option value="Partnership">Partnership opportunity</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="contact-message" class="form-label">Message <span class="required" aria-hidden="true">*</span></label>
            <textarea id="contact-message" name="contact[body]" required rows="5" placeholder="Tell us how we can help..." class="form-textarea"></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-lg contact-submit">Send message</button>
        {% endform %}
      </div>

      <aside class="contact-info-col">
        <div class="contact-info-card">
          <h3 class="contact-info__heading">Get in touch</h3>

          <div class="contact-info__item">
            <span class="contact-info__label">Email</span>
            <a href="mailto:{{ section.settings.email }}" class="contact-info__value">{{ section.settings.email }}</a>
          </div>

          {% if section.settings.phone != blank %}
            <div class="contact-info__item">
              <span class="contact-info__label">Phone</span>
              <a href="tel:{{ section.settings.phone }}" class="contact-info__value">{{ section.settings.phone }}</a>
            </div>
          {% endif %}

          {% if section.settings.hours != blank %}
            <div class="contact-info__item">
              <span class="contact-info__label">Business hours</span>
              <span class="contact-info__value">{{ section.settings.hours }}</span>
            </div>
          {% endif %}

          {% if section.settings.location != blank %}
            <div class="contact-info__item">
              <span class="contact-info__label">Location</span>
              <span class="contact-info__value">{{ section.settings.location }}</span>
            </div>
          {% endif %}

          <div class="contact-social">
            <span class="contact-info__label">Follow us</span>
            {% render 'social-icons', modifier_class: 'social-icons-sm', list: true %}
          </div>

          <p class="contact-partner">Official Shopify Partner</p>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .contact-section {
    background: var(--color-background, #FAFAF8);
    padding: 0 0 var(--space-20);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-16);
    align-items: start;
  }

  .contact-form__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.5rem;
    letter-spacing: -0.03em;
  }

  .contact-form__text {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.375rem;
  }

  .required {
    color: var(--color-accent);
  }

  .form-input,
  .form-select,
  .form-textarea {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 0.9375rem;
    color: var(--color-text);
    background: var(--color-background);
    font-family: inherit;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .form-select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%237A7872' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
    cursor: pointer;
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-submit {
    width: 100%;
    margin-top: 0.5rem;
  }

  .form-success {
    padding: 1rem 1.25rem;
    background: var(--color-accent-subtle);
    border: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
    color: var(--color-accent);
    font-weight: 500;
    font-size: 0.9375rem;
  }

  .form-success p { margin: 0; }

  .form-errors {
    padding: 1rem 1.25rem;
    background: rgba(185, 28, 28, 0.06);
    border: 1px solid rgba(185, 28, 28, 0.2);
    margin-bottom: 1.5rem;
    color: #b91c1c;
    font-size: 0.9375rem;
  }

  .contact-info-card {
    background: var(--color-surface, #F0EEE9);
    border: 1px solid var(--color-border);
    padding: 2rem;
    position: sticky;
    top: calc(var(--header-height, 72px) + 1.5rem);
  }

  .contact-info__heading {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
    color: var(--color-text);
  }

  .contact-info__item {
    margin-bottom: 1.25rem;
  }

  .contact-info__label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
    margin-bottom: 4px;
    font-weight: 600;
  }

  .contact-info__value {
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.975rem;
  }

  a.contact-info__value:hover {
    color: var(--color-accent);
  }

  .contact-social {
    margin-top: 1.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .social-icons-sm,
  .social-icons-sm.social-icons--list {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    list-style: none;
    margin: 0.75rem 0 0;
    padding: 0;
  }

  .social-icons-sm .social-icons__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    transition: border-color 0.2s, color 0.2s;
  }

  .social-icons-sm .social-icons__link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .contact-partner {
    margin: 1.5rem 0 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  @media (max-width: 991px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-info-card {
      position: static;
    }
  }

  @media (max-width: 599px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Contact Form",
  "tag": "div",
  "class": "contact-form-section",
  "settings": [
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form heading",
      "default": "Send us a message"
    },
    {
      "type": "text",
      "id": "form_subtext",
      "label": "Form subtext",
      "default": "Have a question about our stores or services? We'd love to hear from you."
    },
    {
      "type": "header",
      "content": "Contact information"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "hello@shoplane.com.au"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "info": "Leave blank to hide"
    },
    {
      "type": "text",
      "id": "hours",
      "label": "Business hours",
      "default": "Mon–Fri, 9am–5pm AEST"
    },
    {
      "type": "text",
      "id": "location",
      "label": "Location",
      "default": "Australia"
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
