{% comment %} Shoplane Contact Form Section {% endcomment %}

<section class="contact-section section-lg">
  <div class="container">
    <div class="contact-grid animate-on-scroll">

      {%- comment -%} Contact Form {%- endcomment -%}
      <div class="contact-form-col">
        <h2 class="contact-form__heading">{{ section.settings.form_heading }}</h2>
        <p class="contact-form__text">{{ section.settings.form_subtext }}</p>

        {% form 'contact', class: 'contact-form' %}
          {% if form.posted_successfully? %}
            <div class="form-success" role="alert">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="10" fill="#00D4AA" opacity="0.15"/>
                <path d="M6 10.5L8.5 13L14 7" stroke="#00D4AA" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <p>Thanks for reaching out! We'll get back to you within 24 hours.</p>
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="form-errors" role="alert">
              <p>Please fix the following:</p>
              <ul>
                {% for field in form.errors %}
                  <li>{{ form.errors.messages[field] }}</li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}

          <div class="form-row">
            <div class="form-group">
              <label for="contact-name" class="form-label">Full Name <span class="required" aria-hidden="true">*</span></label>
              <input
                type="text"
                id="contact-name"
                name="contact[name]"
                required
                autocomplete="name"
                placeholder="Your name"
                class="form-input"
              >
            </div>
            <div class="form-group">
              <label for="contact-email" class="form-label">Email Address <span class="required" aria-hidden="true">*</span></label>
              <input
                type="email"
                id="contact-email"
                name="contact[email]"
                required
                autocomplete="email"
                placeholder="you@example.com"
                class="form-input"
              >
            </div>
          </div>

          <div class="form-group">
            <label for="contact-subject" class="form-label">Subject</label>
            <select id="contact-subject" name="contact[subject]" class="form-select">
              <option value="" disabled selected>Choose a topic</option>
              <option value="Ready-made store enquiry">Ready-made store enquiry</option>
              <option value="Custom store project">Custom store project</option>
              <option value="Service enquiry">Service enquiry</option>
              <option value="Support">Support / Help with my store</option>
              <option value="Partnership">Partnership opportunity</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="contact-message" class="form-label">Message <span class="required" aria-hidden="true">*</span></label>
            <textarea
              id="contact-message"
              name="contact[body]"
              required
              rows="5"
              placeholder="Tell us how we can help..."
              class="form-textarea"
            ></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-lg contact-submit">
            Send Message
          </button>
        {% endform %}
      </div>

      {%- comment -%} Contact Info {%- endcomment -%}
      <div class="contact-info-col">
        <div class="contact-info-card">
          <h3 class="contact-info__heading">Get in Touch</h3>

          <div class="contact-info__item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="1.5"/>
              <polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <div>
              <span class="contact-info__label">Email</span>
              <a href="mailto:{{ section.settings.email }}" class="contact-info__value">{{ section.settings.email }}</a>
            </div>
          </div>

          {% if section.settings.phone != blank %}
            <div class="contact-info__item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5"/>
              </svg>
              <div>
                <span class="contact-info__label">Phone</span>
                <a href="tel:{{ section.settings.phone }}" class="contact-info__value">{{ section.settings.phone }}</a>
              </div>
            </div>
          {% endif %}

          {% if section.settings.hours != blank %}
            <div class="contact-info__item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                <polyline points="12,6 12,12 16,14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <div>
                <span class="contact-info__label">Business Hours</span>
                <span class="contact-info__value">{{ section.settings.hours }}</span>
              </div>
            </div>
          {% endif %}

          {% if section.settings.location != blank %}
            <div class="contact-info__item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/>
              </svg>
              <div>
                <span class="contact-info__label">Location</span>
                <span class="contact-info__value">{{ section.settings.location }}</span>
              </div>
            </div>
          {% endif %}

          {%- comment -%} Social Links {%- endcomment -%}
          <div class="contact-social">
            <span class="contact-info__label">Follow Us</span>
            <ul class="social-icons-sm">
              {% if settings.social_facebook_link != blank %}
                <li><a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a></li>
              {% endif %}
              {% if settings.social_instagram_link != blank %}
                <li><a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a></li>
              {% endif %}
              {% if settings.social_twitter_link != blank %}
                <li><a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a></li>
              {% endif %}
              {% if settings.social_youtube_link != blank %}
                <li><a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </a></li>
              {% endif %}
            </ul>
          </div>

          {%- comment -%} Partner Badge {%- endcomment -%}
          <div class="contact-partner">
            <span class="partner-badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5"/>
                <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Official Shopify Partner
            </span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .contact-section {
    background: #fff;
    padding: 4rem 0 5rem;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 3.5rem;
    align-items: start;
  }

  /* Form Column */
  .contact-form__heading {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-dark, #0A0A0A);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .contact-form__text {
    font-size: 1rem;
    color: #888;
    margin: 0 0 2rem;
    line-height: 1.6;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .form-group {
    margin-bottom: 1.25rem;
  }
  .form-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text, #333);
    margin-bottom: 0.375rem;
  }
  .required {
    color: #ff6b6b;
  }
  .form-input,
  .form-select,
  .form-textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 0.9375rem;
    color: var(--color-text, #333);
    background: #fff;
    font-family: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--color-accent, #6C63FF);
    box-shadow: 0 0 0 3px rgba(108,99,255,0.1);
  }
  .form-input::placeholder,
  .form-textarea::placeholder {
    color: #bbb;
  }
  .form-select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%23666' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
    cursor: pointer;
  }
  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }
  .contact-submit {
    width: 100%;
    margin-top: 0.5rem;
  }
  .form-success {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: rgba(0,212,170,0.08);
    border-radius: 8px;
    margin-bottom: 1.5rem;
    color: var(--color-teal, #00D4AA);
    font-weight: 500;
    font-size: 0.9375rem;
  }
  .form-success p { margin: 0; }
  .form-errors {
    padding: 1rem 1.25rem;
    background: rgba(255,107,107,0.08);
    border-radius: 8px;
    margin-bottom: 1.5rem;
    color: #ff6b6b;
    font-size: 0.9375rem;
  }
  .form-errors p { margin: 0 0 0.5rem; font-weight: 600; }
  .form-errors ul { margin: 0; padding-left: 1.25rem; }

  /* Info Column */
  .contact-info-card {
    background: var(--color-dark, #0A0A0A);
    border-radius: 16px;
    padding: 2.5rem;
    color: #fff;
    position: sticky;
    top: 120px;
  }
  .contact-info__heading {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 1.75rem;
  }
  .contact-info__item {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    margin-bottom: 1.5rem;
  }
  .contact-info__item svg {
    color: var(--color-accent, #6C63FF);
    margin-top: 2px;
    flex-shrink: 0;
  }
  .contact-info__label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.4);
    margin-bottom: 4px;
    font-weight: 600;
  }
  .contact-info__value {
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 0.2s;
  }
  a.contact-info__value:hover {
    color: var(--color-teal, #00D4AA);
  }

  .contact-social {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .social-icons-sm {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    list-style: none;
    margin: 0.75rem 0 0;
    padding: 0;
  }
  .social-icons-sm a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.6);
    transition: background 0.2s, color 0.2s;
  }
  .social-icons-sm a:hover {
    background: var(--color-accent, #6C63FF);
    color: #fff;
  }

  .contact-partner {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .partner-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(108,99,255,0.12);
    color: var(--color-accent, #6C63FF);
    border-radius: 6px;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  @media (max-width: 991px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .contact-info-card {
      position: static;
    }
  }
  @media (max-width: 599px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Contact Form",
  "tag": "div",
  "class": "contact-form-section",
  "settings": [
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form heading",
      "default": "Send Us a Message"
    },
    {
      "type": "text",
      "id": "form_subtext",
      "label": "Form subtext",
      "default": "Have a question about our stores or services? We'd love to hear from you."
    },
    {
      "type": "header",
      "content": "Contact information"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "hello@shoplane.com.au"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "info": "Leave blank to hide"
    },
    {
      "type": "text",
      "id": "hours",
      "label": "Business hours",
      "default": "Mon–Fri, 9am–5pm AEST"
    },
    {
      "type": "text",
      "id": "location",
      "label": "Location",
      "default": "Australia"
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
