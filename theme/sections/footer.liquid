{% comment %} Shoplane Premium Footer Section {% endcomment %}

<footer class="site-footer" role="contentinfo" aria-label="Site footer">
  {%- comment -%} Top Row: Logo + Newsletter {%- endcomment -%}
  <div class="footer-top">
    <div class="container">
      <div class="footer-top__inner">
        <div class="footer-top__brand">
          <a href="/" class="footer-logo" aria-label="{{ shop.name }} — Home">
            {% if section.settings.logo != blank %}
              <img
                src="{{ section.settings.logo | image_url: width: 180 }}"
                alt="{{ section.settings.logo.alt | default: shop.name }}"
                width="140"
                height="36"
                loading="lazy"
                class="footer-logo__img"
              >
            {% else %}
              <span class="footer-logo__text">{{ shop.name }}</span>
            {% endif %}
          </a>
          <p class="footer-tagline">{{ section.settings.tagline }}</p>
        </div>
        <div class="footer-newsletter">
          <h3 class="footer-newsletter__heading">{{ section.settings.newsletter_heading }}</h3>
          <p class="footer-newsletter__text">{{ section.settings.newsletter_text }}</p>
          {% form 'customer', class: 'footer-newsletter__form' %}
            <div class="newsletter-input-group">
              <input
                type="email"
                name="contact[email]"
                placeholder="Enter your email"
                required
                aria-label="Email for newsletter"
                autocomplete="email"
                class="newsletter-input"
              >
              <input type="hidden" name="contact[tags]" value="newsletter">
              <button type="submit" class="btn btn-primary newsletter-btn">Subscribe</button>
            </div>
            {% if form.posted_successfully? %}
              <p class="newsletter-success">Thanks for subscribing!</p>
            {% endif %}
            {% if form.errors %}
              <p class="newsletter-error">{{ form.errors.messages['email'] }}</p>
            {% endif %}
          {% endform %}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} Main Footer Grid {%- endcomment -%}
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">
        {% for block in section.blocks %}
          {% if block.type == 'footer_column' %}
            <div class="footer-column" {{ block.shopify_attributes }}>
              <h4 class="footer-column__heading">{{ block.settings.heading }}</h4>
              <ul class="footer-column__links">
                {% if block.settings.link_1_text != blank %}
                  <li><a href="{{ block.settings.link_1_url }}">{{ block.settings.link_1_text }}</a></li>
                {% endif %}
                {% if block.settings.link_2_text != blank %}
                  <li><a href="{{ block.settings.link_2_url }}">{{ block.settings.link_2_text }}</a></li>
                {% endif %}
                {% if block.settings.link_3_text != blank %}
                  <li><a href="{{ block.settings.link_3_url }}">{{ block.settings.link_3_text }}</a></li>
                {% endif %}
                {% if block.settings.link_4_text != blank %}
                  <li><a href="{{ block.settings.link_4_url }}">{{ block.settings.link_4_text }}</a></li>
                {% endif %}
                {% if block.settings.link_5_text != blank %}
                  <li><a href="{{ block.settings.link_5_url }}">{{ block.settings.link_5_text }}</a></li>
                {% endif %}
                {% if block.settings.link_6_text != blank %}
                  <li><a href="{{ block.settings.link_6_url }}">{{ block.settings.link_6_text }}</a></li>
                {% endif %}
              </ul>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  {%- comment -%} Social Icons Row {%- endcomment -%}
  <div class="footer-social">
    <div class="container">
      <div class="footer-social__inner">
        <ul class="social-icons" aria-label="Social media links">
          {% if settings.social_facebook_link != blank %}
            <li>
              <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            </li>
          {% endif %}
          {% if settings.social_instagram_link != blank %}
            <li>
              <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
            </li>
          {% endif %}
          {% if settings.social_twitter_link != blank %}
            <li>
              <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            </li>
          {% endif %}
          {% if settings.social_youtube_link != blank %}
            <li>
              <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </a>
            </li>
          {% endif %}
          {% if settings.social_tiktok_link != blank %}
            <li>
              <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
              </a>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </div>

  {%- comment -%} Bottom Bar {%- endcomment -%}
  <div class="footer-bottom">
    <div class="container">
      <div class="footer-bottom__inner">
        <p class="footer-copyright">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
          {% if section.settings.show_partner_badge %}
            <span class="footer-partner-badge">Official Shopify Partner</span>
          {% endif %}
        </p>
        <div class="footer-payments" aria-label="Accepted payment methods">
          {{ section.settings.payment_text }}
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-dark, #0A0A0A);
    color: rgba(255,255,255,0.7);
  }

  /* Top Row */
  .footer-top {
    padding: 3.5rem 0 2.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .footer-top__inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .footer-logo {
    display: inline-block;
    text-decoration: none;
    margin-bottom: 0.75rem;
  }
  .footer-logo__img {
    height: 36px;
    width: auto;
  }
  .footer-logo__text {
    font-size: 1.5rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
  }
  .footer-tagline {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.5);
    max-width: 320px;
    line-height: 1.6;
    margin: 0;
  }
  .footer-newsletter {
    max-width: 440px;
    width: 100%;
  }
  .footer-newsletter__heading {
    font-size: 1.0625rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.375rem;
  }
  .footer-newsletter__text {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.5);
    margin: 0 0 1rem;
  }
  .newsletter-input-group {
    display: flex;
    gap: 0;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.12);
  }
  .newsletter-input {
    flex: 1;
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.06);
    border: none;
    color: #fff;
    font-size: 0.9375rem;
    outline: none;
    font-family: inherit;
  }
  .newsletter-input::placeholder {
    color: rgba(255,255,255,0.35);
  }
  .newsletter-input:focus {
    background: rgba(255,255,255,0.1);
  }
  .newsletter-btn {
    border-radius: 0;
    padding: 0.75rem 1.5rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .newsletter-success {
    color: var(--color-teal, #00D4AA);
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }
  .newsletter-error {
    color: #ff6b6b;
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }

  /* Main Grid */
  .footer-main {
    padding: 3rem 0;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  .footer-column__heading {
    font-size: 0.875rem;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 1.25rem;
  }
  .footer-column__links {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-column__links li {
    margin-bottom: 0.625rem;
  }
  .footer-column__links a {
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 0.2s;
    line-height: 1.5;
  }
  .footer-column__links a:hover {
    color: var(--color-teal, #00D4AA);
  }

  /* Social Icons */
  .footer-social {
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .footer-social__inner {
    display: flex;
    justify-content: center;
  }
  .social-icons {
    display: flex;
    align-items: center;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .social-icons a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.6);
    transition: background 0.2s, color 0.2s, transform 0.2s;
  }
  .social-icons a:hover {
    background: var(--color-accent, #6C63FF);
    color: #fff;
    transform: translateY(-2px);
  }

  /* Bottom Bar */
  .footer-bottom {
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .footer-bottom__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer-copyright {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.4);
    margin: 0;
  }
  .footer-partner-badge {
    display: inline-block;
    margin-left: 0.75rem;
    padding: 0.2rem 0.625rem;
    background: rgba(108,99,255,0.15);
    color: var(--color-accent, #6C63FF);
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 4px;
    vertical-align: middle;
  }
  .footer-payments {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.4);
  }

  @media (max-width: 991px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 599px) {
    .footer-top__inner {
      flex-direction: column;
    }
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-bottom__inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

