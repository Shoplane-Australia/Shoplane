{% comment %} Shoplane Footer — brand, link columns, social, payments {% endcomment %}

<footer
  class="site-footer"
  role="contentinfo"
  aria-label="Site footer"
  style="--footer-bg: {{ section.settings.background_color }};"
>
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">
        {%- comment -%} Brand column {%- endcomment -%}
        <div class="footer-brand">
          {%- if section.settings.partner_logo != blank -%}
            {%- capture partner_logo_alt -%}
              {%- render 'auto-alt', title: 'Shopify Partners', image: section.settings.partner_logo, fallback: 'Shopify Partners' -%}
            {%- endcapture -%}
            {{
              section.settings.partner_logo
              | image_url: width: 320
              | image_tag:
                class: 'footer-brand__partner-logo',
                widths: '160, 240, 320',
                sizes: '160px',
                alt: partner_logo_alt,
                loading: 'lazy'
            }}
          {%- endif -%}

          <a href="{{ routes.root_url }}" class="footer-brand__name" aria-label="{{ shop.name }} — Home">
            {%- if section.settings.logo != blank -%}
              {%- capture brand_logo_alt -%}
                {%- render 'auto-alt', title: section.settings.brand_name, image: section.settings.logo, fallback: shop.name -%}
              {%- endcapture -%}
              {{
                section.settings.logo
                | image_url: width: 280
                | image_tag:
                  class: 'footer-brand__logo-img',
                  widths: '140, 200, 280',
                  sizes: '140px',
                  alt: brand_logo_alt,
                  loading: 'lazy'
              }}
            {%- else -%}
              <span class="footer-brand__logo-text">{{ section.settings.brand_name | default: shop.name }}</span>
            {%- endif -%}
          </a>

          {%- if section.settings.tagline != blank -%}
            <p class="footer-brand__tagline">{{ section.settings.tagline }}</p>
          {%- endif -%}
        </div>

        {%- comment -%} Link columns from Shopify menus {%- endcomment -%}
        {% for block in section.blocks %}
          {% if block.type == 'footer_column' %}
            {%- assign menu = block.settings.menu -%}
            {%- if menu != blank -%}
              <div class="footer-column" {{ block.shopify_attributes }}>
                <h4 class="footer-column__heading">
                  {{ block.settings.heading | default: menu.title }}
                </h4>
                <ul class="footer-column__links">
                  {%- for link in menu.links -%}
                    <li>
                      <a href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>
                        {{ link.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                  {%- if block.settings.show_account_link and shop.customer_accounts_enabled -%}
                    <li>
                      <a href="{{ routes.account_url }}">
                        {{ 'customer.account.title' | t | default: 'My account' }}
                      </a>
                    </li>
                  {%- endif -%}
                </ul>
              </div>
            {%- elsif request.design_mode -%}
              <div class="footer-column footer-column--empty" {{ block.shopify_attributes }}>
                <p class="footer-column__placeholder">Choose a menu for this column</p>
              </div>
            {%- endif -%}
          {% endif %}
        {% endfor %}

        {%- comment -%} Get in touch / social {%- endcomment -%}
        <div class="footer-connect">
          <h4 class="footer-column__heading">{{ section.settings.social_heading }}</h4>
          {%- if section.settings.social_subheading != blank -%}
            <p class="footer-connect__subheading">{{ section.settings.social_subheading }}</p>
          {%- endif -%}
          {%- if section.settings.show_social_accounts -%}
            {% render 'social-icons', modifier_class: 'footer-social-icons', list: true %}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} Payments + Follow on Shop {%- endcomment -%}
  <div class="footer-utility">
    <div class="container">
      <div class="footer-utility__inner">
        {%- if section.settings.show_payment_icons -%}
          <div class="footer-payments">
            <p class="footer-payments__label">{{ section.settings.payment_heading }}</p>
            <ul class="footer-payments__icons" aria-label="Accepted payment methods">
              {%- for type in shop.enabled_payment_types -%}
                <li>{{ type | payment_type_svg_tag: class: 'footer-payments__icon' }}</li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        {%- if section.settings.show_follow_on_shop -%}
          <div class="footer-follow-shop">
            {{ shop | login_button: action: 'follow' }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p class="footer-copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--footer-bg, #0f2a1c);
    color: rgba(255, 255, 255, 0.72);
  }

  .footer-main {
    padding: 3.5rem 0 2.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(160px, 1.2fr) repeat(3, minmax(120px, 1fr)) minmax(140px, 1fr);
    gap: 2rem 2.5rem;
    align-items: start;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-brand__partner-logo {
    width: 140px;
    max-width: 100%;
    height: auto;
    display: block;
  }

  .footer-brand__name {
    display: inline-block;
    text-decoration: none;
  }

  .footer-brand__logo-img {
    height: 28px;
    width: auto;
    display: block;
  }

  .footer-brand__logo-text {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: #fff;
    line-height: 1;
  }

  .footer-brand__tagline {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.55;
    margin: 0;
    max-width: 220px;
  }

  .footer-column__heading {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 1rem;
    line-height: 1.3;
  }

  .footer-column__links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-column__links li {
    margin-bottom: 0.5rem;
  }

  .footer-column__links a {
    color: rgba(255, 255, 255, 0.88);
    text-decoration: none;
    font-size: 0.875rem;
    line-height: 1.45;
    transition: color 0.2s ease;
  }

  .footer-column__links a:hover {
    color: #fff;
  }

  .footer-column__links a[aria-current="page"] {
    color: #fff;
    font-weight: 600;
  }

  .footer-column--empty {
    padding: 1rem;
    border: 1px dashed rgba(255, 255, 255, 0.2);
    border-radius: 8px;
  }

  .footer-column__placeholder {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
  }

  .footer-connect__subheading {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.55);
    margin: -0.5rem 0 0.875rem;
  }

  .footer-social-icons,
  .footer-social-icons.social-icons--list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.625rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-social-icons .social-icons__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.85);
    transition: background 0.2s ease, color 0.2s ease;
  }

  .footer-social-icons .social-icons__link:hover {
    background: rgba(255, 255, 255, 0.16);
    color: #fff;
  }

  .footer-social-icons .social-icons__link svg {
    width: 18px;
    height: 18px;
  }

  .social-icons__placeholder {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
    line-height: 1.5;
  }

  .footer-utility {
    padding: 1.75rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-utility__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-payments__label {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 0.75rem;
  }

  .footer-payments__icons {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-payments__icon {
    height: 24px;
    width: auto;
    display: block;
  }

  .footer-follow-shop {
    margin-left: auto;
  }

  .footer-bottom {
    padding: 1rem 0 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer-copyright {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    margin: 0;
    text-align: center;
  }

  @media (max-width: 1100px) {
    .footer-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-connect {
      grid-column: span 1;
    }
  }

  @media (max-width: 767px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem 1.5rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-connect {
      grid-column: 1 / -1;
    }

    .footer-utility__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-follow-shop {
      margin-left: 0;
    }
  }

  @media (max-width: 479px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0f2a1c"
    },
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "partner_logo",
      "label": "Shopify Partner logo",
      "info": "ALT text uses “Shopify Partners” automatically."
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Brand logo image",
      "info": "Optional. ALT text uses the brand name below."
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name text",
      "default": "SHOPLANE"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline"
    },
    {
      "type": "header",
      "content": "Social"
    },
    {
      "type": "paragraph",
      "content": "Add your social account links in Theme settings → Social Media."
    },
    {
      "type": "checkbox",
      "id": "show_social_accounts",
      "label": "Show social accounts",
      "default": true
    },
    {
      "type": "text",
      "id": "social_heading",
      "label": "Social heading",
      "default": "Get in touch"
    },
    {
      "type": "text",
      "id": "social_subheading",
      "label": "Social subheading",
      "default": "Follow us"
    },
    {
      "type": "header",
      "content": "Payments & Shop"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "text",
      "id": "payment_heading",
      "label": "Payment heading",
      "default": "We accept"
    },
    {
      "type": "checkbox",
      "id": "show_follow_on_shop",
      "label": "Show Follow on Shop button",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "footer_column",
      "name": "Menu",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Title",
          "info": "Defaults to menu title"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Choose a menu",
          "info": "This menu will only show top-level links"
        },
        {
          "type": "checkbox",
          "id": "show_account_link",
          "label": "Add 'My account' link if customer accounts enabled",
          "default": false
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "footer_column",
        "settings": {
          "heading": "Our Services",
          "menu": "footer-services"
        }
      },
      {
        "type": "footer_column",
        "settings": {
          "heading": "Customer Help",
          "menu": "footer-help"
        }
      },
      {
        "type": "footer_column",
        "settings": {
          "heading": "Our Policies",
          "menu": "footer-policies"
        }
      }
    ]
  }
}
{% endschema %}
