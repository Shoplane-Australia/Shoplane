{% comment %} Shoplane Footer — editorial dark {% endcomment %}

<footer
  class="site-footer"
  role="contentinfo"
  aria-label="Site footer"
  style="--footer-bg: {{ section.settings.background_color }};"
>
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="{{ routes.root_url }}" class="footer-brand__name" aria-label="{{ shop.name }} — Home">
            {%- if section.settings.logo != blank -%}
              {%- capture brand_logo_alt -%}
                {%- render 'auto-alt', title: section.settings.brand_name, image: section.settings.logo, fallback: shop.name -%}
              {%- endcapture -%}
              {{
                section.settings.logo
                | image_url: width: 280
                | image_tag:
                  class: 'footer-brand__logo-img',
                  widths: '140, 200, 280',
                  sizes: '140px',
                  alt: brand_logo_alt,
                  loading: 'lazy'
              }}
            {%- else -%}
              <span class="footer-brand__wordmark">{{ section.settings.brand_name | default: shop.name }}</span>
            {%- endif -%}
          </a>

          {%- if section.settings.tagline != blank -%}
            <p class="footer-brand__tagline">{{ section.settings.tagline }}</p>
          {%- endif -%}

          {%- if section.settings.partner_logo != blank -%}
            <div class="footer-brand__partner">
              {%- capture partner_logo_alt -%}
                {%- render 'auto-alt', title: 'Shopify Partners', image: section.settings.partner_logo, fallback: 'Shopify Partners' -%}
              {%- endcapture -%}
              {{
                section.settings.partner_logo
                | image_url: width: 280
                | image_tag:
                  class: 'footer-brand__partner-logo',
                  widths: '140, 200, 280',
                  sizes: '120px',
                  alt: partner_logo_alt,
                  loading: 'lazy'
              }}
            </div>
          {%- elsif section.settings.show_partner_badge -%}
            <p class="footer-brand__badge">Official Shopify Partner</p>
          {%- endif -%}
        </div>

        {% for block in section.blocks %}
          {% if block.type == 'footer_column' %}
            {%- assign menu = block.settings.menu -%}
            {%- if menu != blank -%}
              <nav class="footer-column" aria-label="{{ block.settings.heading | default: menu.title }}" {{ block.shopify_attributes }}>
                <h4 class="footer-column__heading">
                  {{ block.settings.heading | default: menu.title }}
                </h4>
                <ul class="footer-column__links">
                  {%- for link in menu.links -%}
                    <li>
                      <a href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>
                        {{ link.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                  {%- if block.settings.show_account_link and shop.customer_accounts_enabled -%}
                    <li>
                      <a href="{{ routes.account_url }}">
                        {{ 'customer.account.title' | t | default: 'My account' }}
                      </a>
                    </li>
                  {%- endif -%}
                </ul>
              </nav>
            {%- elsif request.design_mode -%}
              <div class="footer-column footer-column--empty" {{ block.shopify_attributes }}>
                <p class="footer-column__placeholder">Choose a menu for this column</p>
              </div>
            {%- endif -%}
          {% endif %}
        {% endfor %}

        <div class="footer-connect">
          <h4 class="footer-column__heading">{{ section.settings.social_heading }}</h4>
          {%- if section.settings.social_subheading != blank -%}
            <p class="footer-connect__subheading">{{ section.settings.social_subheading }}</p>
          {%- endif -%}

          {%- if section.settings.contact_email != blank -%}
            <a href="mailto:{{ section.settings.contact_email }}" class="footer-connect__email">
              {{ section.settings.contact_email }}
            </a>
          {%- endif -%}

          {%- if section.settings.show_social_accounts -%}
            {% render 'social-icons', modifier_class: 'footer-social-icons', list: true %}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  {%- if section.settings.show_payment_icons or section.settings.show_follow_on_shop -%}
    <div class="footer-utility">
      <div class="container">
        <div class="footer-utility__inner">
          {%- if section.settings.show_payment_icons -%}
            <div class="footer-payments">
              <p class="footer-payments__label">{{ section.settings.payment_heading }}</p>
              <ul class="footer-payments__icons" aria-label="Accepted payment methods">
                {%- for type in shop.enabled_payment_types -%}
                  <li>{{ type | payment_type_svg_tag: class: 'footer-payments__icon' }}</li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          {%- if section.settings.show_follow_on_shop -%}
            <div class="footer-follow-shop">
              {{ shop | login_button: action: 'follow' }}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  <div class="footer-bottom">
    <div class="container">
      <div class="footer-bottom__inner">
        <p class="footer-copyright">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
        </p>
        {%- if section.settings.bottom_note != blank -%}
          <p class="footer-bottom__note">{{ section.settings.bottom_note }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--footer-bg, #121212);
    color: rgba(250, 250, 248, 0.65);
    border-top: 1px solid rgba(250, 250, 248, 0.08);
  }

  .footer-main {
    padding: clamp(3rem, 6vw, 4.5rem) 0 2.75rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(200px, 1.35fr) repeat(3, minmax(110px, 1fr)) minmax(150px, 1fr);
    gap: 2.5rem 2.75rem;
    align-items: start;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 280px;
  }

  .footer-brand__name {
    display: inline-block;
    text-decoration: none;
    width: fit-content;
  }

  .footer-brand__logo-img {
    height: 28px;
    width: auto;
    display: block;
  }

  .footer-brand__wordmark {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: #FAFAF8;
    line-height: 0.95;
  }

  .footer-brand__tagline {
    font-size: 0.9375rem;
    color: rgba(250, 250, 248, 0.55);
    line-height: 1.6;
    margin: 0;
  }

  .footer-brand__partner {
    margin-top: 0.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(250, 250, 248, 0.1);
  }

  .footer-brand__partner-logo {
    width: 120px;
    max-width: 100%;
    height: auto;
    display: block;
    opacity: 0.85;
  }

  .footer-brand__badge {
    margin: 0.5rem 0 0;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(250, 250, 248, 0.1);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(250, 250, 248, 0.45);
  }

  .footer-column__heading {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(250, 250, 248, 0.4);
    margin: 0 0 1.15rem;
    line-height: 1.3;
  }

  .footer-column__links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-column__links li {
    margin-bottom: 0.65rem;
  }

  .footer-column__links a {
    color: rgba(250, 250, 248, 0.82);
    text-decoration: none;
    font-size: 0.9375rem;
    line-height: 1.4;
    transition: color 0.2s ease;
  }

  .footer-column__links a:hover {
    color: #FAFAF8;
  }

  .footer-column__links a[aria-current="page"] {
    color: #FAFAF8;
    font-weight: 600;
  }

  .footer-column--empty {
    padding: 1rem;
    border: 1px dashed rgba(250, 250, 248, 0.2);
  }

  .footer-column__placeholder {
    font-size: 0.8125rem;
    color: rgba(250, 250, 248, 0.4);
    margin: 0;
  }

  .footer-connect__subheading {
    font-size: 0.875rem;
    color: rgba(250, 250, 248, 0.5);
    margin: -0.35rem 0 1rem;
    line-height: 1.5;
  }

  .footer-connect__email {
    display: inline-block;
    color: #FAFAF8;
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid rgba(250, 250, 248, 0.25);
    padding-bottom: 2px;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .footer-connect__email:hover {
    color: #FAFAF8;
    border-bottom-color: rgba(250, 250, 248, 0.7);
  }

  .footer-social-icons,
  .footer-social-icons.social-icons--list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-social-icons .social-icons__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid rgba(250, 250, 248, 0.18);
    border-radius: 0;
    background: transparent;
    color: rgba(250, 250, 248, 0.75);
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }

  .footer-social-icons .social-icons__link:hover {
    border-color: rgba(250, 250, 248, 0.45);
    color: #FAFAF8;
    background: rgba(250, 250, 248, 0.06);
  }

  .footer-social-icons .social-icons__link svg {
    width: 16px;
    height: 16px;
  }

  .footer-utility {
    padding: 1.5rem 0;
    border-top: 1px solid rgba(250, 250, 248, 0.08);
  }

  .footer-utility__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-payments__label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(250, 250, 248, 0.4);
    margin: 0 0 0.75rem;
  }

  .footer-payments__icons {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-payments__icon {
    height: 24px;
    width: auto;
    display: block;
    opacity: 0.85;
  }

  .footer-follow-shop {
    margin-left: auto;
  }

  .footer-bottom {
    padding: 1.15rem 0 1.5rem;
    border-top: 1px solid rgba(250, 250, 248, 0.06);
  }

  .footer-bottom__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copyright,
  .footer-bottom__note {
    font-size: 0.75rem;
    color: rgba(250, 250, 248, 0.35);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .footer-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.25rem 2rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
      max-width: 420px;
    }
  }

  @media (max-width: 767px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem 1.5rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-connect {
      grid-column: 1 / -1;
    }

    .footer-utility__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-follow-shop {
      margin-left: 0;
    }

    .footer-bottom__inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 479px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Brand logo image",
      "info": "Optional white/light logo. Falls back to brand name text."
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name text",
      "default": "SHOPLANE"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Ready-made Shopify stores and ecommerce services for Australian businesses."
    },
    {
      "type": "image_picker",
      "id": "partner_logo",
      "label": "Shopify Partner logo"
    },
    {
      "type": "checkbox",
      "id": "show_partner_badge",
      "label": "Show partner text badge if no logo",
      "default": true
    },
    {
      "type": "header",
      "content": "Connect"
    },
    {
      "type": "text",
      "id": "social_heading",
      "label": "Connect heading",
      "default": "Get in touch"
    },
    {
      "type": "text",
      "id": "social_subheading",
      "label": "Connect subheading",
      "default": "Questions about stores or services — we’re here."
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact email",
      "default": "hello@shoplane.com.au"
    },
    {
      "type": "checkbox",
      "id": "show_social_accounts",
      "label": "Show social accounts",
      "default": true
    },
    {
      "type": "paragraph",
      "content": "Add social links in Theme settings → Social media."
    },
    {
      "type": "header",
      "content": "Payments & Shop"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "text",
      "id": "payment_heading",
      "label": "Payment heading",
      "default": "We accept"
    },
    {
      "type": "checkbox",
      "id": "show_follow_on_shop",
      "label": "Show Follow on Shop button",
      "default": false
    },
    {
      "type": "text",
      "id": "bottom_note",
      "label": "Bottom note",
      "default": "Built for Australian ecommerce."
    }
  ],
  "blocks": [
    {
      "type": "footer_column",
      "name": "Menu",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Title",
          "info": "Defaults to menu title"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Choose a menu",
          "info": "Shows top-level links only"
        },
        {
          "type": "checkbox",
          "id": "show_account_link",
          "label": "Add ‘My account’ link if customer accounts enabled",
          "default": false
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "footer_column",
        "settings": {
          "heading": "Explore",
          "menu": "main-menu"
        }
      },
      {
        "type": "footer_column",
        "settings": {
          "heading": "Help",
          "menu": "customer-account-main-menu"
        }
      },
      {
        "type": "footer_column",
        "settings": {
          "heading": "Policies",
          "menu": "our-policies"
        }
      }
    ]
  }
}
{% endschema %}
