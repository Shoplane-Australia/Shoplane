<section
  id="cta-booking-{{ section.id }}"
  class="cta-booking section-dark"
  data-section-id="{{ section.id }}"
  data-section-type="cta-booking"
>
  <div class="container cta-booking__container">
    <div class="cta-booking__inner animate-on-scroll stagger-1">
      {%- if section.settings.eyebrow != blank -%}
        <span class="cta-booking__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      <h2 class="cta-booking__heading animate-on-scroll stagger-2">
        {{ section.settings.heading }}
      </h2>

      {%- if section.settings.subheading != blank -%}
        <p class="cta-booking__subheading animate-on-scroll stagger-3">
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}

      <div class="cta-booking__actions animate-on-scroll stagger-4">
        {%- if section.settings.primary_cta_text != blank -%}
          <a href="{{ section.settings.booking_url }}" class="btn btn-primary btn-lg">
            {{ section.settings.primary_cta_text }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_cta_text != blank -%}
          <a href="{{ section.settings.secondary_cta_url }}" class="btn btn-outline btn-lg">
            {{ section.settings.secondary_cta_text }}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.trust_note != blank -%}
        <p class="cta-booking__trust-note animate-on-scroll stagger-5">
          {{ section.settings.trust_note }}
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #cta-booking-{{ section.id }} {
    background: {{ section.settings.background_color | default: '#121212' }};
    position: relative;
    overflow: hidden;
    padding: var(--space-20) 0;
  }

  #cta-booking-{{ section.id }} .cta-booking__inner {
    text-align: left;
    max-width: 640px;
    color: #FAFAF8;
  }

  #cta-booking-{{ section.id }} .cta-booking__eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(250, 250, 248, 0.55);
    margin-bottom: 1rem;
  }

  #cta-booking-{{ section.id }} .cta-booking__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0 0 1.25rem;
    color: #FAFAF8;
  }

  #cta-booking-{{ section.id }} .cta-booking__subheading {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: rgba(250, 250, 248, 0.65);
    line-height: 1.6;
    margin: 0 0 2.25rem;
    max-width: 42ch;
  }

  #cta-booking-{{ section.id }} .cta-booking__actions {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  #cta-booking-{{ section.id }} .cta-booking__trust-note {
    margin-top: 1.5rem;
    font-size: 0.875rem;
    color: rgba(250, 250, 248, 0.45);
  }

  @media (max-width: 640px) {
    #cta-booking-{{ section.id }} .cta-booking__actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>

{% schema %}
{
  "name": "CTA Booking",
  "tag": "section",
  "class": "cta-booking-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Free Consultation"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Not Sure Where to Start?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Book a free 15-minute call with our team. We'll help you choose the right store or service for your goals — no pressure, no commitment."
    },
    {
      "type": "text",
      "id": "primary_cta_text",
      "label": "Primary CTA text",
      "default": "Book a Free Call"
    },
    {
      "type": "url",
      "id": "booking_url",
      "label": "Booking link (Calendly, etc.)"
    },
    {
      "type": "text",
      "id": "secondary_cta_text",
      "label": "Secondary CTA text",
      "default": "Browse Stores"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "text",
      "id": "trust_note",
      "label": "Trust note text",
      "default": "No credit card required. 100% free consultation."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#121212"
    }
  ],
  "presets": [
    {
      "name": "CTA Booking"
    }
  ]
}
{% endschema %}
