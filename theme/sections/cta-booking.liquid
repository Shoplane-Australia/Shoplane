<section
  id="cta-booking-{{ section.id }}"
  class="cta-booking section-dark"
  data-section-id="{{ section.id }}"
  data-section-type="cta-booking"
>
  {%- comment -%} Decorative glow accents {%- endcomment -%}
  <div class="cta-booking__glow cta-booking__glow--left" aria-hidden="true"></div>
  <div class="cta-booking__glow cta-booking__glow--right" aria-hidden="true"></div>

  <div class="container cta-booking__container">
    <div class="cta-booking__inner animate-on-scroll stagger-1">
      {%- if section.settings.eyebrow != blank -%}
        <span class="cta-booking__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      <h2 class="cta-booking__heading animate-on-scroll stagger-2">
        {{ section.settings.heading }}
      </h2>

      {%- if section.settings.subheading != blank -%}
        <p class="cta-booking__subheading animate-on-scroll stagger-3">
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}

      <div class="cta-booking__actions animate-on-scroll stagger-4">
        {%- if section.settings.primary_cta_text != blank -%}
          <a href="{{ section.settings.booking_url }}" class="btn btn-primary btn-lg cta-booking__btn-primary">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <rect x="3" y="4" width="14" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M7 2v4M13 2v4M3 9h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            {{ section.settings.primary_cta_text }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_cta_text != blank -%}
          <a href="{{ section.settings.secondary_cta_url }}" class="btn btn-outline btn-lg">
            {{ section.settings.secondary_cta_text }}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.trust_note != blank -%}
        <p class="cta-booking__trust-note animate-on-scroll stagger-5">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 1l1.8 3.6L14 5.3l-3 2.9.7 4.1L8 10.5l-3.7 1.8.7-4.1-3-2.9 4.2-.7L8 1z" fill="#00D4AA"/>
          </svg>
          {{ section.settings.trust_note }}
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #cta-booking-{{ section.id }} {
    background: {{ section.settings.background_color }};
    position: relative;
    overflow: hidden;
    padding: 100px 0;
  }

  #cta-booking-{{ section.id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(108, 99, 255, 0.08) 0%,
      transparent 40%,
      transparent 60%,
      rgba(0, 212, 170, 0.06) 100%
    );
    z-index: 0;
  }

  #cta-booking-{{ section.id }} .cta-booking__glow {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.25;
    z-index: 0;
    pointer-events: none;
  }

  #cta-booking-{{ section.id }} .cta-booking__glow--left {
    background: #6C63FF;
    left: -10%;
    top: 20%;
  }

  #cta-booking-{{ section.id }} .cta-booking__glow--right {
    background: #00D4AA;
    right: -10%;
    bottom: 10%;
  }

  #cta-booking-{{ section.id }} .cta-booking__container {
    position: relative;
    z-index: 1;
  }

  #cta-booking-{{ section.id }} .cta-booking__inner {
    text-align: center;
    max-width: 680px;
    margin: 0 auto;
    color: #ffffff;
  }

  #cta-booking-{{ section.id }} .cta-booking__eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #00D4AA;
    margin-bottom: 16px;
  }

  #cta-booking-{{ section.id }} .cta-booking__heading {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0 0 20px;
    background: linear-gradient(135deg, #ffffff 30%, #C4BFFF 70%, #00D4AA 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  #cta-booking-{{ section.id }} .cta-booking__subheading {
    font-size: 1.15rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
    margin: 0 0 40px;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }

  #cta-booking-{{ section.id }} .cta-booking__actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  #cta-booking-{{ section.id }} .cta-booking__btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  #cta-booking-{{ section.id }} .cta-booking__trust-note {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 28px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.45);
  }

  @media (max-width: 640px) {
    #cta-booking-{{ section.id }} .cta-booking__actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>

{% schema %}
{
  "name": "CTA Booking",
  "tag": "section",
  "class": "cta-booking-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Free Consultation"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Not Sure Where to Start?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Book a free 15-minute call with our team. We'll help you choose the right store or service for your goals — no pressure, no commitment."
    },
    {
      "type": "text",
      "id": "primary_cta_text",
      "label": "Primary CTA text",
      "default": "Book a Free Call"
    },
    {
      "type": "url",
      "id": "booking_url",
      "label": "Booking link (Calendly, etc.)"
    },
    {
      "type": "text",
      "id": "secondary_cta_text",
      "label": "Secondary CTA text",
      "default": "Browse Stores"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "text",
      "id": "trust_note",
      "label": "Trust note text",
      "default": "No credit card required. 100% free consultation."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#0A0A0A"
    }
  ],
  "presets": [
    {
      "name": "CTA Booking"
    }
  ]
}
{% endschema %}
