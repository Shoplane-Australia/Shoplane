{% comment %} Shoplane Product Hero Section — Main product page content {% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}

<section class="product-hero section-lg" itemscope itemtype="https://schema.org/Product">
  <meta itemprop="name" content="{{ product.title }}">
  <meta itemprop="description" content="{{ product.description | strip_html | truncate: 200 }}">
  <meta itemprop="url" content="{{ shop.url }}{{ product.url }}">
  {% if product.featured_image %}
    <meta itemprop="image" content="{{ product.featured_image | image_url: width: 1200 }}">
  {% endif %}
  <div itemprop="brand" itemscope itemtype="https://schema.org/Brand">
    <meta itemprop="name" content="{{ product.vendor | default: shop.name }}">
  </div>
  <div itemprop="offers" itemscope itemtype="https://schema.org/AggregateOffer">
    <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
    <meta itemprop="lowPrice" content="{{ product.price_min | money_without_trailing_zeros }}">
    <meta itemprop="highPrice" content="{{ product.price_max | money_without_trailing_zeros }}">
    <meta itemprop="offerCount" content="{{ product.variants.size }}">
    <link itemprop="availability" href="https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}">
  </div>

  <div class="container">
    {%- comment -%} Breadcrumbs {%- endcomment -%}
    <nav class="breadcrumbs animate-on-scroll" aria-label="Breadcrumb">
      <ol class="breadcrumbs__list">
        <li><a href="/">Home</a></li>
        {% if product.collections.size > 0 %}
          <li><a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a></li>
        {% endif %}
        <li aria-current="page">{{ product.title }}</li>
      </ol>
    </nav>

    <div class="product-hero__grid">
      {%- comment -%} Image Gallery {%- endcomment -%}
      <div class="product-hero__gallery animate-on-scroll">
        <div class="product-gallery">
          <div class="product-gallery__main" id="product-main-image">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 900 }}"
                srcset="{{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 900 }} 900w, {{ product.featured_image | image_url: width: 1200 }} 1200w"
                sizes="(max-width: 767px) 100vw, 55vw"
                alt="{{ product.featured_image.alt | escape | default: product.title }}"
                width="{{ product.featured_image.width }}"
                height="{{ product.featured_image.height }}"
                loading="eager"
                class="product-gallery__image"
                id="main-product-img"
              >
            {% else %}
              <div class="product-gallery__placeholder">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
                  <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/>
                  <path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            {% endif %}
          </div>

          {% if product.images.size > 1 %}
            <div class="product-gallery__thumbs" role="listbox" aria-label="Product image thumbnails">
              {% for image in product.images %}
                <button
                  class="product-gallery__thumb{% if forloop.first %} product-gallery__thumb--active{% endif %}"
                  role="option"
                  aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                  aria-label="View image {{ forloop.index }}"
                  data-image-src="{{ image | image_url: width: 900 }}"
                  data-image-srcset="{{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 900 }} 900w, {{ image | image_url: width: 1200 }} 1200w"
                  data-image-alt="{{ image.alt | escape | default: product.title }}"
                >
                  <img
                    src="{{ image | image_url: width: 120 }}"
                    alt=""
                    width="80"
                    height="80"
                    loading="lazy"
                  >
                </button>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>

      {%- comment -%} Product Info {%- endcomment -%}
      <div class="product-hero__info animate-on-scroll">
        <h1 class="product-hero__title">{{ product.title }}</h1>

        <div class="product-hero__price">
          {% if product.price_varies %}
            <span class="price-label">From</span>
          {% endif %}
          <span class="price-current">{{ product.price_min | money }}</span>
          {% if product.compare_at_price_min > product.price_min %}
            <span class="price-compare">{{ product.compare_at_price_min | money }}</span>
          {% endif %}
        </div>

        {% if product.metafields.descriptors.subtitle %}
          <p class="product-hero__excerpt">{{ product.metafields.descriptors.subtitle.value }}</p>
        {% elsif product.description != blank %}
          <p class="product-hero__excerpt">{{ product.description | strip_html | truncate: 160 }}</p>
        {% endif %}

        {%- comment -%} Variant Selector (Card Style) {%- endcomment -%}
        {% if product.variants.size > 1 %}
          <div class="variant-selector" id="variant-selector">
            <p class="variant-selector__label">Choose your package:</p>
            <div class="variant-cards">
              {% for variant in product.variants %}
                <label class="variant-card{% if variant == current_variant %} variant-card--selected{% endif %}{% unless variant.available %} variant-card--unavailable{% endunless %}">
                  <input
                    type="radio"
                    name="id"
                    value="{{ variant.id }}"
                    {% if variant == current_variant %}checked{% endif %}
                    {% unless variant.available %}disabled{% endunless %}
                    class="variant-card__input visually-hidden"
                    data-variant-id="{{ variant.id }}"
                    data-variant-price="{{ variant.price | money }}"
                  >
                  <span class="variant-card__inner">
                    <span class="variant-card__name">{{ variant.title }}</span>
                    <span class="variant-card__price">{{ variant.price | money }}</span>
                    {% unless variant.available %}
                      <span class="variant-card__badge variant-card__badge--sold-out">Sold Out</span>
                    {% endunless %}
                    {% if variant == product.variants.last and variant.available %}
                      <span class="variant-card__badge variant-card__badge--popular">Most Popular</span>
                    {% endif %}
                  </span>
                </label>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {%- comment -%} Add to Cart {%- endcomment -%}
        {% form 'product', product, id: 'product-form' %}
          <input type="hidden" name="id" value="{{ current_variant.id }}" id="product-variant-id">
          <div class="product-hero__actions">
            <button
              type="submit"
              class="btn btn-primary btn-lg btn-block add-to-cart-btn"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {% if current_variant.available %}
                Add to Cart — {{ current_variant.price | money }}
              {% else %}
                Sold Out
              {% endif %}
            </button>
          </div>
        {% endform %}

        {%- comment -%} Trust Badges {%- endcomment -%}
        <div class="trust-badges">
          <div class="trust-badge">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>One-time payment</span>
          </div>
          <div class="trust-badge">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <polyline points="7,10 12,15 17,10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <line x1="12" y1="15" x2="12" y2="3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Digital delivery</span>
          </div>
          <div class="trust-badge">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Full ownership</span>
          </div>
        </div>

        {%- comment -%} Preview Store Link {%- endcomment -%}
        {% if product.metafields.custom.preview_url %}
          <a href="{{ product.metafields.custom.preview_url.value }}" target="_blank" rel="noopener noreferrer" class="preview-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <polyline points="15,3 21,3 21,9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <line x1="10" y1="14" x2="21" y2="3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Preview This Store
          </a>
        {% endif %}

        {%- comment -%} Accordion Sections {%- endcomment -%}
        {% if section.blocks.size > 0 %}
          <div class="product-accordions">
            {% for block in section.blocks %}
              {% if block.type == 'accordion' %}
                <details class="product-accordion" {{ block.shopify_attributes }}>
                  <summary class="product-accordion__trigger">
                    <span>{{ block.settings.heading }}</span>
                    <svg class="accordion-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </summary>
                  <div class="product-accordion__content">
                    {{ block.settings.content }}
                  </div>
                </details>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .product-hero {
    padding: 2rem 0 4rem;
    background: #fff;
  }

  /* Breadcrumbs */
  .breadcrumbs__list {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    font-size: 0.8125rem;
    color: #999;
  }
  .breadcrumbs__list li:not(:last-child)::after {
    content: '›';
    margin-left: 0.5rem;
    color: #ccc;
  }
  .breadcrumbs__list a {
    color: #666;
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumbs__list a:hover {
    color: var(--color-accent, #6C63FF);
  }
  .breadcrumbs__list [aria-current] {
    color: var(--color-text, #333);
    font-weight: 500;
  }

  /* Grid */
  .product-hero__grid {
    display: grid;
    grid-template-columns: 55% 45%;
    gap: 3.5rem;
    align-items: start;
  }

  /* Gallery */
  .product-gallery__main {
    border-radius: 12px;
    overflow: hidden;
    background: #f7f7f8;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .product-gallery__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .product-gallery__placeholder {
    color: #ccc;
  }
  .product-gallery__thumbs {
    display: flex;
    gap: 0.625rem;
    margin-top: 0.875rem;
    overflow-x: auto;
    padding-bottom: 4px;
  }
  .product-gallery__thumb {
    width: 72px;
    height: 72px;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid transparent;
    background: #f7f7f8;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: border-color 0.2s, opacity 0.2s;
    opacity: 0.6;
  }
  .product-gallery__thumb--active {
    border-color: var(--color-accent, #6C63FF);
    opacity: 1;
  }
  .product-gallery__thumb:hover {
    opacity: 1;
  }
  .product-gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Product Info */
  .product-hero__title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-dark, #0A0A0A);
    margin: 0 0 0.75rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .product-hero__price {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .price-label {
    font-size: 0.875rem;
    color: #888;
    font-weight: 500;
  }
  .price-current {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-accent, #6C63FF);
  }
  .price-compare {
    font-size: 1rem;
    color: #bbb;
    text-decoration: line-through;
  }
  .product-hero__excerpt {
    font-size: 1rem;
    color: #666;
    line-height: 1.7;
    margin: 0 0 1.75rem;
  }

  /* Variant Selector Cards */
  .variant-selector {
    margin-bottom: 1.5rem;
  }
  .variant-selector__label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text, #333);
    margin: 0 0 0.75rem;
  }
  .variant-cards {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .variant-card {
    cursor: pointer;
    position: relative;
  }
  .variant-card--unavailable {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .variant-card__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 1.125rem;
    border: 2px solid #e5e5e5;
    border-radius: 10px;
    transition: border-color 0.2s, background 0.2s;
  }
  .variant-card--selected .variant-card__inner {
    border-color: var(--color-accent, #6C63FF);
    background: rgba(108,99,255,0.04);
  }
  .variant-card:hover:not(.variant-card--unavailable) .variant-card__inner {
    border-color: var(--color-accent, #6C63FF);
  }
  .variant-card__name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text, #333);
  }
  .variant-card__price {
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--color-accent, #6C63FF);
  }
  .variant-card__badge {
    position: absolute;
    top: -8px;
    right: 12px;
    font-size: 0.6875rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.02em;
  }
  .variant-card__badge--sold-out {
    background: #f0f0f0;
    color: #999;
  }
  .variant-card__badge--popular {
    background: var(--color-teal, #00D4AA);
    color: #fff;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0,0,0,0);
    border: 0;
  }

  /* Add to Cart */
  .product-hero__actions {
    margin-bottom: 1.5rem;
  }
  .add-to-cart-btn {
    width: 100%;
    font-size: 1.0625rem;
    padding: 1rem;
  }

  /* Trust Badges */
  .trust-badges {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .trust-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: #666;
  }
  .trust-badge svg {
    color: var(--color-teal, #00D4AA);
    flex-shrink: 0;
  }

  /* Preview Link */
  .preview-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-accent, #6C63FF);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    margin-bottom: 2rem;
    transition: opacity 0.2s;
  }
  .preview-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  /* Accordions */
  .product-accordions {
    border-top: 1px solid #eee;
    margin-top: 0.5rem;
  }
  .product-accordion {
    border-bottom: 1px solid #eee;
  }
  .product-accordion__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text, #333);
    cursor: pointer;
    list-style: none;
  }
  .product-accordion__trigger::-webkit-details-marker {
    display: none;
  }
  .product-accordion__trigger::marker {
    display: none;
    content: '';
  }
  .accordion-icon {
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .product-accordion[open] .accordion-icon {
    transform: rotate(180deg);
  }
  .product-accordion__content {
    padding: 0 0 1.25rem;
    font-size: 0.9375rem;
    color: #666;
    line-height: 1.7;
  }

  @media (max-width: 767px) {
    .product-hero__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .product-hero__title {
      font-size: 1.5rem;
    }
    .trust-badges {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>

<script>
  (function() {
    /* Thumbnail click to swap main image */
    var thumbs = document.querySelectorAll('.product-gallery__thumb');
    var mainImg = document.getElementById('main-product-img');
    thumbs.forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        thumbs.forEach(function(t) {
          t.classList.remove('product-gallery__thumb--active');
          t.setAttribute('aria-selected', 'false');
        });
        this.classList.add('product-gallery__thumb--active');
        this.setAttribute('aria-selected', 'true');
        if (mainImg) {
          mainImg.src = this.dataset.imageSrc;
          mainImg.srcset = this.dataset.imageSrcset;
          mainImg.alt = this.dataset.imageAlt;
        }
      });
    });

    /* Variant card selection */
    var variantInputs = document.querySelectorAll('.variant-card__input');
    var hiddenInput = document.getElementById('product-variant-id');
    var addBtn = document.querySelector('.add-to-cart-btn');
    variantInputs.forEach(function(input) {
      input.addEventListener('change', function() {
        document.querySelectorAll('.variant-card').forEach(function(c) {
          c.classList.remove('variant-card--selected');
        });
        this.closest('.variant-card').classList.add('variant-card--selected');
        if (hiddenInput) hiddenInput.value = this.value;
        if (addBtn) {
          addBtn.textContent = 'Add to Cart — ' + this.dataset.variantPrice;
          addBtn.disabled = false;
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Product Hero",
  "tag": "div",
  "class": "product-hero-section",
  "settings": [],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion item",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "What's Included"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Your store comes with a professionally designed theme, winning products, supplier connections, and complete setup — ready to launch.</p>"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "accordion",
        "settings": {
          "heading": "What's Included",
          "content": "<p>Your store includes a premium Shopify theme, pre-loaded winning products with descriptions and images, supplier integrations, payment gateway setup, and essential apps — everything you need to start selling.</p>"
        }
      },
      {
        "type": "accordion",
        "settings": {
          "heading": "Delivery Process",
          "content": "<p>After purchase, you'll receive login credentials to your new Shopify store within 24–48 hours. We'll walk you through a handover process so you're confident running your business.</p>"
        }
      },
      {
        "type": "accordion",
        "settings": {
          "heading": "Frequently Asked Questions",
          "content": "<p><strong>Do I need a Shopify subscription?</strong><br>Yes, you'll need an active Shopify plan (from $39/mo). We build the store, you run it.</p><p><strong>Can I customise the store?</strong><br>Absolutely. You get full ownership and can modify anything — products, design, branding, everything.</p>"
        }
      }
    ]
  },
  "templates": ["product"]
}
{% endschema %}
