<section
  id="services-trust-{{ section.id }}"
  class="services-trust-strip"
  data-section-id="{{ section.id }}"
>
  <div class="container">
    <div class="services-trust-strip__inner animate-on-scroll stagger-1">
      {%- if section.settings.heading != blank -%}
        <p class="services-trust-strip__heading">{{ section.settings.heading }}</p>
      {%- endif -%}
      {%- if section.blocks.size > 0 -%}
        <ul class="services-trust-strip__stats" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'stat' -%}
              <li {{ block.shopify_attributes }}>
                <span class="services-trust-strip__stat-value">{{ block.settings.value }}</span>
                <span class="services-trust-strip__stat-label">{{ block.settings.label }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #services-trust-{{ section.id }} {
    background: var(--color-surface, #F0EEE9);
    border-block: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }

  #services-trust-{{ section.id }} .services-trust-strip__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem 2rem;
  }

  #services-trust-{{ section.id }} .services-trust-strip__heading {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    margin: 0;
  }

  #services-trust-{{ section.id }} .services-trust-strip__stats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2.5rem;
  }

  #services-trust-{{ section.id }} .services-trust-strip__stat-value {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  #services-trust-{{ section.id }} .services-trust-strip__stat-label {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    margin-top: 0.15rem;
  }
</style>

{% schema %}
{
  "name": "Services Trust Strip",
  "tag": "section",
  "class": "services-trust-strip-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by Australian entrepreneurs"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#F0EEE9"
    },
    {
      "type": "text",
      "id": "stats_line",
      "label": "Stats line (unused)"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "50+" },
        { "type": "text", "id": "label", "label": "Label", "default": "stores delivered" }
      ]
    }
  ],
  "presets": [{ "name": "Services Trust Strip" }]
}
{% endschema %}
