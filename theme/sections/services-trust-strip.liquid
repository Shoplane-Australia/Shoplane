{%- comment -%}
  Early credibility strip — sits directly under the services hero.
{%- endcomment -%}

<section
  id="services-trust-{{ section.id }}"
  class="services-trust-strip"
  data-section-id="{{ section.id }}"
  data-section-type="services-trust-strip"
>
  <div class="container">
    <div class="services-trust-strip__inner{% unless request.design_mode %} animate-on-scroll stagger-1{% endunless %}">
      {%- if section.settings.heading != blank -%}
        <p class="services-trust-strip__heading">{{ section.settings.heading }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="services-trust-strip__stats" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'stat' -%}
              <li {{ block.shopify_attributes }}>
                {%- if block.settings.value != blank -%}
                  <span class="services-trust-strip__stat-value">{{ block.settings.value }}</span>
                {%- endif -%}
                {%- if block.settings.label != blank -%}
                  <span class="services-trust-strip__stat-label">{{ block.settings.label }}</span>
                {%- endif -%}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- elsif section.settings.stats_line != blank -%}
        <p class="services-trust-strip__line">{{ section.settings.stats_line }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #services-trust-{{ section.id }} {
    position: relative;
    z-index: 2;
    background: {{ section.settings.background_color }};
    padding: 0 0 40px;
    margin-top: -8px;
  }

  #services-trust-{{ section.id }} .services-trust-strip__inner {
    text-align: center;
    padding: 20px 28px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
  }

  #services-trust-{{ section.id }} .services-trust-strip__heading {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.92);
    margin: 0 0 10px;
    letter-spacing: -0.01em;
  }

  #services-trust-{{ section.id }} .services-trust-strip__line {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
    letter-spacing: 0.01em;
  }

  #services-trust-{{ section.id }} .services-trust-strip__stats {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 8px 0;
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.55);
  }

  #services-trust-{{ section.id }} .services-trust-strip__stats li {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  #services-trust-{{ section.id }} .services-trust-strip__stats li:not(:last-child)::after {
    content: '•';
    margin: 0 14px;
    color: rgba(255, 255, 255, 0.28);
    font-weight: 400;
  }

  #services-trust-{{ section.id }} .services-trust-strip__stat-value {
    color: rgba(255, 255, 255, 0.85);
    font-weight: 600;
  }

  #services-trust-{{ section.id }} .services-trust-strip__stat-label {
    color: rgba(255, 255, 255, 0.55);
  }

  @media (max-width: 640px) {
    #services-trust-{{ section.id }} .services-trust-strip__stats {
      flex-direction: column;
      gap: 6px;
    }

    #services-trust-{{ section.id }} .services-trust-strip__stats li:not(:last-child)::after {
      display: none;
    }
  }

  {% if request.design_mode %}
    #services-trust-{{ section.id }} .animate-on-scroll {
      opacity: 1;
      transform: none;
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "Services trust strip",
  "tag": "section",
  "class": "services-trust-strip-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by Australian entrepreneurs"
    },
    {
      "type": "text",
      "id": "stats_line",
      "label": "Stats line (fallback if no blocks)",
      "default": "50+ stores delivered • 9 niches covered • 24h response"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#12121a"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "50+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "stores delivered"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Services trust strip",
      "blocks": [
        { "type": "stat", "settings": { "value": "50+", "label": "stores delivered" } },
        { "type": "stat", "settings": { "value": "9", "label": "niches covered" } },
        { "type": "stat", "settings": { "value": "24h", "label": "response" } }
      ]
    }
  ]
}
{% endschema %}
