{% comment %} About Content — Editorial light {% endcomment %}

<section class="about-section">
  <div class="container">
    <div class="about-intro animate-on-scroll">
      <div class="about-intro__content">
        <h2 class="about-intro__title">{{ section.settings.heading }}</h2>
        <div class="about-intro__text">
          {{ section.settings.content }}
        </div>
      </div>
      {% if section.settings.image != blank %}
        <div class="about-intro__image">
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            srcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 800 }} 800w"
            sizes="(max-width: 767px) 100vw, 40vw"
            alt="{% render 'auto-alt', title: section.settings.heading, image: section.settings.image %}"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            class="about-intro__img"
          >
        </div>
      {% endif %}
    </div>

    {% assign value_blocks = section.blocks | where: 'type', 'value' %}
    {% if value_blocks.size > 0 %}
      <div class="about-values animate-on-scroll">
        <h3 class="about-values__heading">{{ section.settings.values_heading }}</h3>
        <ol class="about-values__list">
          {% for block in value_blocks %}
            <li class="about-values__item" {{ block.shopify_attributes }}>
              <span class="about-values__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
              <div>
                <h4 class="about-values__title">{{ block.settings.title }}</h4>
                <p class="about-values__text">{{ block.settings.description }}</p>
              </div>
            </li>
          {% endfor %}
        </ol>
      </div>
    {% endif %}

    {% if section.settings.show_partner_callout %}
      <div class="partner-callout animate-on-scroll">
        <span class="partner-callout__label">Official Shopify Partner</span>
        <p class="partner-callout__text">We're a certified Shopify Partner, trusted by merchants across Australia. Our stores are built to Shopify's quality standards with best practices baked in.</p>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .about-section {
    background: var(--color-background, #FAFAF8);
    padding: 0 0 var(--space-20);
  }

  .about-intro {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--space-12);
    align-items: start;
    margin-bottom: var(--space-16);
  }

  .about-intro__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 1.25rem;
    letter-spacing: -0.03em;
  }

  .about-intro__text {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
  }

  .about-intro__text p {
    margin: 0 0 1rem;
  }

  .about-intro__img {
    width: 100%;
    display: block;
    border: 1px solid var(--color-border);
  }

  .about-values {
    margin-bottom: var(--space-16);
  }

  .about-values__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-8);
    letter-spacing: -0.03em;
  }

  .about-values__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }

  .about-values__item {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: var(--space-5);
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .about-values__num {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-tertiary);
  }

  .about-values__title {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.35rem;
  }

  .about-values__text {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin: 0;
    max-width: 48ch;
  }

  .partner-callout {
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .partner-callout__label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .partner-callout__text {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    max-width: 52ch;
  }

  @media (max-width: 767px) {
    .about-intro {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>

{% schema %}
{
  "name": "About Content",
  "tag": "div",
  "class": "about-content-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "About Shoplane"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Shoplane was founded with a clear mission: make launching an online business simple, structured, and accessible for every Australian entrepreneur.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "About image"
    },
    {
      "type": "text",
      "id": "values_heading",
      "label": "Values heading",
      "default": "What we stand for"
    },
    {
      "type": "checkbox",
      "id": "show_partner_callout",
      "label": "Show Shopify Partner callout",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA heading (unused — use CTA Booking section)",
      "default": "Ready to Launch Your Store?"
    },
    {
      "type": "text",
      "id": "cta_subtext",
      "label": "CTA subtext",
      "default": "Browse our stores or book a free consultation."
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Primary button text",
      "default": "Browse Stores"
    },
    {
      "type": "url",
      "id": "cta_primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary button text",
      "default": "Book a Call"
    },
    {
      "type": "url",
      "id": "cta_secondary_link",
      "label": "Secondary button link"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon (unused)",
          "options": [
            { "value": "quality", "label": "Quality" },
            { "value": "speed", "label": "Speed" },
            { "value": "support", "label": "Support" },
            { "value": "trust", "label": "Trust" },
            { "value": "store", "label": "Store" },
            { "value": "shield", "label": "Shield" },
            { "value": "zap", "label": "Zap" }
          ],
          "default": "quality"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Value"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "A brief description of this core value."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Content",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "title": "Built for growth",
            "description": "We don't just launch stores — we build structured ecommerce businesses designed to scale."
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Transparency first",
            "description": "One-time payments, clear scope, honest communication. No hidden fees, no subscriptions."
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Australian focus",
            "description": "AUD pricing, GST-ready, local suppliers, and support tailored to the Australian market."
          }
        }
      ]
    }
  ]
}
{% endschema %}
