{% comment %} Shoplane Collection Grid — Editorial light {% endcomment %}

{%- liquid
  assign grid_collection = section.settings.collection
  if grid_collection == blank
    assign grid_collection = collection
  endif
  assign use_page_sort = false
  if section.settings.collection == blank and collection != blank
    assign use_page_sort = true
  endif
-%}

<section id="stores-grid" class="collection-grid section-lg">
  <div class="container">
    {%- if grid_collection == blank -%}
      <div class="collection-empty animate-on-scroll">
        <div class="collection-empty__inner">
          <h2 class="collection-empty__title">Select a collection</h2>
          <p class="collection-empty__text">Choose a collection in this section’s settings to show stores here.</p>
        </div>
      </div>
    {%- else -%}
      <div class="collection-toolbar animate-on-scroll">
        <div class="collection-toolbar__info">
          <p class="collection-toolbar__count">
            {{ grid_collection.products_count }} {{ grid_collection.products_count | pluralize: 'store', 'stores' }}
          </p>
        </div>
        {%- if use_page_sort -%}
          <div class="collection-toolbar__sort">
            <label for="sort-by-{{ section.id }}" class="sort-label">Sort by</label>
            <select id="sort-by-{{ section.id }}" class="sort-select" aria-label="Sort products">
              <option value="manual" {% if collection.sort_by == 'manual' %}selected{% endif %}>Featured</option>
              <option value="price-ascending" {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>Price: Low to High</option>
              <option value="price-descending" {% if collection.sort_by == 'price-descending' %}selected{% endif %}>Price: High to Low</option>
              <option value="title-ascending" {% if collection.sort_by == 'title-ascending' %}selected{% endif %}>A — Z</option>
              <option value="title-descending" {% if collection.sort_by == 'title-descending' %}selected{% endif %}>Z — A</option>
              <option value="created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>Newest</option>
              <option value="best-selling" {% if collection.sort_by == 'best-selling' %}selected{% endif %}>Best Selling</option>
            </select>
          </div>
        {%- endif -%}
      </div>

      {%- paginate grid_collection.products by section.settings.products_per_page -%}
        {% if grid_collection.products.size > 0 %}
          <div class="product-grid animate-on-scroll">
            {% for product in grid_collection.products %}
              {% render 'product-card', product: product, layout: 'row' %}
            {% endfor %}
          </div>
        {% else %}
          <div class="collection-empty animate-on-scroll">
            <div class="collection-empty__inner">
              <h2 class="collection-empty__title">No stores found</h2>
              <p class="collection-empty__text">This collection has no products yet. Add products to “{{ grid_collection.title }}” or pick another collection.</p>
              <a href="{{ routes.collections_url }}" class="btn btn-primary">Browse All Stores</a>
            </div>
          </div>
        {% endif %}

        {% if paginate.pages > 1 %}
          <nav class="pagination animate-on-scroll" aria-label="Collection pagination">
            <ul class="pagination__list">
              {% if paginate.previous %}
                <li>
                  <a href="{{ paginate.previous.url }}" class="pagination__link pagination__link--prev" aria-label="Previous page">
                    Previous
                  </a>
                </li>
              {% endif %}

              {% for part in paginate.parts %}
                <li>
                  {% if part.is_link %}
                    <a href="{{ part.url }}" class="pagination__link" aria-label="Page {{ part.title }}">{{ part.title }}</a>
                  {% elsif part.title == paginate.current_page %}
                    <span class="pagination__link pagination__link--current" aria-current="page">{{ part.title }}</span>
                  {% else %}
                    <span class="pagination__ellipsis">{{ part.title }}</span>
                  {% endif %}
                </li>
              {% endfor %}

              {% if paginate.next %}
                <li>
                  <a href="{{ paginate.next.url }}" class="pagination__link pagination__link--next" aria-label="Next page">
                    Next
                  </a>
                </li>
              {% endif %}
            </ul>
          </nav>
        {% endif %}
      {%- endpaginate -%}
    {%- endif -%}
  </div>
</section>

<style>
  .collection-grid {
    background: var(--color-background, #FAFAF8);
    padding: 0 0 var(--space-20);
  }

  .collection-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .collection-toolbar__count {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .collection-toolbar__sort {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .sort-label {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    font-weight: 500;
    white-space: nowrap;
  }

  .sort-select {
    padding: 0.5rem 2rem 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    color: var(--color-text);
    background: var(--color-background) url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%237A7872' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E") no-repeat right 0.75rem center;
    appearance: none;
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.2s;
  }

  .sort-select:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .product-grid {
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 5vw, 4rem);
  }

  .collection-empty__inner {
    text-align: left;
    padding: 4rem 0;
  }

  .collection-empty__title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }

  .collection-empty__text {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 400px;
    margin: 0 0 1.5rem;
    line-height: 1.6;
  }

  .pagination {
    margin-top: 3rem;
    display: flex;
    justify-content: flex-start;
  }

  .pagination__list {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pagination__link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: background 0.2s, color 0.2s;
  }

  .pagination__link:hover {
    background: var(--color-surface);
    color: var(--color-accent);
  }

  .pagination__link--current {
    background: var(--color-accent);
    color: var(--color-text-inverse);
  }

  .pagination__link--current:hover {
    background: var(--color-accent-hover);
    color: var(--color-text-inverse);
  }

  .pagination__ellipsis {
    padding: 0.5rem 0.25rem;
    color: var(--color-text-tertiary);
    font-size: 0.875rem;
  }

  /* One store per row — image left, content + button right */
  .product-card {
    background: transparent;
    border: none;
    padding: 0;
  }

  .product-card--row .product-card__link {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    text-decoration: none;
    color: inherit;
  }

  .product-card--row .product-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: transparent;
    margin: 0;
  }

  .product-card--row .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.7s var(--ease-out, ease);
  }

  .product-card--row .product-card__link:hover .product-card__image {
    transform: scale(1.03);
  }

  .product-card--row .product-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: var(--color-text-tertiary);
    font-family: var(--font-heading);
    font-size: 0.95rem;
    padding: 1rem;
    text-align: center;
  }

  .product-card--row .product-card__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.65rem;
    min-width: 0;
  }

  .product-card--row .product-card__type {
    font-family: var(--font-mono, var(--font-body));
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }

  .product-card--row .product-card__title {
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.4vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0;
    line-height: 1.2;
  }

  .product-card--row .product-card__excerpt {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin: 0;
    max-width: 36ch;
  }

  .product-card--row .product-card__footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem 1.25rem;
    width: 100%;
    margin-top: 0.75rem;
    padding-top: 0;
  }

  .product-card--row .product-card__price {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
  }

  .product-card--row .product-card__price-label {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .product-card--row .product-card__price-value {
    font-family: var(--font-mono, var(--font-heading));
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .product-card--row .product-card__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.35rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--color-text-inverse, #FAFAF8);
    background: var(--color-accent, #1B4D3E);
    border: none;
    white-space: nowrap;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .product-card--row .product-card__link:hover .product-card__btn {
    background: var(--color-accent-hover, #163d32);
  }

  @media (max-width: 768px) {
    .product-card--row .product-card__link {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .product-card--row .product-card__media {
      aspect-ratio: 16 / 11;
    }

    .product-card--row .product-card__footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  (function() {
    var sortSelect = document.getElementById('sort-by-{{ section.id }}');
    if (sortSelect) {
      sortSelect.addEventListener('change', function() {
        var url = new URL(window.location.href);
        url.searchParams.set('sort_by', this.value);
        url.searchParams.delete('page');
        window.location.href = url.toString();
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Collection Grid",
  "tag": "div",
  "class": "collection-grid-section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Pick which collection to show. Leave empty to use the collection of the current page (when this template is assigned to a collection)."
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 6,
      "max": 24,
      "step": 3,
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Collection Grid"
    }
  ]
}
{% endschema %}
