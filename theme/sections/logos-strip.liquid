<section
  id="logos-strip-{{ section.id }}"
  class="logos-strip"
  data-section-id="{{ section.id }}"
  data-section-type="logos-strip"
>
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <p class="logos-strip__heading animate-on-scroll stagger-1">{{ section.settings.heading }}</p>
    {%- endif -%}
  </div>

  <div class="logos-strip__track-wrapper animate-on-scroll stagger-2">
    <div class="logos-strip__track" data-auto-scroll="{{ section.settings.auto_scroll }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'logo' -%}
          <div class="logos-strip__item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 160 }}"
                alt="{{ block.settings.name | escape }}"
                loading="lazy"
                width="120"
                height="40"
              >
            {%- else -%}
              <span class="logos-strip__item-text">{{ block.settings.name }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #logos-strip-{{ section.id }} {
    background: var(--color-surface);
    padding: var(--space-xl) 0;
    overflow: hidden;
  }

  #logos-strip-{{ section.id }} .logos-strip__heading {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    text-align: center;
    margin: 0 0 var(--space-lg);
  }

  #logos-strip-{{ section.id }} .logos-strip__track-wrapper {
    position: relative;
    width: 100%;
  }

  #logos-strip-{{ section.id }} .logos-strip__track {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2xl);
    flex-wrap: wrap;
    padding: 0 var(--space-lg);
  }

  #logos-strip-{{ section.id }} .logos-strip__item {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  #logos-strip-{{ section.id }} .logos-strip__item img {
    max-width: 120px;
    max-height: 36px;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.5;
    transition: filter 0.3s ease, opacity 0.3s ease;
  }

  #logos-strip-{{ section.id }} .logos-strip__item:hover img {
    filter: grayscale(0%);
    opacity: 1;
  }

  #logos-strip-{{ section.id }} .logos-strip__item-text {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-secondary);
    opacity: 0.5;
    transition: opacity 0.3s ease;
    white-space: nowrap;
  }

  #logos-strip-{{ section.id }} .logos-strip__item:hover .logos-strip__item-text {
    opacity: 1;
  }

  @keyframes logos-strip-marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  #logos-strip-{{ section.id }} .logos-strip__track[data-auto-scroll="true"] {
    justify-content: flex-start;
    flex-wrap: nowrap;
    overflow: hidden;
    animation: logos-strip-marquee 30s linear infinite;
    width: max-content;
  }

  #logos-strip-{{ section.id }} .logos-strip__track[data-auto-scroll="true"]:hover {
    animation-play-state: paused;
  }
</style>

<script>
  (function() {
    var section = document.getElementById('logos-strip-{{ section.id }}');
    if (!section) return;
    var track = section.querySelector('.logos-strip__track');
    if (!track || track.getAttribute('data-auto-scroll') !== 'true') return;
    var items = track.innerHTML;
    track.innerHTML = items + items;
  })();
</script>

{% schema %}
{
  "name": "Logos Strip",
  "tag": "section",
  "class": "logos-strip-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "Trusted integrations & partners"
    },
    {
      "type": "checkbox",
      "id": "auto_scroll",
      "label": "Enable marquee auto-scroll",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 16,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Partner name",
          "default": "Partner"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logos Strip",
      "blocks": [
        { "type": "logo", "settings": { "name": "Shopify" } },
        { "type": "logo", "settings": { "name": "Klaviyo" } },
        { "type": "logo", "settings": { "name": "LOOX" } },
        { "type": "logo", "settings": { "name": "Judge.me" } },
        { "type": "logo", "settings": { "name": "Afterpay" } },
        { "type": "logo", "settings": { "name": "Stripe" } },
        { "type": "logo", "settings": { "name": "Zip" } },
        { "type": "logo", "settings": { "name": "PayPal" } }
      ]
    }
  ]
}
{% endschema %}
