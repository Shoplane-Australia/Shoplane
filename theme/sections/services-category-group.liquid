{%- comment -%}
  Service category row — premium layout for the services landing page.
{%- endcomment -%}

{%- liquid
  assign category_collection = section.settings.collection
  if category_collection != blank and category_collection.products == blank
    assign category_collection = collections[section.settings.collection]
  endif
  assign anchor_id = section.settings.anchor_id
  if anchor_id == blank and section.settings.number != blank
    assign anchor_id = 'category-' | append: section.settings.number
  endif
  assign style_mod = section.settings.style | default: 'light'
-%}

<section
  id="{{ anchor_id }}"
  class="services-category-group services-category-group--{{ style_mod }}"
  data-section-id="{{ section.id }}"
  data-section-type="services-category-group"
>
  {%- if style_mod == 'warm' -%}
    <div class="services-category-group__bg" aria-hidden="true"></div>
  {%- endif -%}

  <div class="container services-category-group__container">
    <header class="services-category-group__header{% unless request.design_mode %} animate-on-scroll stagger-1{% endunless %}">
      <div class="services-category-group__intro">
        {%- if section.settings.number != blank -%}
          <span class="services-category-group__number">{{ section.settings.number }}</span>
        {%- endif -%}
        <div class="services-category-group__intro-text">
          <h2 class="services-category-group__title">
            {%- if section.settings.title != blank -%}
              {{ section.settings.title }}
            {%- elsif category_collection != blank -%}
              {{ category_collection.title }}
            {%- endif -%}
          </h2>
          {%- if section.settings.description != blank -%}
            <p class="services-category-group__desc">{{ section.settings.description }}</p>
          {%- elsif category_collection.description != blank -%}
            <p class="services-category-group__desc">{{ category_collection.description | strip_html | truncate: 160 }}</p>
          {%- endif -%}
        </div>
      </div>
      {%- if category_collection != blank and category_collection.products_count > 0 -%}
        <span class="services-category-group__count">
          {{ category_collection.products_count }}
          {%- if category_collection.products_count == 1 -%}service{%- else -%}services{%- endif -%}
        </span>
      {%- endif -%}
    </header>

    <div class="services-category-group__grid{% unless request.design_mode %} animate-on-scroll stagger-2{% endunless %}">
      {%- if category_collection != blank and category_collection.products_count > 0 -%}
        {%- for product in category_collection.products limit: section.settings.products_limit -%}
          {% render 'service-card', product: product %}
        {%- endfor -%}
      {%- elsif request.design_mode -%}
        {%- for i in (1..3) -%}
          <article class="service-card service-card--placeholder">
            <div class="service-card__media">
              <div class="service-card__media-placeholder">
                <span class="service-card__media-title">Service {{ i }}</span>
              </div>
              <span class="service-card__badge">Worldwide</span>
            </div>
            <div class="service-card__body">
              <h3 class="service-card__title">Assign a collection</h3>
              <p class="service-card__excerpt">Choose a collection in this section to populate service cards.</p>
              <div class="service-card__footer">
                <span class="service-card__price">$99</span>
                <span class="service-card__btn">Get started</span>
              </div>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .services-category-group {
    position: relative;
    padding: var(--space-16) 0;
    scroll-margin-top: calc(var(--header-height, 80px) + 56px);
  }

  #shopify-section-{{ section.id }} .services-category-group--light,
  #shopify-section-{{ section.id }} .services-category-group--cream,
  #shopify-section-{{ section.id }} .services-category-group--warm {
    background: var(--color-background, #FAFAF8);
  }

  #shopify-section-{{ section.id }} .services-category-group--cream {
    background: var(--color-surface, #F0EEE9);
  }

  #shopify-section-{{ section.id }} .services-category-group__bg {
    display: none;
  }

  #shopify-section-{{ section.id }} .services-category-group__container {
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .services-category-group__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 40px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--color-border);
  }

  #shopify-section-{{ section.id }} .services-category-group__intro {
    display: flex;
    align-items: flex-start;
    gap: 20px;
  }

  #shopify-section-{{ section.id }} .services-category-group__number {
    flex-shrink: 0;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-tertiary);
    background: none;
    box-shadow: none;
    width: auto;
    height: auto;
    border-radius: 0;
    padding-top: 0.35rem;
  }

  #shopify-section-{{ section.id }} .services-category-group__title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0 0 8px;
    line-height: 1.15;
  }

  #shopify-section-{{ section.id }} .services-category-group__desc {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 52ch;
  }

  #shopify-section-{{ section.id }} .services-category-group__count {
    flex-shrink: 0;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    background: none;
    padding: 0;
    border-radius: 0;
  }

  #shopify-section-{{ section.id }} .services-category-group__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-10) var(--space-8);
  }

  @media (max-width: 640px) {
    #shopify-section-{{ section.id }} .services-category-group__header {
      flex-direction: column;
      align-items: flex-start;
    }

    #shopify-section-{{ section.id }} .services-category-group__grid {
      grid-template-columns: 1fr;
    }
  }

  {% if request.design_mode %}
    #shopify-section-{{ section.id }} .animate-on-scroll {
      opacity: 1;
      transform: none;
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "Services category group",
  "tag": "section",
  "class": "services-category-group-section",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "category-01",
      "info": "Used for jump nav links, e.g. category-01"
    },
    {
      "type": "text",
      "id": "number",
      "label": "Category number",
      "default": "01"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Category title"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Category description"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Services collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Services shown",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 12
    },
    {
      "type": "select",
      "id": "style",
      "label": "Background style",
      "options": [
        { "value": "light", "label": "White" },
        { "value": "cream", "label": "Cream" },
        { "value": "warm", "label": "Warm gradient" }
      ],
      "default": "light"
    }
  ],
  "presets": [
    {
      "name": "Services category group",
      "settings": {
        "number": "01",
        "title": "Store setup & launch",
        "description": "Everything you need to launch your store the right way.",
        "anchor_id": "category-01"
      }
    }
  ]
}
{% endschema %}
