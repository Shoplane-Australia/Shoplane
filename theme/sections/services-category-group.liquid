{%- comment -%}
  One service category row — left intro + right card grid.
  Used on the main services landing page (one section instance per category).
{%- endcomment -%}

{%- liquid
  assign category_collection = section.settings.collection
  if category_collection != blank and category_collection.products == blank
    assign category_collection = collections[section.settings.collection]
  endif
-%}

<section
  id="services-category-{{ section.id }}"
  class="services-category-group"
  data-section-id="{{ section.id }}"
  data-section-type="services-category-group"
>
  <div class="container">
    <div class="services-category-group__layout">
      <aside class="services-category-group__intro{% unless request.design_mode %} animate-on-scroll stagger-1{% endunless %}">
        {%- if section.settings.number != blank -%}
          <span class="services-category-group__number">{{ section.settings.number }}</span>
        {%- endif -%}
        <h2 class="services-category-group__title">
          {%- assign category_url = section.settings.category_url | default: category_collection.url -%}
          {%- if category_url != blank -%}
            <a href="{{ category_url }}" class="services-category-group__title-link">
          {%- endif -%}
          {%- if section.settings.title != blank -%}
            {{ section.settings.title }}
          {%- elsif category_collection != blank -%}
            {{ category_collection.title }}
          {%- endif -%}
          {%- if category_url != blank -%}
            </a>
          {%- endif -%}
        </h2>
        {%- if section.settings.description != blank -%}
          <p class="services-category-group__desc">{{ section.settings.description }}</p>
        {%- elsif category_collection.description != blank -%}
          <p class="services-category-group__desc">{{ category_collection.description | strip_html | truncate: 160 }}</p>
        {%- endif -%}
        {%- assign category_url = section.settings.category_url | default: category_collection.url -%}
        {%- if category_url != blank -%}
          <a href="{{ category_url }}" class="services-category-group__view-all">
            View all services
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}
      </aside>

      <div class="services-category-group__grid{% unless request.design_mode %} animate-on-scroll stagger-2{% endunless %}">
        {%- if category_collection != blank and category_collection.products_count > 0 -%}
          {%- for product in category_collection.products limit: section.settings.products_limit -%}
            {% render 'service-card', product: product %}
          {%- endfor -%}
        {%- elsif request.design_mode -%}
          {%- for i in (1..4) -%}
            <article class="service-card service-card--placeholder">
              <div class="service-card__media">
                <div class="service-card__media-placeholder">
                  <span class="service-card__media-title">Service {{ i }}</span>
                </div>
                <span class="service-card__badge">Worldwide</span>
              </div>
              <div class="service-card__body">
                <h3 class="service-card__title">Assign a collection</h3>
                <p class="service-card__excerpt">Choose a collection in this section to populate service cards automatically.</p>
              </div>
            </article>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  #services-category-{{ section.id }} {
    background: {{ section.settings.background_color }};
    padding: 72px 0;
    border-top: 1px solid rgba(15, 42, 28, 0.06);
  }

  #services-category-{{ section.id }} .services-category-group__layout {
    display: grid;
    grid-template-columns: minmax(220px, 280px) 1fr;
    gap: 48px;
    align-items: start;
  }

  #services-category-{{ section.id }} .services-category-group__number {
    display: block;
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: #1b4332;
    margin-bottom: 12px;
  }

  #services-category-{{ section.id }} .services-category-group__title {
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #1b4332;
    margin: 0 0 12px;
    line-height: 1.2;
  }

  #services-category-{{ section.id }} .services-category-group__title-link {
    color: inherit;
    text-decoration: none;
  }

  #services-category-{{ section.id }} .services-category-group__title-link:hover {
    color: var(--color-accent);
  }

  #services-category-{{ section.id }} .services-category-group__desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #2d6a4f;
    margin: 0 0 20px;
  }

  #services-category-{{ section.id }} .services-category-group__view-all {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }

  #services-category-{{ section.id }} .services-category-group__view-all:hover {
    text-decoration: underline;
  }

  #services-category-{{ section.id }} .services-category-group__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  @media (max-width: 991px) {
    #services-category-{{ section.id }} .services-category-group__layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 640px) {
    #services-category-{{ section.id }} .services-category-group__grid {
      grid-template-columns: 1fr;
    }
  }

  {% if request.design_mode %}
    #services-category-{{ section.id }} .animate-on-scroll {
      opacity: 1;
      transform: none;
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "Services category group",
  "tag": "section",
  "class": "services-category-group-section",
  "settings": [
    {
      "type": "text",
      "id": "number",
      "label": "Category number",
      "default": "01"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Category title",
      "info": "Defaults to collection title if empty"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Category description"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Services collection",
      "info": "Products in this collection appear as service cards"
    },
    {
      "type": "url",
      "id": "category_url",
      "label": "Category landing page URL",
      "info": "Defaults to collection URL. Link to the full category page."
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Services shown on landing page",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#f9f8f3"
    }
  ],
  "presets": [
    {
      "name": "Services category group",
      "settings": {
        "number": "01",
        "title": "Store setup & launch",
        "description": "Everything you need to launch your store the right way."
      }
    }
  ]
}
{% endschema %}
