<section
  id="social-proof-{{ section.id }}"
  class="social-proof section-lg"
  data-section-id="{{ section.id }}"
  data-section-type="social-proof"
>
  <div class="container">
    {%- if section.settings.stat_1_value != blank or section.settings.stat_2_value != blank -%}
      <div class="social-proof__stats{% unless request.design_mode %} animate-on-scroll stagger-1{% endunless %}">
        {%- if section.settings.stat_1_value != blank -%}
          <div class="social-proof__stat-item">
            <span class="social-proof__stat-value">{{ section.settings.stat_1_value }}</span>
            <span class="social-proof__stat-label">{{ section.settings.stat_1_label }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_2_value != blank -%}
          <div class="social-proof__stat-item">
            <span class="social-proof__stat-value">{{ section.settings.stat_2_value }}</span>
            <span class="social-proof__stat-label">{{ section.settings.stat_2_label }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_3_value != blank -%}
          <div class="social-proof__stat-item">
            <span class="social-proof__stat-value">{{ section.settings.stat_3_value }}</span>
            <span class="social-proof__stat-label">{{ section.settings.stat_3_label }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_4_value != blank -%}
          <div class="social-proof__stat-item">
            <span class="social-proof__stat-value">{{ section.settings.stat_4_value }}</span>
            <span class="social-proof__stat-label">{{ section.settings.stat_4_label }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <header class="social-proof__header{% unless request.design_mode %} animate-on-scroll stagger-2{% endunless %}">
      {%- if section.settings.eyebrow != blank -%}
        <span class="social-proof__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="social-proof__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="social-proof__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="social-proof__testimonials">
        {%- for block in section.blocks -%}
          {%- if block.type == 'testimonial' -%}
          <blockquote
            class="social-proof__quote{% unless request.design_mode %} animate-on-scroll stagger-{{ forloop.index | plus: 2 }}{% endunless %}"
            {{ block.shopify_attributes }}
          >
            <p>{{ block.settings.quote }}</p>
            <footer>
              <cite class="social-proof__author-name">{{ block.settings.name }}</cite>
              {%- if block.settings.business_type != blank -%}
                <span class="social-proof__author-role">{{ block.settings.business_type }}</span>
              {%- endif -%}
            </footer>
          </blockquote>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #social-proof-{{ section.id }} {
    background: var(--color-background, #FAFAF8);
    padding: var(--space-20) 0;
    color: var(--color-text);
  }

  #social-proof-{{ section.id }} .social-proof__stats {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
    margin-bottom: var(--space-16);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--color-border);
  }

  #social-proof-{{ section.id }} .social-proof__stat-value {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    line-height: 1.1;
  }

  #social-proof-{{ section.id }} .social-proof__stat-label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    margin-top: 0.35rem;
  }

  #social-proof-{{ section.id }} .social-proof__header {
    text-align: left;
    max-width: 560px;
    margin: 0 0 var(--space-12);
  }

  #social-proof-{{ section.id }} .social-proof__eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  #social-proof-{{ section.id }} .social-proof__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 0.75rem;
  }

  #social-proof-{{ section.id }} .social-proof__subheading {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  #social-proof-{{ section.id }} .social-proof__testimonials {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-10);
  }

  #social-proof-{{ section.id }} .social-proof__quote {
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
  }

  #social-proof-{{ section.id }} .social-proof__quote p {
    font-family: var(--font-heading);
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    font-weight: 500;
    line-height: 1.45;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin: 0 0 1.25rem;
    font-style: normal;
  }

  #social-proof-{{ section.id }} .social-proof__quote footer {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  #social-proof-{{ section.id }} .social-proof__author-name {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    font-style: normal;
    color: var(--color-text);
  }

  #social-proof-{{ section.id }} .social-proof__author-role {
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
  }

  @media (max-width: 991px) {
    #social-proof-{{ section.id }} .social-proof__testimonials {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  {% if request.design_mode %}
    #social-proof-{{ section.id }} .animate-on-scroll {
      opacity: 1;
      transform: none;
    }
  {% endif %}
</style>

