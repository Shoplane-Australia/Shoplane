<section
  id="social-proof-{{ section.id }}"
  class="social-proof section-dark section-lg"
  data-section-id="{{ section.id }}"
  data-section-type="social-proof"
>
  <div class="container">
    {%- comment -%} Stats counters {%- endcomment -%}
    <div class="social-proof__stats{% unless request.design_mode %} animate-on-scroll stagger-1{% endunless %}">
      {%- if section.settings.stat_1_value != blank -%}
        <div class="social-proof__stat-item">
          <span class="social-proof__stat-value" data-target="{{ section.settings.stat_1_value }}">
            {{ section.settings.stat_1_value }}
          </span>
          <span class="social-proof__stat-label">{{ section.settings.stat_1_label }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_2_value != blank -%}
        <div class="social-proof__stat-item">
          <span class="social-proof__stat-value" data-target="{{ section.settings.stat_2_value }}">
            {{ section.settings.stat_2_value }}
          </span>
          <span class="social-proof__stat-label">{{ section.settings.stat_2_label }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_3_value != blank -%}
        <div class="social-proof__stat-item">
          <span class="social-proof__stat-value" data-target="{{ section.settings.stat_3_value }}">
            {{ section.settings.stat_3_value }}
          </span>
          <span class="social-proof__stat-label">{{ section.settings.stat_3_label }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_4_value != blank -%}
        <div class="social-proof__stat-item">
          <span class="social-proof__stat-value" data-target="{{ section.settings.stat_4_value }}">
            {{ section.settings.stat_4_value }}
          </span>
          <span class="social-proof__stat-label">{{ section.settings.stat_4_label }}</span>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Section heading {%- endcomment -%}
    <header class="social-proof__header{% unless request.design_mode %} animate-on-scroll stagger-2{% endunless %}">
      {%- if section.settings.eyebrow != blank -%}
        <span class="section-eyebrow section-eyebrow--light">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="social-proof__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="social-proof__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    {%- comment -%} Testimonial cards {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="social-proof__testimonials grid-3">
        {%- for block in section.blocks -%}
          {%- if block.type == 'testimonial' -%}
          <article
            class="social-proof__card card-dark{% unless request.design_mode %} animate-on-scroll stagger-{{ forloop.index | plus: 2 }}{% endunless %}"
            {{ block.shopify_attributes }}
          >
            <div class="social-proof__card-stars" aria-label="{{ block.settings.rating }} out of 5 stars">
              {%- for i in (1..5) -%}
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  {%- if i <= block.settings.rating -%}
                    <path d="M9 1.5l2.12 4.3 4.74.69-3.43 3.34.81 4.72L9 12.26l-4.24 2.29.81-4.72L2.14 6.49l4.74-.69L9 1.5z" fill="#FFB800"/>
                  {%- else -%}
                    <path d="M9 1.5l2.12 4.3 4.74.69-3.43 3.34.81 4.72L9 12.26l-4.24 2.29.81-4.72L2.14 6.49l4.74-.69L9 1.5z" fill="rgba(255,255,255,0.12)"/>
                  {%- endif -%}
                </svg>
              {%- endfor -%}
            </div>

            <blockquote class="social-proof__card-quote">
              <p>{{ block.settings.quote }}</p>
            </blockquote>

            <footer class="social-proof__card-author">
              {%- if block.settings.avatar != blank -%}
                <img
                  class="social-proof__avatar"
                  src="{{ block.settings.avatar | image_url: width: 80 }}"
                  alt="{{ block.settings.name }}"
                  width="40"
                  height="40"
                  loading="lazy"
                >
              {%- else -%}
                <div class="social-proof__avatar social-proof__avatar--placeholder">
                  {{ block.settings.name | slice: 0 }}
                </div>
              {%- endif -%}
              <div class="social-proof__author-info">
                <strong class="social-proof__author-name">{{ block.settings.name }}</strong>
                {%- if block.settings.business_type != blank -%}
                  <span class="social-proof__author-role">{{ block.settings.business_type }}</span>
                {%- endif -%}
              </div>
            </footer>
          </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #social-proof-{{ section.id }} {
    background: {{ section.settings.background_color }};
    padding: 100px 0;
    color: #ffffff;
  }

  #social-proof-{{ section.id }} .social-proof__stats {
    display: flex;
    justify-content: center;
    gap: 64px;
    flex-wrap: wrap;
    margin-bottom: 72px;
    padding-bottom: 72px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  #social-proof-{{ section.id }} .social-proof__stat-item {
    text-align: center;
  }

  #social-proof-{{ section.id }} .social-proof__stat-value {
    display: block;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, #ffffff, #00D4AA);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.1;
  }

  #social-proof-{{ section.id }} .social-proof__stat-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 6px;
  }

  #social-proof-{{ section.id }} .social-proof__header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 56px;
  }

  #social-proof-{{ section.id }} .section-eyebrow--light {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #6C63FF;
    margin-bottom: 12px;
  }

  #social-proof-{{ section.id }} .social-proof__heading {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 16px;
  }

  #social-proof-{{ section.id }} .social-proof__subheading {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
  }

  #social-proof-{{ section.id }} .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  #social-proof-{{ section.id }} .card-dark {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    transition: all 0.35s ease;
  }

  #social-proof-{{ section.id }} .card-dark:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(108,99,255,0.2);
    transform: translateY(-2px);
  }

  #social-proof-{{ section.id }} .social-proof__card-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 20px;
  }

  #social-proof-{{ section.id }} .social-proof__card-quote {
    margin: 0 0 24px;
    flex: 1;
  }

  #social-proof-{{ section.id }} .social-proof__card-quote p {
    font-size: 1rem;
    line-height: 1.65;
    color: rgba(255,255,255,0.75);
    margin: 0;
    font-style: italic;
  }

  #social-proof-{{ section.id }} .social-proof__card-author {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  #social-proof-{{ section.id }} .social-proof__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
  }

  #social-proof-{{ section.id }} .social-proof__avatar--placeholder {
    background: linear-gradient(135deg, #6C63FF, #00D4AA);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    text-transform: uppercase;
  }

  #social-proof-{{ section.id }} .social-proof__author-name {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: #ffffff;
  }

  #social-proof-{{ section.id }} .social-proof__author-role {
    display: block;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
  }

  @media (max-width: 991px) {
    #social-proof-{{ section.id }} .grid-3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    #social-proof-{{ section.id }} .grid-3 {
      grid-template-columns: 1fr;
    }
    #social-proof-{{ section.id }} .social-proof__stats {
      gap: 32px;
    }
  }

  {% if request.design_mode %}
    #social-proof-{{ section.id }} .animate-on-scroll {
      opacity: 1;
      transform: none;
    }
  {% endif %}
</style>

<script>
  (function() {
    var section = document.getElementById('social-proof-{{ section.id }}');
    if (!section) return;
    var counters = section.querySelectorAll('.social-proof__stat-value[data-target]');
    var animated = false;

    function animateCounters() {
      if (animated) return;
      animated = true;
      counters.forEach(function(el) {
        var raw = el.getAttribute('data-target');
        var suffix = raw.replace(/[\d.]/g, '');
        var target = parseFloat(raw);
        if (isNaN(target)) return;
        var duration = 2000;
        var start = performance.now();
        function tick(now) {
          var progress = Math.min((now - start) / duration, 1);
          var eased = 1 - Math.pow(1 - progress, 3);
          var current = Math.round(eased * target);
          el.textContent = current + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      });
    }

    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            animateCounters();
            observer.disconnect();
          }
        });
      }, { threshold: 0.3 });
      observer.observe(section.querySelector('.social-proof__stats'));
    }
  })();
</script>

