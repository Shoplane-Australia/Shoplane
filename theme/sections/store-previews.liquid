<section
  id="store-previews-{{ section.id }}"
  class="store-previews section-lg"
  data-section-id="{{ section.id }}"
  data-section-type="store-previews"
>
  <div class="container">
    <header class="store-previews__header animate-on-scroll stagger-1">
      <h2 class="store-previews__heading">
        {{ section.settings.heading }}
      </h2>
      {%- if section.settings.description != blank -%}
        <p class="store-previews__description">
          {{ section.settings.description }}
        </p>
      {%- endif -%}
    </header>
  </div>

  <div class="store-previews__track-wrapper animate-on-scroll stagger-2">
    <div class="store-previews__track" data-auto-scroll="{{ section.settings.auto_scroll }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'store_preview' -%}
          <a
            href="{{ block.settings.url | default: '#' }}"
            class="store-previews__item"
            {{ block.shopify_attributes }}
          >
            <div class="store-previews__item-media">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 520 }}"
                  alt="{{ block.settings.store_name | escape }}"
                  loading="lazy"
                  width="520"
                  height="340"
                >
              {%- else -%}
                <div class="store-previews__item-placeholder">
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>
            {%- if block.settings.store_name != blank -%}
              <span class="store-previews__item-name">{{ block.settings.store_name }}</span>
            {%- endif -%}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #store-previews-{{ section.id }} {
    background: var(--color-background);
    padding: var(--space-3xl) 0;
    overflow: hidden;
  }

  #store-previews-{{ section.id }} .store-previews__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto var(--space-2xl);
  }

  #store-previews-{{ section.id }} .store-previews__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
  }

  #store-previews-{{ section.id }} .store-previews__description {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  #store-previews-{{ section.id }} .store-previews__track-wrapper {
    position: relative;
    width: 100%;
  }

  #store-previews-{{ section.id }} .store-previews__track {
    display: flex;
    gap: var(--space-lg);
    overflow-x: auto;
    scroll-behavior: smooth;
    padding: 0 var(--space-lg) var(--space-md);
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  #store-previews-{{ section.id }} .store-previews__track::-webkit-scrollbar {
    display: none;
  }

  #store-previews-{{ section.id }} .store-previews__item {
    flex: 0 0 260px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease;
  }

  #store-previews-{{ section.id }} .store-previews__item:hover {
    transform: translateY(-4px);
  }

  #store-previews-{{ section.id }} .store-previews__item-media {
    width: 260px;
    height: 170px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.3s ease;
  }

  #store-previews-{{ section.id }} .store-previews__item:hover .store-previews__item-media {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  #store-previews-{{ section.id }} .store-previews__item-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #store-previews-{{ section.id }} .store-previews__item-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #store-previews-{{ section.id }} .store-previews__item-placeholder .placeholder-svg {
    width: 40%;
    height: auto;
    opacity: 0.2;
  }

  #store-previews-{{ section.id }} .store-previews__item-name {
    display: block;
    margin-top: var(--space-xs);
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
    text-align: center;
  }

  @keyframes store-previews-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  #store-previews-{{ section.id }} .store-previews__track[data-auto-scroll="true"] {
    overflow: hidden;
    animation: store-previews-scroll 40s linear infinite;
    width: max-content;
  }

  #store-previews-{{ section.id }} .store-previews__track[data-auto-scroll="true"]:hover {
    animation-play-state: paused;
  }
</style>

<script>
  (function() {
    var section = document.getElementById('store-previews-{{ section.id }}');
    if (!section) return;
    var track = section.querySelector('.store-previews__track');
    if (!track || track.getAttribute('data-auto-scroll') !== 'true') return;
    var items = track.innerHTML;
    track.innerHTML = items + items;
  })();
</script>

{% schema %}
{
  "name": "Store Previews",
  "tag": "section",
  "class": "store-previews-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premium Stores. Real Results."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "A selection of beautifully designed, conversion-focused Shopify stores ready for you to launch."
    },
    {
      "type": "checkbox",
      "id": "auto_scroll",
      "label": "Enable auto-scroll",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "store_preview",
      "name": "Store Preview",
      "limit": 16,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Preview image"
        },
        {
          "type": "text",
          "id": "store_name",
          "label": "Store name",
          "default": "Premium Store"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Store link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Previews",
      "blocks": [
        { "type": "store_preview", "settings": { "store_name": "Haven Home" } },
        { "type": "store_preview", "settings": { "store_name": "Summit Outdoor" } },
        { "type": "store_preview", "settings": { "store_name": "PawHaus" } },
        { "type": "store_preview", "settings": { "store_name": "Volt Tech" } },
        { "type": "store_preview", "settings": { "store_name": "Luxe Living" } },
        { "type": "store_preview", "settings": { "store_name": "Trailblaze Co" } },
        { "type": "store_preview", "settings": { "store_name": "PetVibe" } },
        { "type": "store_preview", "settings": { "store_name": "GadgetFlow" } },
        { "type": "store_preview", "settings": { "store_name": "Coastal Home" } },
        { "type": "store_preview", "settings": { "store_name": "ZenFit Gear" } }
      ]
    }
  ]
}
{% endschema %}
