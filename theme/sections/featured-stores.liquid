<section
  id="featured-stores-{{ section.id }}"
  class="featured-stores section-lg"
  data-section-id="{{ section.id }}"
  data-section-type="featured-stores"
>
  <div class="container">
    <header class="featured-stores__header animate-on-scroll stagger-1">
      <h2 class="featured-stores__heading">
        {{ section.settings.heading }}
      </h2>
      {%- if section.settings.description != blank -%}
        <p class="featured-stores__description">
          {{ section.settings.description }}
        </p>
      {%- endif -%}
    </header>

    <div class="featured-stores__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'niche_card' -%}
          <a
            href="{{ block.settings.url | default: '#' }}"
            class="featured-stores__card{% unless request.design_mode %} animate-on-scroll stagger-{{ forloop.index | plus: 2 }}{% endunless %}"
            {{ block.shopify_attributes }}
          >
            <div class="featured-stores__card-media">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{% render 'auto-alt', title: block.settings.title, image: block.settings.image, fallback: section.settings.heading %}"
                  loading="lazy"
                  width="800"
                  height="500"
                >
              {%- else -%}
                <div class="featured-stores__card-placeholder">
                  <span class="featured-stores__placeholder-text">{{ block.settings.title }}</span>
                </div>
              {%- endif -%}
            </div>
            <div class="featured-stores__card-body">
              <h3 class="featured-stores__card-title">{{ block.settings.title }}</h3>
              {%- if block.settings.description != blank -%}
                <p class="featured-stores__card-desc">{{ block.settings.description }}</p>
              {%- endif -%}
              <span class="featured-stores__card-link">View stores</span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_text != blank -%}
      <div class="featured-stores__cta animate-on-scroll stagger-6">
        <a href="{{ section.settings.cta_url | default: '#' }}" class="btn btn-outline">
          {{ section.settings.cta_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #featured-stores-{{ section.id }} {
    background: var(--color-background, #FAFAF8);
    padding: var(--space-20) 0;
  }

  #featured-stores-{{ section.id }} .featured-stores__header {
    text-align: left;
    max-width: 640px;
    margin: 0 0 var(--space-12);
  }

  #featured-stores-{{ section.id }} .featured-stores__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0 0 var(--space-4);
  }

  #featured-stores-{{ section.id }} .featured-stores__description {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  #featured-stores-{{ section.id }} .featured-stores__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-8) var(--space-6);
    width: 100%;
  }

  #featured-stores-{{ section.id }} .featured-stores__card {
    display: flex;
    flex-direction: column;
    background: transparent;
    border: none;
    border-radius: 0;
    overflow: visible;
    text-decoration: none;
    color: inherit;
    transition: none;
  }

  #featured-stores-{{ section.id }} .featured-stores__card-media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-surface);
    margin-bottom: var(--space-4);
  }

  #featured-stores-{{ section.id }} .featured-stores__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease-out);
  }

  #featured-stores-{{ section.id }} .featured-stores__card:hover .featured-stores__card-media img {
    transform: scale(1.04);
  }

  #featured-stores-{{ section.id }} .featured-stores__card-placeholder {
    width: 100%;
    height: 100%;
    min-height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    color: var(--color-text-tertiary);
  }

  #featured-stores-{{ section.id }} .featured-stores__placeholder-text {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
  }

  #featured-stores-{{ section.id }} .featured-stores__card-body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0;
  }

  #featured-stores-{{ section.id }} .featured-stores__card-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
    letter-spacing: -0.02em;
  }

  #featured-stores-{{ section.id }} .featured-stores__card-desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  #featured-stores-{{ section.id }} .featured-stores__card-link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 0.5rem;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  #featured-stores-{{ section.id }} .featured-stores__cta {
    text-align: left;
    margin-top: var(--space-12);
  }

  @media (max-width: 1024px) {
    #featured-stores-{{ section.id }} .featured-stores__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }
  }

  @media (max-width: 640px) {
    #featured-stores-{{ section.id }} .featured-stores__grid {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
  }

  {% if request.design_mode %}
    #featured-stores-{{ section.id }} .animate-on-scroll {
      opacity: 1;
      transform: none;
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "Featured Stores",
  "tag": "section",
  "class": "featured-stores-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Browse Stores by Niche"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Explore high-converting Shopify stores across proven, in-demand niches."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "View All Stores"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button link"
    }
  ],
  "blocks": [
    {
      "type": "niche_card",
      "name": "Niche Card",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Niche name",
          "default": "Home & Living"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Tag line",
          "default": "Modern home decor and essentials"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Card link"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Badge text (unused)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Stores",
      "blocks": [
        {
          "type": "niche_card",
          "settings": {
            "title": "Home & Living",
            "description": "Modern home decor and essentials"
          }
        },
        {
          "type": "niche_card",
          "settings": {
            "title": "Outdoor Living",
            "description": "Adventure gear and outdoor lifestyle"
          }
        },
        {
          "type": "niche_card",
          "settings": {
            "title": "Pet Supplies",
            "description": "Premium products for happy pets"
          }
        },
        {
          "type": "niche_card",
          "settings": {
            "title": "Tech & Gadgets",
            "description": "Cutting-edge tech accessories"
          }
        }
      ]
    }
  ]
}
{% endschema %}
