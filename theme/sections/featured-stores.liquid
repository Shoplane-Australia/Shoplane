<section
  id="featured-stores-{{ section.id }}"
  class="featured-stores section-lg"
  data-section-id="{{ section.id }}"
  data-section-type="featured-stores"
>
  <div class="container">
    <header class="featured-stores__header animate-on-scroll stagger-1">
      <h2 class="featured-stores__heading">
        {{ section.settings.heading }}
      </h2>
      {%- if section.settings.description != blank -%}
        <p class="featured-stores__description">
          {{ section.settings.description }}
        </p>
      {%- endif -%}
    </header>

    <div class="featured-stores__grid animate-on-scroll stagger-2">
      {%- for block in section.blocks -%}
        {%- if block.type == 'niche_card' -%}
          <a
            href="{{ block.settings.url | default: '#' }}"
            class="featured-stores__card animate-on-scroll stagger-{{ forloop.index | plus: 2 }}"
            {{ block.shopify_attributes }}
          >
            <div class="featured-stores__card-media">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.title | escape }}"
                  loading="lazy"
                  width="800"
                  height="500"
                >
              {%- else -%}
                <div class="featured-stores__card-placeholder">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.4"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                  <span class="featured-stores__placeholder-text">{{ block.settings.title }}</span>
                </div>
              {%- endif -%}
              {%- if block.settings.tag != blank -%}
                <span class="featured-stores__card-tag">{{ block.settings.tag }}</span>
              {%- endif -%}
            </div>
            <div class="featured-stores__card-body">
              <div class="featured-stores__card-info">
                <h3 class="featured-stores__card-title">{{ block.settings.title }}</h3>
                {%- if block.settings.description != blank -%}
                  <p class="featured-stores__card-desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
              <span class="featured-stores__card-arrow" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_text != blank -%}
      <div class="featured-stores__cta animate-on-scroll stagger-6">
        <a href="{{ section.settings.cta_url | default: '#' }}" class="btn-secondary">
          {{ section.settings.cta_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #featured-stores-{{ section.id }} {
    background: var(--color-background);
    padding: var(--space-3xl) 0;
  }

  #featured-stores-{{ section.id }} .featured-stores__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto var(--space-2xl);
  }

  #featured-stores-{{ section.id }} .featured-stores__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
  }

  #featured-stores-{{ section.id }} .featured-stores__description {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  #featured-stores-{{ section.id }} .featured-stores__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  #featured-stores-{{ section.id }} .featured-stores__card {
    display: flex;
    flex-direction: column;
    background: var(--color-background);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }

  #featured-stores-{{ section.id }} .featured-stores__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.1);
  }

  #featured-stores-{{ section.id }} .featured-stores__card-media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-surface);
  }

  #featured-stores-{{ section.id }} .featured-stores__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  #featured-stores-{{ section.id }} .featured-stores__card:hover .featured-stores__card-media img {
    transform: scale(1.05);
  }

  #featured-stores-{{ section.id }} .featured-stores__card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: linear-gradient(135deg, var(--color-surface) 0%, #e8e6f0 100%);
    color: var(--color-text-secondary);
  }

  #featured-stores-{{ section.id }} .featured-stores__placeholder-text {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    opacity: 0.5;
  }

  #featured-stores-{{ section.id }} .featured-stores__card-tag {
    position: absolute;
    top: var(--space-sm);
    left: var(--space-sm);
    padding: 4px 12px;
    background: var(--color-accent);
    color: #ffffff;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: var(--radius-sm);
  }

  #featured-stores-{{ section.id }} .featured-stores__card-body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-lg);
  }

  #featured-stores-{{ section.id }} .featured-stores__card-info {
    flex: 1;
    min-width: 0;
  }

  #featured-stores-{{ section.id }} .featured-stores__card-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 4px;
  }

  #featured-stores-{{ section.id }} .featured-stores__card-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  #featured-stores-{{ section.id }} .featured-stores__card-arrow {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    transition: all 0.3s ease;
  }

  #featured-stores-{{ section.id }} .featured-stores__card:hover .featured-stores__card-arrow {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #ffffff;
  }

  #featured-stores-{{ section.id }} .featured-stores__cta {
    text-align: center;
    margin-top: var(--space-2xl);
  }

  #featured-stores-{{ section.id }} .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 36px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    background: transparent;
    border: 2px solid var(--color-text);
    border-radius: var(--radius-md);
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  #featured-stores-{{ section.id }} .btn-secondary:hover {
    background: var(--color-text);
    color: var(--color-background);
  }

  @media (max-width: 991px) {
    #featured-stores-{{ section.id }} .featured-stores__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    #featured-stores-{{ section.id }} .featured-stores__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Featured Stores",
  "tag": "section",
  "class": "featured-stores-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Browse Stores by Niche"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Explore high-converting Shopify stores across proven, in-demand niches."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "View All Stores"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button link"
    }
  ],
  "blocks": [
    {
      "type": "niche_card",
      "name": "Niche Card",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Niche name",
          "default": "Home & Living"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Tag line",
          "default": "Modern home decor and essentials"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Card link"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Badge text",
          "default": "High demand"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Stores",
      "blocks": [
        {
          "type": "niche_card",
          "settings": {
            "title": "Home & Living",
            "description": "Modern home decor and essentials",
            "tag": "High demand"
          }
        },
        {
          "type": "niche_card",
          "settings": {
            "title": "Outdoor Living",
            "description": "Adventure gear and outdoor lifestyle",
            "tag": "Trending"
          }
        },
        {
          "type": "niche_card",
          "settings": {
            "title": "Pet Supplies",
            "description": "Premium products for happy pets",
            "tag": "Evergreen"
          }
        },
        {
          "type": "niche_card",
          "settings": {
            "title": "Tech & Gadgets",
            "description": "Cutting-edge tech accessories",
            "tag": "Fast growing"
          }
        }
      ]
    }
  ]
}
{% endschema %}
