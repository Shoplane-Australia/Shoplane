{
  "name": "shoplane-theme",
  "private": true,
  "description": "Shoplane premium Shopify theme",
  "scripts": {
    "dev": "shopify theme dev --open --theme-editor-sync",
    "pull": "shopify theme pull --environment pull",
    "pull:all": "shopify theme pull --development",
    "push": "shopify theme push --environment push",
    "push:templates": "shopify theme push --environment push-templates",
    "push:config": "shopify theme push --environment push-homepage",
    "push:homepage": "shopify theme push --environment push-homepage",
    "push:footer": "shopify theme push --environment push-footer"
  }
}
