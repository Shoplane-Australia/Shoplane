  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading Font",
        "default": "syne_n7"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body Font",
        "default": "manrope_n4"
      },
      {
        "type": "range",
        "id": "font_body_scale",
        "label": "Body Font Size Scale",
        "min": 80,
        "max": 130,
        "step": 5,
        "unit": "%",
        "default": 100
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "text",
        "id": "social_facebook",
