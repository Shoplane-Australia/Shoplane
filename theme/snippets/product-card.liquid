{%- comment -%}
  Product Card — used in collections and featured grids.
  Required: product (Shopify product object)
  Optional: card_class (additional CSS classes)
{%- endcomment -%}

{%- assign card_product = product -%}

<article class="product-card card card-hover {{ card_class }}" itemscope itemtype="https://schema.org/Product">
  <a href="{{ card_product.url }}" class="product-card__link" aria-label="{{ card_product.title }}">
    <div class="product-card__media">
      {%- if card_product.featured_image -%}
        <img
          src="{{ card_product.featured_image | image_url: width: 600 }}"
          srcset="{{ card_product.featured_image | image_url: width: 300 }} 300w,
                  {{ card_product.featured_image | image_url: width: 450 }} 450w,
                  {{ card_product.featured_image | image_url: width: 600 }} 600w"
          sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
          alt="{{ card_product.featured_image.alt | default: card_product.title | escape }}"
          loading="lazy"
          width="{{ card_product.featured_image.width }}"
          height="{{ card_product.featured_image.height }}"
          class="product-card__image"
          itemprop="image"
        >
      {%- else -%}
        <div class="product-card__placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
        </div>
      {%- endif -%}

      {%- if card_product.type != blank -%}
        <span class="product-card__badge badge">{{ card_product.type }}</span>
      {%- endif -%}
    </div>

    <div class="product-card__content">
      <h3 class="product-card__title" itemprop="name">{{ card_product.title }}</h3>

      {%- if card_product.description != blank -%}
        <p class="product-card__excerpt">{{ card_product.description | strip_html | truncate: 100 }}</p>
      {%- endif -%}

      <div class="product-card__footer">
        <div class="product-card__price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <meta itemprop="priceCurrency" content="{{ shop.currency }}">
          {%- if card_product.price_varies -%}
            <span class="product-card__price-label">From</span>
          {%- endif -%}
          <span class="product-card__price-value" itemprop="price" content="{{ card_product.price | money_without_currency }}">
            {{ card_product.price | money }}
          </span>
          <link itemprop="availability" href="https://schema.org/{% if card_product.available %}InStock{% else %}OutOfStock{% endif %}">
        </div>

        <span class="product-card__cta btn btn-sm btn-secondary">
          View Details
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </span>
      </div>
    </div>
  </a>
</article>
