{%- comment -%}Trust Badges Strip — horizontal row of trust signals{%- endcomment -%}

<div class="trust-bar {{ modifier_class }}" {% if section_id %}id="{{ section_id }}"{% endif %}>
  <div class="container">
    <div class="trust-bar__inner">
      {%- if settings.trust_badge_1 != blank -%}
      <div class="trust-badge animate-on-scroll stagger-1">
        <svg class="trust-badge__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 12 15 16 10"></polyline></svg>
        <span>{{ settings.trust_badge_1 }}</span>
      </div>
      {%- endif -%}
      {%- if settings.trust_badge_2 != blank -%}
      <div class="trust-badge animate-on-scroll stagger-2">
        <svg class="trust-badge__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        <span>{{ settings.trust_badge_2 }}</span>
      </div>
      {%- endif -%}
      {%- if settings.trust_badge_3 != blank -%}
      <div class="trust-badge animate-on-scroll stagger-3">
        <svg class="trust-badge__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
        <span>{{ settings.trust_badge_3 }}</span>
      </div>
      {%- endif -%}
      {%- if settings.trust_badge_4 != blank -%}
      <div class="trust-badge animate-on-scroll stagger-4">
        <svg class="trust-badge__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        <span>{{ settings.trust_badge_4 }}</span>
      </div>
      {%- endif -%}
    </div>
  </div>
</div>
