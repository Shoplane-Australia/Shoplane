{%- comment -%}
  Service card — used on services landing & category pages.
  Required: product (Shopify product object)
{%- endcomment -%}

{%- liquid
  assign service_product = product
  assign service_badge = badge
  if service_badge == blank
    if service_product.tags contains 'Australia Only' or service_product.tags contains 'australia-only'
      assign service_badge = 'Australia Only'
    else
      assign service_badge = 'Worldwide'
    endif
  endif
  assign service_excerpt = service_product.description | strip_html | truncate: 120
-%}

<article class="service-card">
  <a href="{{ service_product.url }}" class="service-card__link">
    <div class="service-card__media">
      {%- if service_product.featured_image != blank -%}
        {%- capture service_alt -%}
          {%- render 'auto-alt', title: service_product.title, image: service_product.featured_image -%}
        {%- endcapture -%}
        {{
          service_product.featured_image
          | image_url: width: 800
          | image_tag:
            class: 'service-card__image',
            loading: 'lazy',
            widths: '400, 600, 800',
            sizes: '(max-width: 768px) 100vw, 50vw',
            alt: service_alt
        }}
      {%- else -%}
        <div class="service-card__media-placeholder">
          <span class="service-card__media-title">{{ service_product.title }}</span>
        </div>
      {%- endif -%}
      {%- if service_badge != blank -%}
        <span class="service-card__badge">{{ service_badge }}</span>
      {%- endif -%}
    </div>
    <div class="service-card__body">
      <h3 class="service-card__title">{{ service_product.title }}</h3>
      {%- if service_excerpt != blank -%}
        <p class="service-card__excerpt">{{ service_excerpt }}</p>
      {%- endif -%}
      <span class="service-card__cta">
        Learn more
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </div>
  </a>
</article>
