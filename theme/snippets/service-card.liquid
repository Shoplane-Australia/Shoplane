{%- comment -%}
  Service card — editorial light
{%- endcomment -%}

{%- liquid
  assign service_product = product
  assign service_excerpt = service_product.description | strip_html | truncate: 100
  assign is_popular = false
  if service_product.tags contains 'popular' or service_product.tags contains 'most-popular' or service_product.tags contains 'MOST POPULAR'
    assign is_popular = true
  endif
-%}

<article class="service-card{% if is_popular %} service-card--featured{% endif %}">
  <a href="{{ service_product.url }}" class="service-card__link">
    <div class="service-card__media">
      {%- if service_product.featured_image != blank -%}
        {%- capture service_alt -%}
          {%- render 'auto-alt', title: service_product.title, image: service_product.featured_image -%}
        {%- endcapture -%}
        {{
          service_product.featured_image
          | image_url: width: 800
          | image_tag:
            class: 'service-card__image',
            loading: 'lazy',
            widths: '400, 600, 800',
            sizes: '(max-width: 768px) 100vw, 50vw',
            alt: service_alt
        }}
      {%- else -%}
        <div class="service-card__media-placeholder">
          <span>{{ service_product.title | truncate: 28 }}</span>
        </div>
      {%- endif -%}
    </div>

    <div class="service-card__body">
      {%- if is_popular -%}
        <span class="service-card__type">Popular</span>
      {%- endif -%}
      <h3 class="service-card__title">{{ service_product.title }}</h3>
      {%- if service_excerpt != blank -%}
        <p class="service-card__excerpt">{{ service_excerpt }}</p>
      {%- endif -%}
      <div class="service-card__footer">
        <span class="service-card__price">
          {%- if service_product.price_varies -%}From {% endif -%}
          {{ service_product.price | money }}
        </span>
        <span class="service-card__cta">View details</span>
      </div>
    </div>
  </a>
</article>

<style>
  .service-card {
    background: transparent;
    border: none;
  }

  .service-card__link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .service-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-surface);
    margin-bottom: 1rem;
  }

  .service-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .service-card__link:hover .service-card__image {
    transform: scale(1.04);
  }

  .service-card__media-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    color: var(--color-text-tertiary);
    font-family: var(--font-heading);
    padding: 1rem;
    text-align: center;
  }

  .service-card__type {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
    display: block;
  }

  .service-card__title {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 0.35rem;
    color: var(--color-text);
  }

  .service-card__excerpt {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .service-card__footer {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
  }

  .service-card__price {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
  }

  .service-card__cta {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
